{
    "task": [
        {
            "name": "ProtocolSpace",
            "label": "$task.ProtocolSpace.label",
            "entry": "ProtocolSpaceSchedule",
            "description": "$task.ProtocolSpace.description",
            "option": [
                "ProtocolSpaceSchedule",
                "AutoFightSetting",
                "ProtocolSpaceTeamChoose",
                "ProtocolSpaceSuccessAction",
                "ProtocolSpaceSuccessCount",
                "ProtocolSpaceFailedCount",
                "ProtocolSpaceTab"
            ],
            "controller": [
                "Win32-Front",
                "Wlroots"
            ],
            "group": [
                "sanity_sink"
            ]
        }
    ],
    "option": {
        "ProtocolSpaceSchedule": {
            "type": "checkbox",
            "label": "$option.TaskSchedule.label",
            "default_case": [
                "ProtocolSpaceScheduleMonday",
                "ProtocolSpaceScheduleTuesday",
                "ProtocolSpaceScheduleWednesday",
                "ProtocolSpaceScheduleThursday",
                "ProtocolSpaceScheduleFriday",
                "ProtocolSpaceScheduleSaturday",
                "ProtocolSpaceScheduleSunday"
            ],
            "cases": [
                {
                    "name": "ProtocolSpaceScheduleMonday",
                    "label": "$option.TaskScheduleMonday.label",
                    "pipeline_override": {
                        "ProtocolSpaceScheduleEnabled": {
                            "attach": {
                                "monday": true
                            }
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceScheduleTuesday",
                    "label": "$option.TaskScheduleTuesday.label",
                    "pipeline_override": {
                        "ProtocolSpaceScheduleEnabled": {
                            "attach": {
                                "tuesday": true
                            }
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceScheduleWednesday",
                    "label": "$option.TaskScheduleWednesday.label",
                    "pipeline_override": {
                        "ProtocolSpaceScheduleEnabled": {
                            "attach": {
                                "wednesday": true
                            }
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceScheduleThursday",
                    "label": "$option.TaskScheduleThursday.label",
                    "pipeline_override": {
                        "ProtocolSpaceScheduleEnabled": {
                            "attach": {
                                "thursday": true
                            }
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceScheduleFriday",
                    "label": "$option.TaskScheduleFriday.label",
                    "pipeline_override": {
                        "ProtocolSpaceScheduleEnabled": {
                            "attach": {
                                "friday": true
                            }
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceScheduleSaturday",
                    "label": "$option.TaskScheduleSaturday.label",
                    "pipeline_override": {
                        "ProtocolSpaceScheduleEnabled": {
                            "attach": {
                                "saturday": true
                            }
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceScheduleSunday",
                    "label": "$option.TaskScheduleSunday.label",
                    "pipeline_override": {
                        "ProtocolSpaceScheduleEnabled": {
                            "attach": {
                                "sunday": true
                            }
                        }
                    }
                }
            ]
        },
        "AutoFightSetting": {
            "type": "switch",
            "label": "$option.AutoFightSetting.label",
            "description": "$option.AutoFightSetting.description",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "AutoFightHealthDangerousSwitch",
                        "AutoFightDodge",
                        "AutoFightLockTarget",
                        "AutoFightAxis"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "ProtocolSpaceTeamChoose": {
            "type": "select",
            "label": "$option.ProtocolSpaceTeamChoose.label",
            "default_case": "ProtocolSpaceTeamChooseDefault",
            "cases": [
                {
                    "name": "ProtocolSpaceTeamChooseDefault",
                    "label": "$option.ProtocolSpaceTeamChoose.case.ProtocolSpaceTeamChooseDefault.label",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChoose": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceTeamChoose01",
                    "label": "01",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChooseTextRecognition": {
                            "expected": [
                                "01"
                            ]
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceTeamChoose02",
                    "label": "02",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChooseTextRecognition": {
                            "expected": [
                                "02"
                            ]
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceTeamChoose03",
                    "label": "03",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChooseTextRecognition": {
                            "expected": [
                                "03"
                            ]
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceTeamChoose04",
                    "label": "04",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChooseTextRecognition": {
                            "expected": [
                                "04"
                            ]
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceTeamChoose05",
                    "label": "05",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChooseTextRecognition": {
                            "expected": [
                                "05"
                            ]
                        }
                    }
                }
            ]
        },
        "ProtocolSpaceSuccessAction": {
            "type": "select",
            "label": "$option.ProtocolSpaceSuccessAction.label",
            "default_case": "RewardClaim",
            "cases": [
                {
                    "name": "RewardClaim",
                    "label": "$option.ProtocolSpaceSuccessAction.case.RewardClaim.label",
                    "pipeline_override": {
                        "ProtocolSpaceRewardSelectClaim": {
                            "enabled": true
                        },
                        "ProtocolSpaceRewardSelectNoClaim": {
                            "enabled": false
                        },
                        "ProtocolSpaceEnterSpaceSelectClaimReward": {
                            "enabled": true
                        },
                        "ProtocolSpaceEnterSpaceSelectNoClaimReward": {
                            "enabled": false
                        }
                    },
                    "option": [
                        "ProtocolSpaceUsePermit"
                    ]
                },
                {
                    "name": "NoRewardClaim",
                    "label": "$option.ProtocolSpaceSuccessAction.case.NoRewardClaim.label",
                    "pipeline_override": {
                        "ProtocolSpaceRewardSelectClaim": {
                            "enabled": false
                        },
                        "ProtocolSpaceRewardSelectNoClaim": {
                            "enabled": true
                        },
                        "ProtocolSpaceEnterSpaceSelectClaimReward": {
                            "enabled": false
                        },
                        "ProtocolSpaceEnterSpaceSelectNoClaimReward": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "ProtocolSpaceSuccessCount": {
            "type": "select",
            "label": "$option.ProtocolSpaceSuccessCount.label",
            "default_case": "ProtocolSpaceSuccessCountUnlimited",
            "cases": [
                {
                    "name": "ProtocolSpaceSuccessCount1",
                    "label": "1",
                    "pipeline_override": {
                        "ProtocolSpaceRewardClaimSuccessContinue": {
                            "max_hit": 0
                        },
                        "ProtocolSpaceRewardNoClaimSuccessContinue": {
                            "max_hit": 0
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceSuccessCount2",
                    "label": "2",
                    "pipeline_override": {
                        "ProtocolSpaceRewardClaimSuccessContinue": {
                            "max_hit": 1
                        },
                        "ProtocolSpaceRewardNoClaimSuccessContinue": {
                            "max_hit": 1
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceSuccessCount3",
                    "label": "3",
                    "pipeline_override": {
                        "ProtocolSpaceRewardClaimSuccessContinue": {
                            "max_hit": 2
                        },
                        "ProtocolSpaceRewardNoClaimSuccessContinue": {
                            "max_hit": 2
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceSuccessCount4",
                    "label": "4",
                    "pipeline_override": {
                        "ProtocolSpaceRewardClaimSuccessContinue": {
                            "max_hit": 3
                        },
                        "ProtocolSpaceRewardNoClaimSuccessContinue": {
                            "max_hit": 3
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceSuccessCount5",
                    "label": "5",
                    "pipeline_override": {
                        "ProtocolSpaceRewardClaimSuccessContinue": {
                            "max_hit": 4
                        },
                        "ProtocolSpaceRewardNoClaimSuccessContinue": {
                            "max_hit": 4
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceSuccessCountUnlimited",
                    "label": "$option.ProtocolSpaceCountUnlimited.label"
                }
            ]
        },
        "ProtocolSpaceFailedCount": {
            "type": "select",
            "label": "$option.ProtocolSpaceFailedCount.label",
            "default_case": "ProtocolSpaceFailedCount3",
            "cases": [
                {
                    "name": "ProtocolSpaceFailedCount1",
                    "label": "1",
                    "pipeline_override": {
                        "ProtocolSpaceOperationFailedContinue": {
                            "max_hit": 0
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceFailedCount2",
                    "label": "2",
                    "pipeline_override": {
                        "ProtocolSpaceOperationFailedContinue": {
                            "max_hit": 1
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceFailedCount3",
                    "label": "3",
                    "pipeline_override": {
                        "ProtocolSpaceOperationFailedContinue": {
                            "max_hit": 2
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceFailedCount4",
                    "label": "4",
                    "pipeline_override": {
                        "ProtocolSpaceOperationFailedContinue": {
                            "max_hit": 3
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceFailedCount5",
                    "label": "5",
                    "pipeline_override": {
                        "ProtocolSpaceOperationFailedContinue": {
                            "max_hit": 4
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceFailedCountUnlimited",
                    "label": "$option.ProtocolSpaceCountUnlimited.label"
                }
            ]
        },
        "ProtocolSpaceUsePermit": {
            "type": "switch",
            "label": "$option.ProtocolSpaceUsePermit.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ProtocolSpaceRewardUsePermit": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ProtocolSpaceRewardUsePermit": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "ProtocolSpaceTab": {
            "type": "select",
            "label": "$option.ProtocolSpaceTab.label",
            "cases": [
                {
                    "name": "OperatorProgression",
                    "label": "$option.OperatorProgression.label",
                    "pipeline_override": {
                        "ProtocolSpaceOperationalManualSwitchProtocolSpaceTab": {
                            "expected": [
                                "员养成",
                                "Operator Progression"
                            ],
                            "anchor": {
                                "ProtocolSpaceOperationalManualFindProtocolSpaceEnableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceNormalEnable",
                                "ProtocolSpaceOperationalManualFindProtocolSpaceDisableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceNormalDisable"
                            }
                        },
                        "ProtocolSpaceOperationalManualScrollEnd": {
                            "template": "ProtocolSpace/SkillUp.png"
                        }
                    },
                    "option": [
                        "OperatorProgression",
                        "ProtocolSpaceLevel"
                    ]
                },
                {
                    "name": "WeaponProgression",
                    "label": "$option.WeaponProgression.label",
                    "pipeline_override": {
                        "ProtocolSpaceOperationalManualSwitchProtocolSpaceTab": {
                            "expected": [
                                "武器养成",
                                "Weapon Progression"
                            ],
                            "anchor": {
                                "ProtocolSpaceOperationalManualFindProtocolSpaceEnableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceNormalEnable",
                                "ProtocolSpaceOperationalManualFindProtocolSpaceDisableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceNormalDisable"
                            }
                        },
                        "ProtocolSpaceOperationalManualScrollEnd": {
                            "template": [
                                "ProtocolSpace/WeaponTune.png",
                                "ProtocolSpace/WeaponTuneLow.png"
                            ]
                        }
                    },
                    "option": [
                        "WeaponProgression",
                        "ProtocolSpaceLevel"
                    ]
                },
                {
                    "name": "CrisisDrills",
                    "label": "$option.CrisisDrills.label",
                    "pipeline_override": {
                        "ProtocolSpaceOperationalManualSwitchProtocolSpaceTab": {
                            "expected": [
                                "危境预演",
                                "Crisis Drills"
                            ],
                            "anchor": {
                                "ProtocolSpaceOperationalManualFindProtocolSpaceEnableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceDeepDiveEnable",
                                "ProtocolSpaceOperationalManualFindProtocolSpaceDisableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceDeepDiveDisable"
                            }
                        },
                        "ProtocolSpaceOperationalManualScrollEnd": {
                            "template": [
                                "ProtocolSpace/AdvancedProgression5.png",
                                "ProtocolSpace/AdvancedProgression5Low.png"
                            ]
                        }
                    },
                    "option": [
                        "CrisisDrills"
                    ]
                }
            ]
        },
        "ProtocolSpaceLevel": {
            "type": "select",
            "label": "$option.ProtocolSpaceLevel.label",
            "default_case": "ProtocolSpaceLevel05",
            "cases": [
                {
                    "name": "ProtocolSpaceLevel01",
                    "label": "$option.ProtocolSpaceLevel.case.ProtocolSpaceLevel01.label",
                    "pipeline_override": {
                        "ProtocolSpaceLevelChoose": {
                            "recognition": {
                                "param": {"index": 0}
                            },
                            "next": [
                                "ProtocolSpacePrepareLock",
                                "ProtocolSpaceEnterSpace"
                            ]
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceLevel02",
                    "label": "$option.ProtocolSpaceLevel.case.ProtocolSpaceLevel02.label",
                    "pipeline_override": {
                        "ProtocolSpaceLevelChoose": {
                            "recognition": {
                                "param": {"index": 1}
                            },
                            "next": [
                                "ProtocolSpacePrepareLock",
                                "ProtocolSpaceEnterSpace"
                            ]
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceLevel03",
                    "label": "$option.ProtocolSpaceLevel.case.ProtocolSpaceLevel03.label",
                    "pipeline_override": {
                        "ProtocolSpaceLevelChoose": {
                            "recognition": {
                                "param": {"index": 2}
                            }
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceLevel04",
                    "label": "$option.ProtocolSpaceLevel.case.ProtocolSpaceLevel04.label",
                    "pipeline_override": {
                        "ProtocolSpaceLevelChoose": {
                            "recognition": {
                                "param": {"index": 3}
                            }
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceLevel05",
                    "label": "$option.ProtocolSpaceLevel.case.ProtocolSpaceLevel05.label",
                    "pipeline_override": {
                        "ProtocolSpaceLevelChoose": {
                            "recognition": {
                                "param": {"index": 4}
                            }
                        }
                    }
                }
            ]
        },
        "OperatorProgression": {
            "type": "select",
