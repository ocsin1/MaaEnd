{
    "task": [
        {
            "name": "ProtocolSpace",
            "label": "$task.ProtocolSpace.label",
            "entry": "ProtocolSpaceEntry",
            "description": "$task.ProtocolSpace.description",
            "option": [
                "AutoFightSetting",
                "ProtocolSpaceTeamChoose",
                "ProtocolSpaceSuccessCount",
                "ProtocolSpaceFailedCount",
                "ProtocolSpaceUsePermit",
                "ProtocolSpaceTab"
            ],
            "controller": [
                "Win32-Front",
                "Wlroots"
            ],
            "group": [
                "foreground"
            ]
        }
    ],
    "option": {
        "AutoFightSetting": {
            "type": "switch",
            "label": "$option.AutoFightSetting.label",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "AutoFightReserveSkillLevel",
                        "AutoFightHealthDangerousSwitch",
                        "AutoFightDodge",
                        "AutoFightLockTarget"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "ProtocolSpaceTeamChoose": {
            "type": "select",
            "label": "$option.ProtocolSpaceTeamChoose.label",
            "default_case": "ProtocolSpaceTeamChooseDefault",
            "cases": [
                {
                    "name": "ProtocolSpaceTeamChooseDefault",
                    "label": "$option.ProtocolSpaceTeamChoose.case.ProtocolSpaceTeamChooseDefault.label",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChoose": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceTeamChoose01",
                    "label": "01",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChooseTextRecognition": {
                            "expected": [
                                "01"
                            ]
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceTeamChoose02",
                    "label": "02",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChooseTextRecognition": {
                            "expected": [
                                "02"
                            ]
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceTeamChoose03",
                    "label": "03",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChooseTextRecognition": {
                            "expected": [
                                "03"
                            ]
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceTeamChoose04",
                    "label": "04",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChooseTextRecognition": {
                            "expected": [
                                "04"
                            ]
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceTeamChoose05",
                    "label": "05",
                    "pipeline_override": {
                        "ProtocolSpaceTeamChooseTextRecognition": {
                            "expected": [
                                "05"
                            ]
                        }
                    }
                }
            ]
        },
        "ProtocolSpaceSuccessCount": {
            "type": "select",
            "label": "$option.ProtocolSpaceSuccessCount.label",
            "default_case": "ProtocolSpaceSuccessCountUnlimited",
            "cases": [
                {
                    "name": "ProtocolSpaceSuccessCount1",
                    "label": "1",
                    "pipeline_override": {
                        "ProtocolSpaceOperationSuccessExitToWorldContinue": {
                            "max_hit": 0
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceSuccessCount2",
                    "label": "2",
                    "pipeline_override": {
                        "ProtocolSpaceOperationSuccessExitToWorldContinue": {
                            "max_hit": 1
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceSuccessCount3",
                    "label": "3",
                    "pipeline_override": {
                        "ProtocolSpaceOperationSuccessExitToWorldContinue": {
                            "max_hit": 2
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceSuccessCount4",
                    "label": "4",
                    "pipeline_override": {
                        "ProtocolSpaceOperationSuccessExitToWorldContinue": {
                            "max_hit": 3
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceSuccessCount5",
                    "label": "5",
                    "pipeline_override": {
                        "ProtocolSpaceOperationSuccessExitToWorldContinue": {
                            "max_hit": 4
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceSuccessCountUnlimited",
                    "label": "$option.ProtocolSpaceCountUnlimited.label"
                }
            ]
        },
        "ProtocolSpaceFailedCount": {
            "type": "select",
            "label": "$option.ProtocolSpaceFailedCount.label",
            "default_case": "ProtocolSpaceFailedCount3",
            "cases": [
                {
                    "name": "ProtocolSpaceFailedCount1",
                    "label": "1",
                    "pipeline_override": {
                        "ProtocolSpaceOperationFailedExitToWorldContinue": {
                            "max_hit": 0
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceFailedCount2",
                    "label": "2",
                    "pipeline_override": {
                        "ProtocolSpaceOperationFailedExitToWorldContinue": {
                            "max_hit": 1
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceFailedCount3",
                    "label": "3",
                    "pipeline_override": {
                        "ProtocolSpaceOperationFailedExitToWorldContinue": {
                            "max_hit": 2
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceFailedCount4",
                    "label": "4",
                    "pipeline_override": {
                        "ProtocolSpaceOperationFailedExitToWorldContinue": {
                            "max_hit": 3
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceFailedCount5",
                    "label": "5",
                    "pipeline_override": {
                        "ProtocolSpaceOperationFailedExitToWorldContinue": {
                            "max_hit": 4
                        }
                    }
                },
                {
                    "name": "ProtocolSpaceFailedCountUnlimited",
                    "label": "$option.ProtocolSpaceCountUnlimited.label"
                }
            ]
        },
        "ProtocolSpaceUsePermit": {
            "type": "switch",
            "label": "$option.ProtocolSpaceUsePermit.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ProtocolSpaceRewardUsePermit": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ProtocolSpaceRewardUsePermit": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "ProtocolSpaceTab": {
            "type": "select",
            "label": "$option.ProtocolSpaceTab.label",
            "cases": [
                {
                    "name": "OperatorProgression",
                    "label": "$option.OperatorProgression.label",
                    "pipeline_override": {
                        "ProtocolSpaceOperationalManualSwitchProtocolSpaceTab": {
                            "expected": [
                                "员养成",
                                "Operator Progression"
                            ],
                            "anchor": {
                                "ProtocolSpaceOperationalManualFindProtocolSpaceEnableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceNormalEnable",
                                "ProtocolSpaceOperationalManualFindProtocolSpaceDisableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceNormalDisable"
                            }
                        },
                        "ProtocolSpaceOperationalManualScrollEnd": {
                            "template": "ProtocolSpace/SkillUp.png"
                        }
                    },
                    "option": [
                        "OperatorProgression"
                    ]
                },
                {
                    "name": "WeaponProgression",
                    "label": "$option.WeaponProgression.label",
                    "pipeline_override": {
                        "ProtocolSpaceOperationalManualSwitchProtocolSpaceTab": {
                            "expected": [
                                "武器养成",
                                "Weapon Progression"
                            ],
                            "anchor": {
                                "ProtocolSpaceOperationalManualFindProtocolSpaceEnableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceNormalEnable",
                                "ProtocolSpaceOperationalManualFindProtocolSpaceDisableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceNormalDisable"
                            }
                        },
                        "ProtocolSpaceOperationalManualScrollEnd": {
                            "template": [
                                "ProtocolSpace/WeaponTune.png",
                                "ProtocolSpace/WeaponTuneLow.png"
                            ]
                        }
                    },
                    "option": [
                        "WeaponProgression"
                    ]
                },
                {
                    "name": "CrisisDrills",
                    "label": "$option.CrisisDrills.label",
                    "pipeline_override": {
                        "ProtocolSpaceOperationalManualSwitchProtocolSpaceTab": {
                            "expected": [
                                "危境预演",
                                "Crisis Drills"
                            ],
                            "anchor": {
                                "ProtocolSpaceOperationalManualFindProtocolSpaceEnableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceDeepDiveEnable",
                                "ProtocolSpaceOperationalManualFindProtocolSpaceDisableAnchor": "ProtocolSpaceOperationalManualFindProtocolSpaceDeepDiveDisable"
                            }
                        },
                        "ProtocolSpaceOperationalManualScrollEnd": {
                            "template": [
                                "ProtocolSpace/AdvancedProgression5.png",
                                "ProtocolSpace/AdvancedProgression5Low.png"
                            ]
                        }
                    },
                    "option": [
                        "CrisisDrills"
                    ]
                }
            ]
        },
        "OperatorProgression": {
            "type": "select",
            "label": "$option.OperatorProgression.label",
            "cases": [
                {
                    "name": "OperatorEXP",
                    "label": "$option.OperatorProgression.OperatorEXP.label",
                    "pipeline_override": {
                        "ProtocolSpaceFindTargetRecognition": {
                            "template": [
                                "ProtocolSpace/OperatorEXP.png",
                                "ProtocolSpace/OperatorEXPLow.png"
                            ]
                        }
                    },
                    "option": [
                        "RewardsSetOption"
                    ]
                },
                {
                    "name": "Promotions",
                    "label": "$option.OperatorProgression.Promotions.label",
                    "pipeline_override": {
                        "ProtocolSpaceFindTargetRecognition": {
                            "template": [
                                "ProtocolSpace/Promotions.png",
                                "ProtocolSpace/PromotionsLow.png"
                            ]
                        }
                    },
                    "option": [
                        "RewardsSetOption"
                    ]
                },
                {
                    "name": "T-Creds",
                    "label": "$option.OperatorProgression.TCreds.label",
                    "pipeline_override": {
                        "ProtocolSpaceFindTargetRecognition": {
                            "template": "ProtocolSpace/T-Creds.png"
                        }
                    }
                },
                {
                    "name": "SkillUp",
                    "label": "$option.OperatorProgression.SkillUp.label",
                    "pipeline_override": {
                        "ProtocolSpaceFindTargetRecognition": {
                            "template": [
                                "ProtocolSpace/SkillUp.png",
                                "ProtocolSpace/SkillUpLow.png"
                            ]
                        }
                    },
                    "option": [
                        "RewardsSetOption"
                    ]
                }
            ]
        },
        "WeaponProgression": {
            "type": "select",
            "label": "$option.WeaponProgression.label",
            "cases": [
                {
                    "name": "WeaponEXP",
                    "label": "$option.WeaponProgression.WeaponEXP.label",
                    "pipeline_override": {
                        "ProtocolSpaceFindTargetRecognition": {
                            "template": "ProtocolSpace/WeaponEXP.png"
                        }
                    }
                },
                {
                    "name": "WeaponTune",
                    "label": "$option.WeaponProgression.WeaponTune.label",
                    "pipeline_override": {
                        "ProtocolSpaceFindTargetRecognition": {
                            "template": [
                                "ProtocolSpace/WeaponTune.png",
                                "ProtocolSpace/WeaponTuneLow.png"
                            ]
                        }
                    },
                    "option": [
                        "RewardsSetOption"
                    ]
                }
            ]
        },
        "CrisisDrills": {
            "type": "select",
            "label": "$option.CrisisDrills.label",
            "cases": [
                {
                    "name": "AdvancedProgression1",
                    "label": "$option.CrisisDrills.AdvancedProgression1.label",
                    "pipeline_override": {
                        "ProtocolSpaceFindTargetRecognition": {
                            "template": "ProtocolSpace/AdvancedProgression1.png"
                        }
                    }
                },
                {
                    "name": "AdvancedProgression2",
                    "label": "$option.CrisisDrills.AdvancedProgression2.label",
                    "pipeline_override": {
                        "ProtocolSpaceFindTargetRecognition": {
                            "template": "ProtocolSpace/AdvancedProgression2.png"
                        }
                    }
                },
                {
                    "name": "AdvancedProgression3",
                    "label": "$option.CrisisDrills.AdvancedProgression3.label",
                    "pipeline_override": {
                        "ProtocolSpaceFindTargetRecognition": {
                            "template": "ProtocolSpace/AdvancedProgression3.png"
                        }
                    }
                },
                {
                    "name": "AdvancedProgression4",
                    "label": "$option.CrisisDrills.AdvancedProgression4.label",
                    "pipeline_override": {
                        "ProtocolSpaceFindTargetRecognition": {
                            "template": "ProtocolSpace/AdvancedProgression4.png"
                        }
                    }
                },
                {
                    "name": "AdvancedProgression5",
                    "label": "$option.CrisisDrills.AdvancedProgression5.label",
                    "pipeline_override": {
                        "ProtocolSpaceFindTargetRecognition": {
                            "template": "ProtocolSpace/AdvancedProgression5.png"
                        }
                    }
                }
            ]
        },
        "RewardsSetOption": {
            "type": "select",
            "label": "$option.RewardsSetOption.label",
            "cases": [
                {
                    "name": "RewardsSetA",
                    "label": "A",
                    "pipeline_override": {
                        "ProtocolSpaceNormalPrepareChooseRewardABText": {
                            "expected": [
                                "A"
                            ]
                        }
                    }
                },
                {
                    "name": "RewardsSetB",
                    "label": "B",
                    "pipeline_override": {
                        "ProtocolSpaceNormalPrepareChooseRewardABText": {
                            "expected": [
                                "B"
                            ]
                        }
                    }
                }
            ]
        }
    }
}
