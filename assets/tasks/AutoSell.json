{
    "task": [
        {
            "name": "AutoSell",
            "label": "$task.AutoSell.label",
            "entry": "AutoSellMain",
            "controller": [
                "Win32-Front",
                "Wlroots"
            ],
            "option": [
                "AutoSellValleyIV",
                "AutoSellWuling",
                "AutoSellPriceType"
            ],
            "group": [
                "regional_development"
            ]
        }
    ],
    "option": {
        "AutoSellValleyIV": {
            "type": "switch",
            "label": "$global.region.ValleyIV",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AutoSellScanValleyIVMain": {
                            "enabled": true
                        },
                        "AutoSellExecuteValleyIVMain": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "AutoSellTicketOverflowValleyIV"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "AutoSellScanValleyIVMain": {
                            "enabled": false
                        },
                        "AutoSellExecuteValleyIVMain": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoSellWuling": {
            "type": "switch",
            "label": "$global.region.Wuling",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AutoSellScanWulingMain": {
                            "enabled": true
                        },
                        "AutoSellExecuteWulingMain": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "AutoSellTicketOverflowWuling"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "AutoSellScanWulingMain": {
                            "enabled": false
                        },
                        "AutoSellExecuteWulingMain": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoSellPriceType": {
            "type": "select",
            "label": "$option.AutoSellPriceType.label",
            "default_case": "AutoSellPriceTypePerCategory",
            "cases": [
                {
                    "name": "AutoSellPriceTypeGlobal",
                    "label": "$option.AutoSellPriceTypeGlobal.label",
                    "option": [
                        "AutoSellPriceGlobal"
                    ]
                },
                {
                    "name": "AutoSellPriceTypePerCategory",
                    "label": "$option.AutoSellPriceTypePerCategory.label",
                    "option": [
                        "AutoSellPricePerCategory"
                    ]
                }
            ]
        },
        "AutoSellTicketOverflowValleyIV": {
            "type": "input",
            "label": "$option.AutoSellTicketOverflow.label",
            "inputs": [
                {
                    "name": "AutoSellTicketOverflowValleyIVValue",
                    "label": "$option.inputs.AutoSellTicketOverflowValue.label",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "default": "30000000"
                }
            ],
            "pipeline_override": {
                "AutoSellTicketValleyIVOverflow": {
                    "custom_recognition_param": {
                        "expression": "{AutoSellTicketOverflowValleyIVValue} < {AutoSellOwnTicketCountRecognition}",
                        "focus_matched_resolved_expression": true
                    }
                }
            }
        },
        "AutoSellTicketOverflowWuling": {
            "type": "input",
            "label": "$option.AutoSellTicketOverflow.label",
            "inputs": [
                {
                    "name": "AutoSellTicketOverflowWulingValue",
                    "label": "$option.inputs.AutoSellTicketOverflowValue.label",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "default": "30000000"
                }
            ],
            "pipeline_override": {
                "AutoSellTicketWulingOverflow": {
                    "custom_recognition_param": {
                        "expression": "{AutoSellTicketOverflowWulingValue} < {AutoSellOwnTicketCountRecognition}",
                        "focus_matched_resolved_expression": true
                    }
                }
            }
        },
        "AutoSellPriceGlobal": {
            "type": "input",
            "label": "$option.AutoSellPriceGlobal.label",
            "inputs": [
                {
                    "name": "AutoSellPriceGlobalValue",
                    "label": "$option.AutoSellPriceGlobal.inputs.AutoSellPriceGlobalValue.label",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "default": "4600"
                }
            ],
            "pipeline_override": {
                "AutoSellExecuteValleyIVMain": {
                    "custom_action_param": {
                        "region": "ValleyIV",
                        "moderate_price": "{AutoSellPriceGlobalValue}",
                        "large_price": "{AutoSellPriceGlobalValue}",
                        "massive_price": "{AutoSellPriceGlobalValue}"
                    }
                },
                "AutoSellExecuteWulingMain": {
                    "custom_action_param": {
                        "region": "Wuling",
                        "moderate_price": "{AutoSellPriceGlobalValue}",
                        "large_price": "{AutoSellPriceGlobalValue}",
                        "massive_price": "{AutoSellPriceGlobalValue}"
                    }
                }
            }
        },
        "AutoSellPricePerCategory": {
            "type": "input",
            "label": "$option.AutoSellPricePerCategory.label",
            "inputs": [
                {
                    "name": "AutoSellPricePerCategoryModeratePriceVolatilityValue",
                    "label": "$option.AutoSellPricePerCategory.inputs.AutoSellPricePerCategoryModeratePriceVolatilityValue.label",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "default": "4600"
                },
                {
                    "name": "AutoSellPricePerCategoryLargePriceVolatilityValue",
                    "label": "$option.AutoSellPricePerCategory.inputs.AutoSellPricePerCategoryLargePriceVolatilityValue.label",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "default": "5000"
                },
                {
                    "name": "AutoSellPricePerCategoryMassivePriceVolatilityValue",
                    "label": "$option.AutoSellPricePerCategory.inputs.AutoSellPricePerCategoryMassivePriceVolatilityValue.label",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "default": "5300"
                }
            ],
            "pipeline_override": {
                "AutoSellExecuteValleyIVMain": {
                    "custom_action_param": {
                        "region": "ValleyIV",
                        "moderate_price": "{AutoSellPricePerCategoryModeratePriceVolatilityValue}",
                        "large_price": "{AutoSellPricePerCategoryLargePriceVolatilityValue}",
                        "massive_price": "{AutoSellPricePerCategoryMassivePriceVolatilityValue}"
                    }
                },
                "AutoSellExecuteWulingMain": {
                    "custom_action_param": {
                        "region": "Wuling",
                        "moderate_price": "{AutoSellPricePerCategoryModeratePriceVolatilityValue}",
                        "large_price": "{AutoSellPricePerCategoryLargePriceVolatilityValue}",
                        "massive_price": "{AutoSellPricePerCategoryMassivePriceVolatilityValue}"
                    }
                }
            }
        }
    }
}
