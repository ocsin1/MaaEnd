{
    "task": [
        {
            "name": "VisitFriends",
            "label": "$task.VisitFriends.label",
            "entry": "VisitFriendsMain",
            "description": "$task.VisitFriends.description",
            "option": [
                "VisitFriendsRemark",
                "ProductionAssistType"
            ],
            "controller": [
                "Win32-Window",
                "Win32-Window-Background",
                "Win32-Front"
            ],
            "group": [
                "daily"
            ]
        }
    ],
    "option": {
        "VisitFriendsRemark": {
            "type": "switch",
            "label": "$option.VisitFriendsRemark.label",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "VisitFriendsRemark": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "VisitFriendsRemark": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "ProductionAssistType": {
            "type": "checkbox",
            "label": "$option.ProductionAssistType.label",
            "default_case": [
                "ProductionAssistControlNexus",
                "ProductionAssistMFGCabin",
                "ProductionAssistGrowthChamber"
            ],
            "cases": [
                {
                    "name": "ProductionAssistControlNexus",
                    "label": "$option.ProductionAssistType.ProductionAssistControlNexus.label",
                    "pipeline_override": {
                        "VisitFriendsMenuScanTargetFriendNormalOpen": {
                            "attach": {
                                "control_nexus_assist": true
                            }
                        },
                        "VisitFriendsMenuScanTargetFriendRemarkOpen": {
                            "attach": {
                                "control_nexus_assist": true
                            }
                        }
                    }
                },
                {
                    "name": "ProductionAssistMFGCabin",
                    "label": "$option.ProductionAssistType.ProductionAssistMFGCabin.label",
                    "pipeline_override": {
                        "VisitFriendsMenuScanTargetFriendNormalOpen": {
                            "attach": {
                                "mfg_cabin_assist": true
                            }
                        },
                        "VisitFriendsMenuScanTargetFriendRemarkOpen": {
                            "attach": {
                                "mfg_cabin_assist": true
                            }
                        }
                    }
                },
                {
                    "name": "ProductionAssistGrowthChamber",
                    "label": "$option.ProductionAssistType.ProductionAssistGrowthChamber.label",
                    "pipeline_override": {
                        "VisitFriendsMenuScanTargetFriendNormalOpen": {
                            "attach": {
                                "growth_chamber_assist": true
                            }
                        },
                        "VisitFriendsMenuScanTargetFriendRemarkOpen": {
                            "attach": {
                                "growth_chamber_assist": true
                            }
                        }
                    }
                }
            ]
        }
    }
}
