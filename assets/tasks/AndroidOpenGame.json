                    "pipeline_override": {
                        "AndroidOpenGame": {
                            "next": [
                                "AndroidOpenGame_CN"
                            ]
                        },
                        "CloseGame": {
                            "next": [
                                "CloseGame_CN"
                            ]
                        }
                    }
                },
                {
                    "name": "Bilibili",
                    "label": "$option.ClientVersion.cases.Bilibili.label",
                    "pipeline_override": {
                        "AndroidOpenGame": {
                            "next": [
                                "AndroidOpenGame_Bilibili"
                            ]
                        },
                        "CloseGame": {
