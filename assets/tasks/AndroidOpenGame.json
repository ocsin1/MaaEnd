                    }
                },
                {
                    "name": "VN",
                    "label": "$option.ClientVersion.cases.VN.label",
                    "pipeline_override": {
                        "AndroidOpenGame": {
                            "next": [
                                "AndroidOpenGame_VN"
                            ]
                        },
                        "CloseGame": {
                            "next": [
                                "CloseGame_VN"
                            ]
