                                "CloseGame_Bilibili"
                            ]
                        }
                    }
                },
                {
                    "name": "Global",
                    "label": "$option.ClientVersion.cases.Global.label",
                    "pipeline_override": {
                        "AndroidOpenGame": {
                            "next": [
