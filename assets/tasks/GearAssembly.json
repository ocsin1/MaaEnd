{
    "task": [
        {
            "name": "GearAssembly",
            "label": "$task.GearAssembly.label",
            "entry": "GearAssemblyStart",
            "description": "$task.GearAssembly.description",
            "option": [
                "GearAssemblySortOrder",
                "GearAssemblySelectionMethod"
            ],
            "group": [
                "daily"
            ]
        }
    ],
    "option": {
        "GearAssemblySortOrder": {
            "type": "select",
            "label": "$task.GearAssembly.option.GearAssemblySortOrder.label",
            "default_case": "Lower",
            "cases": [
                {
                    "name": "Lower",
                    "label": "$task.GearAssembly.option.GearAssemblySortOrder.cases.Lower.label",
                    "pipeline_override": {
                        "GearAssemblySwitchAscending": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Higher",
                    "label": "$task.GearAssembly.option.GearAssemblySortOrder.cases.Higher.label",
                    "pipeline_override": {
                        "GearAssemblySwitchAscending": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "GearAssemblySelectionMethod": {
            "type": "select",
            "label": "$task.GearAssembly.option.GearAssemblySelectionMethod.label",
            "default_case": "Auto",
            "cases": [
                {
                    "name": "Auto",
                    "label": "$task.GearAssembly.option.GearAssemblySelectionMethod.cases.Auto.label",
                    "pipeline_override": {
                        "GearAssemblyFirstAssemble": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "First",
                    "label": "$task.GearAssembly.option.GearAssemblySelectionMethod.cases.First.label",
                    "pipeline_override": {
                        "GearAssemblyFirstAssemble": {
                            "enabled": true
                        }
                    }
                }
            ]
        }
    }
}
