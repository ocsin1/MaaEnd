{
    "task": [
        {
            "name": "ResourceRecycleStation",
            "label": "$task.ResourceRecycleStation.label",
            "entry": "ResourceRecycleStationStart",
            "description": "$task.ResourceRecycleStation.description",
            "option": [
                "ResourceRecycleStationRegion"
            ],
            "controller": [
                "Win32-Window",
                "Win32-Window-Background",
                "Win32-Front"
            ],
            "group": [
                "open_world"
            ]
        }
    ],
    "option": {
        "ResourceRecycleStationRegion": {
            "type": "checkbox",
            "label": "$option.ResourceRecycleStationRegion.label",
            "default_case": [
                "Wuling",
                "ValleyIV"
            ],
            "cases": [
                {
                    "name": "Wuling",
                    "label": "$option.ResourceRecycleStationWuling.label",
                    "pipeline_override": {
                        "ResourceRecycleStationWulingSub": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "ValleyIV",
                    "label": "$option.ResourceRecycleStationValleyIV.label",
                    "pipeline_override": {
                        "ResourceRecycleStationValleyIVSub": {
                            "enabled": true
                        }
                    }
                }
            ]
        }
    }
}
