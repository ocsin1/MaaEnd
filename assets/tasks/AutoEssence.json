{
    "task": [
        {
            "name": "AutoEssence",
            "label": "$task.AutoEssence.label",
            "entry": "AutoEssenceMain",
            "description": "$task.AutoEssence.description",
            "controller": [
                "ADB",
                "Win32-Front"
            ],
            "option": [
                "AutoEssenceChallengeMode",
                "AutoEssenceObtainMode",
                "AutoEssenceDoOverride",
                "EssenceFilterAfterBattle",
                "AutoEssenceRepeatCount"
            ],
            "group": [
                "foreground"
            ]
        }
    ],
    "option": {
        "AutoEssenceChallengeMode": {
            "type": "select",
            "label": "$option.AutoEssenceChallengeMode.label",
            "description": "$option.AutoEssenceChallengeMode.description",
            "default_case": "Walk",
            "cases": [
                {
                    "name": "Walk",
                    "label": "$option.AutoEssenceChallengeMode.cases.Walk.label",
                    "pipeline_override": {
                        "AutoEssenceClickEssenceChallengeUsingWalk": {
                            "enabled": true
                        },
                        "AutoEssenceClickEssenceChallengeUsingAutoFight": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "AutoFight",
                    "label": "$option.AutoEssenceChallengeMode.cases.AutoFight.label",
                    "pipeline_override": {
                        "AutoEssenceClickEssenceChallengeUsingWalk": {
                            "enabled": false
                        },
                        "AutoEssenceClickEssenceChallengeUsingAutoFight": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "AutoEssenceObtainMode": {
            "type": "select",
            "label": "$option.AutoEssenceObtainMode.label",
            "description": "$option.AutoEssenceObtainMode.description",
            "default_case": "ObtainScaling1",
            "cases": [
                {
                    "name": "Discard",
                    "label": "$option.AutoEssenceObtainMode.cases.Discard.label",
                    "pipeline_override": {
                        "AutoEssenceClickObtainButtonPre": {
                            "next": [
                                "AutoEssenceClickDiscardButton"
                            ]
                        }
                    }
                },
                {
                    "name": "ObtainScaling1",
                    "label": "$option.AutoEssenceObtainMode.cases.ObtainScaling1.label",
                    "pipeline_override": {
                    }
                },
                {
                    "name": "ObtainScaling2",
                    "label": "$option.AutoEssenceObtainMode.cases.ObtainScaling2.label",
                    "pipeline_override": {
                        "AutoEssenceChooseScaling2": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "AutoEssenceDoOverride": {
            "type": "switch",
            "label": "$option.AutoEssenceDoOverride.label",
            "description": "$option.AutoEssenceDoOverride.description",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AutoEssenceChooseOverrideOff": {
                            "enabled": false
                        },
                        "AutoEssenceChooseOverrideOn": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "AutoEssenceChooseOverrideOff": {
                            "enabled": true
                        },
                        "AutoEssenceChooseOverrideOn": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoEssenceRepeatCount": {
            "type": "input",
            "label": "$option.AutoEssenceRepeatCount.label",
            "description": "$option.AutoEssenceRepeatCount.description",
            "inputs": [
                {
                    "name": "AutoEssenceRepeatCountValue",
                    "label": "$option.AutoEssenceRepeatCount.inputs.AutoEssenceRepeatCountValue.label",
                    "description": "$option.AutoEssenceRepeatCount.inputs.AutoEssenceRepeatCountValue.description",
                    "pipeline_type": "int",
                    "verify": "^(([1-9])|([1-9][0-9]))$",
                    "default": "1"
                }
            ],
            "pipeline_override": {
                "AutoEssenceMain": {
                    "max_hit": "{AutoEssenceRepeatCountValue}"
                },
                "AutoEssenceOnSuccess": {
                    "next": [
                        "AutoEssenceMain",
                        "[JumpBack]AutoEssenceAfterBattleRunEndLootReport",
                        "AutoEssenceOnComplete"
                    ]
                }
            }
        },
        "EssenceFilterAfterBattle": {
            "type": "switch",
            "label": "$option.EssenceFilterAfterBattle.label",
            "description": "$option.EssenceFilterAfterBattle.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleStart": {
                            "enabled": true
                        },
                        "AutoEssenceAfterBattleRunEndLootReport": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "EssenceFilterAfterBattleSelectInputLanguage",
                        "EssenceFilterAfterBattleSelectWeaponRarity",
                        "EssenceFilterAfterBattleSelectEssence",
                        "EssenceFilterAfterBattleSelectExtraRules"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleStart": {
                            "enabled": false
                        },
                        "AutoEssenceAfterBattleRunEndLootReport": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "EssenceFilterAfterBattleSelectInputLanguage": {
            "type": "select",
            "label": "$option.EssenceFilterAfterBattleSelectInputLanguage.label",
            "description": "$option.EssenceFilterAfterBattleSelectInputLanguage.description",
            "default_case": "CN",
            "cases": [
                {
                    "name": "CN",
                    "label": "$option.EssenceFilterAfterBattleSelectInputLanguage.cases.CN.label",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "input_language": "CN"
                            }
                        }
                    }
                },
                {
                    "name": "TC",
                    "label": "$option.EssenceFilterAfterBattleSelectInputLanguage.cases.TC.label",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "input_language": "TC"
                            }
                        }
                    }
                },
                {
                    "name": "EN",
                    "label": "$option.EssenceFilterAfterBattleSelectInputLanguage.cases.EN.label",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "input_language": "EN"
                            }
                        }
                    }
                },
                {
                    "name": "JP",
                    "label": "$option.EssenceFilterAfterBattleSelectInputLanguage.cases.JP.label",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "input_language": "JP"
                            }
                        }
                    }
                },
                {
                    "name": "KR",
                    "label": "$option.EssenceFilterAfterBattleSelectInputLanguage.cases.KR.label",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "input_language": "KR"
                            }
                        }
                    }
                }
            ]
        },
        "EssenceFilterAfterBattleSelectWeaponRarity": {
            "type": "switch",
            "label": "$option.SelectWeaponRarity.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "EssenceFilterAfterBattleRarity6Weapon",
                        "EssenceFilterAfterBattleRarity5Weapon",
                        "EssenceFilterAfterBattleRarity4Weapon"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "EssenceFilterAfterBattleRarity6Weapon": {
            "type": "switch",
            "label": "$option.Rarity6Weapon.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "rarity6_weapon": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "rarity6_weapon": false
                            }
                        }
                    }
                }
            ]
        },
        "EssenceFilterAfterBattleRarity5Weapon": {
            "type": "switch",
            "label": "$option.Rarity5Weapon.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "rarity5_weapon": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "rarity5_weapon": false
                            }
                        }
                    }
                }
            ]
        },
        "EssenceFilterAfterBattleRarity4Weapon": {
            "type": "switch",
            "label": "$option.Rarity4Weapon.label",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "rarity4_weapon": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "rarity4_weapon": false
                            }
                        }
                    }
                }
            ]
        },
        "EssenceFilterAfterBattleSelectEssence": {
            "type": "switch",
            "label": "$option.SelectEssence.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "EssenceFilterAfterBattleFlawlessEssence",
                        "EssenceFilterAfterBattlePureEssence"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "EssenceFilterAfterBattleFlawlessEssence": {
            "type": "switch",
            "label": "$option.FlawlessEssence.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "flawless_essence": true
                            }
                        },
                        "EssenceFilterAfterBattleIsflawless": {
                            "next": [
                                "EssenceAfterBattleYellowSlot1"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "flawless_essence": false
                            }
                        },
                        "EssenceFilterAfterBattleIsflawless": {
                            "next": [
                                "EssenceFilterAfterBattleRowNextItem"
                            ]
                        }
                    }
                }
            ]
        },
        "EssenceFilterAfterBattlePureEssence": {
            "type": "switch",
            "label": "$option.PureEssence.label",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "pure_essence": true
                            }
                        },
                        "EssenceFilterAfterBattleIsPure": {
                            "next": [
                                "EssenceAfterBattleYellowSlot1"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "pure_essence": false
                            }
                        },
                        "EssenceFilterAfterBattleIsPure": {
                            "next": [
                                "EssenceFilterAfterBattleRowNextItem"
                            ]
                        }
                    }
                }
            ]
        },
        "EssenceFilterAfterBattleSelectExtraRules": {
            "type": "switch",
            "label": "$option.SelectExtraRules.label",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "EssenceFilterAfterBattleKeepFuturePromising",
                        "EssenceFilterAfterBattleKeepSlot3Level3Practical",
                        "EssenceFilterAfterBattleDiscardUnmatched"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "EssenceFilterAfterBattleKeepFuturePromising": {
            "type": "switch",
            "label": "$option.KeepFuturePromising.label",
            "description": "$option.KeepFuturePromising.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "EssenceFilterAfterBattleFuturePromisingMinTotal",
                        "EssenceFilterAfterBattleLockFuturePromising"
                    ],
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "keep_future_promising": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "keep_future_promising": false
                            }
                        }
                    }
                }
            ]
        },
        "EssenceFilterAfterBattleLockFuturePromising": {
            "type": "switch",
            "label": "$option.LockFuturePromising.label",
            "description": "$option.LockFuturePromising.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "lock_future_promising": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "lock_future_promising": false
                            }
                        }
                    }
                }
            ]
        },
        "EssenceFilterAfterBattleFuturePromisingMinTotal": {
            "type": "input",
            "label": "$option.KeepFuturePromising.inputs.FuturePromisingMinTotal.label",
            "description": "$option.KeepFuturePromising.inputs.FuturePromisingMinTotal.description",
            "inputs": [
                {
                    "name": "EssenceFilterAfterBattleFuturePromisingMinTotal",
                    "label": "$option.KeepFuturePromising.inputs.FuturePromisingMinTotal.label",
                    "description": "$option.KeepFuturePromising.inputs.FuturePromisingMinTotal.description",
                    "pipeline_type": "int",
                    "verify": "^[3-9]$|^1[0-5]$",
                    "default": "6"
                }
            ],
            "pipeline_override": {
                "EssenceFilterAfterBattleInit": {
                    "attach": {
                        "future_promising_min_total": "{EssenceFilterAfterBattleFuturePromisingMinTotal}"
                    }
                }
            }
        },
        "EssenceFilterAfterBattleKeepSlot3Level3Practical": {
            "type": "switch",
            "label": "$option.KeepSlot3Level3Practical.label",
            "description": "$option.KeepSlot3Level3Practical.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "EssenceFilterAfterBattleSlot3MinLevel",
                        "EssenceFilterAfterBattleLockSlot3Practical"
                    ],
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "keep_slot3_level3_practical": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "keep_slot3_level3_practical": false
                            }
                        }
                    }
                }
            ]
        },
        "EssenceFilterAfterBattleLockSlot3Practical": {
            "type": "switch",
            "label": "$option.LockSlot3Practical.label",
            "description": "$option.LockSlot3Practical.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "lock_slot3_practical": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "lock_slot3_practical": false
                            }
                        }
                    }
                }
            ]
        },
        "EssenceFilterAfterBattleSlot3MinLevel": {
            "type": "input",
            "label": "$option.KeepSlot3Level3Practical.inputs.Slot3MinLevel.label",
            "description": "$option.KeepSlot3Level3Practical.inputs.Slot3MinLevel.description",
            "inputs": [
                {
                    "name": "EssenceFilterAfterBattleSlot3MinLevel",
                    "label": "$option.KeepSlot3Level3Practical.inputs.Slot3MinLevel.label",
                    "description": "$option.KeepSlot3Level3Practical.inputs.Slot3MinLevel.description",
                    "pipeline_type": "int",
                    "verify": "^[1-3]$",
                    "default": "3"
                }
            ],
            "pipeline_override": {
                "EssenceFilterAfterBattleInit": {
                    "attach": {
                        "slot3_min_level": "{EssenceFilterAfterBattleSlot3MinLevel}"
                    }
                }
            }
        },
        "EssenceFilterAfterBattleDiscardUnmatched": {
            "type": "switch",
            "label": "$option.DiscardUnmatched.label",
            "description": "$option.DiscardUnmatched.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "discard_unmatched": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterAfterBattleInit": {
                            "attach": {
                                "discard_unmatched": false
                            }
                        }
                    }
                }
            ]
        }
    }
}
