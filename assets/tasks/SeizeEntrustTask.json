{
    "task": [
        {
            "name": "SeizeEntrustTask",
            "label": "$task.SeizeEntrustTask.label",
            "entry": "SeizeEntrustTaskMain",
            "description": "$task.SeizeEntrustTask.description",
            "option": [
                "SeizeEntrustTaskisGoDepotNodeWorld"
            ],
            "controller": [
                "Win32-Front",
                "Win32-Window",
                "Win32-Window-Background",
                "Wlroots"
            ],
            "group": [
                "daily"
            ]
        }
    ],
    "option": {
        "SeizeEntrustTaskisGoDepotNodeWorld": {
            "type": "switch",
            "label": "$task.SeizeEntrustTaskisGoDepotNodeWorld.label",
            "description": "$task.SeizeEntrustTaskisGoDepotNodeWorld.description",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "SeizeEntrustTaskGoDepotNode": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "Yes",
                    "option": [
                        "SeizeEntrustTaskSelectDestination"
                    ],
                    "pipeline_override": {
                        "SeizeEntrustTaskGoDepotNode": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "SeizeEntrustTaskisWalkingToDepotNode": {
            "type": "switch",
            "label": "$task.SeizeEntrustTaskisWalkingToDepotNode.label",
            "description": "$task.SeizeEntrustTaskisWalkingToDepotNode.description",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "SeizeEntrustTaskWalkingToDepotNode": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SeizeEntrustTaskWalkingToDepotNode": {
                            "enabled": true
                        }
                    }
                }
            ],
            "controller": [
                "Win32-Front",
                "Wlroots"
            ]
        },
        "SeizeEntrustTaskSelectDestination": {
            "type": "select",
            "label": "选择要传送到的锚点",
            "description": "",
            "cases": [
                {
                    "name": "仓储节点上方锚点",
                    "option": [
                        "SeizeEntrustTaskisWalkingToDepotNode"
                    ],
                    "pipeline_override": {
                        "isSeizeEntrustTaskInMap": {
                            "next": [
                                "isSeizeEntrustTaskInWolrld",
                                "[JumpBack]SceneEnterWorldWulingWulingCity5"
                            ]
                        }
                    }
                },
                {
                    "name": "仓储节点左侧锚点",
                    "pipeline_override": {
                        "isSeizeEntrustTaskInMap": {
                            "next": [
                                "isSeizeEntrustTaskInWolrld",
                                "[JumpBack]SceneEnterWorldWulingWulingCity6"
                            ]
                        }
                    }
                }
            ]
        }
    }
}
