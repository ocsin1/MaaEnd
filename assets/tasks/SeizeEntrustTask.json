{
    "task": [
        {
            "name": "SeizeEntrustTask",
            "label": "$task.SeizeEntrustTask.label",
            "entry": "SeizeEntrustTaskMain",
            "option": [
                "SeizeEntrustTaskCommissionSource"
            ],
            "controller": [
                "Win32-Front",
                "Win32-Window",
                "Win32-Window-Background",
                "Wlroots"
            ],
            "group": [
                "regional_development"
            ]
        }
    ],
    "option": {
        "SeizeEntrustTaskCommissionSource": {
            "type": "select",
            "default_case": "WulingCity",
            "label": "$task.SeizeEntrustTaskCommissionSource.label",
            "cases": [
                {
                    "name": "WulingCity",
                    "label": "$task.SeizeEntrustTaskCommissionSource.cases.WulingCity.label",
                    "option": [
                        "SeizeEntrustTaskisGoDepotNodeWorld"
                    ]
                },
                {
                    "name": "TestArea",
                    "label": "$task.SeizeEntrustTaskCommissionSource.cases.TestArea.label",
                    "pipeline_override": {
                        "SeizeEntrustTaskGoDepotNode": {
                            "enabled": false
                        },
                        "SeizeEntrustTaskFindTarget": {
                            "recognition": {
                                "param": {
                                    "all_of": [
                                        {
                                            "sub_name": "WulingTpl",
                                            "recognition": {
                                                "type": "TemplateMatch",
                                                "param": {
                                                    "roi": [
                                                        841,
                                                        177,
                                                        48,
                                                        424
                                                    ],
                                                    "template": [
                                                        "SeizeEntrustTask/wuling.png"
                                                    ]
                                                }
                                            }
                                        },
                                        {
                                            "recognition": {
                                                "type": "OCR",
                                                "param": {
                                                    "roi": "WulingTpl",
                                                    "roi_offset": [
                                                        0,
                                                        30,
                                                        0,
                                                        -20
                                                    ],
                                                    "expected": [
                                                        "10.6"
                                                    ],
                                                    "only_rec": true
                                                }
                                            }
                                        },
                                        {
                                            "recognition": {
                                                "type": "OCR",
                                                "param": {
                                                    "roi": "WulingTpl",
                                                    "roi_offset": [
                                                        -215,
                                                        -6,
                                                        19,
                                                        -6
                                                    ],
                                                    "expected": [
                                                        "试验园区",
                                                        "實驗園區",
                                                        "(?i)Test\\s*Area",
                                                        "実験区域",
                                                        "실험 구역"
                                                    ]
                                                }
                                            }
                                        }
                                    ]
                                }
                            }
                        },
                        "SeizeEntrustTaskFindTargetF1": {
                            "recognition": {
                                "param": {
                                    "all_of": [
                                        {
                                            "sub_name": "WulingTpl",
                                            "recognition": {
                                                "type": "TemplateMatch",
                                                "param": {
                                                    "roi": [
                                                        841,
                                                        177,
                                                        48,
                                                        424
                                                    ],
                                                    "template": [
                                                        "SeizeEntrustTask/wuling.png"
                                                    ]
                                                }
                                            }
                                        },
                                        {
                                            "recognition": {
                                                "type": "OCR",
                                                "param": {
                                                    "roi": "WulingTpl",
                                                    "roi_offset": [
                                                        0,
                                                        30,
                                                        0,
                                                        -20
                                                    ],
                                                    "expected": [
                                                        "10.6"
                                                    ],
                                                    "only_rec": true
                                                }
                                            }
                                        },
                                        {
                                            "recognition": {
                                                "type": "OCR",
                                                "param": {
                                                    "roi": "WulingTpl",
                                                    "roi_offset": [
                                                        -215,
                                                        -6,
                                                        19,
                                                        -6
                                                    ],
                                                    "expected": [
                                                        "试验园区",
                                                        "實驗園區",
                                                        "(?i)Test\\s*Area",
                                                        "実験区域",
                                                        "실험 구역"
                                                    ]
                                                }
                                            }
                                        }
                                    ]
                                }
                            },
                            "focus": {
                                "Node.Recognition.Succeeded": "$task.SeizeEntrustTask.focus.testAreaFound"
                            }
                        }
                    }
                }
            ]
        },
        "SeizeEntrustTaskisGoDepotNodeWorld": {
            "type": "switch",
            "label": "$task.SeizeEntrustTaskisGoDepotNodeWorld.label",
            "description": "$task.SeizeEntrustTaskisGoDepotNodeWorld.description",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "SeizeEntrustTaskGoDepotNode": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "Yes",
                    "option": [
                        "SeizeEntrustTaskSelectDestination"
                    ],
                    "pipeline_override": {
                        "SeizeEntrustTaskGoDepotNode": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "SeizeEntrustTaskisWalkingToDepotNode": {
            "type": "switch",
            "label": "$task.SeizeEntrustTaskisWalkingToDepotNode.label",
            "description": "$task.SeizeEntrustTaskisWalkingToDepotNode.description",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "SeizeEntrustTaskWalkingToDepotNode": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SeizeEntrustTaskWalkingToDepotNode": {
                            "enabled": true
                        }
                    }
                }
            ],
            "controller": [
                "Win32-Front",
                "Wlroots"
            ]
        },
        "SeizeEntrustTaskSelectDestination": {
            "type": "select",
            "label": "选择要传送到的锚点",
            "description": "",
            "cases": [
                {
                    "name": "仓储节点上方锚点",
                    "option": [
                        "SeizeEntrustTaskisWalkingToDepotNode"
                    ],
                    "pipeline_override": {
                        "isSeizeEntrustTaskInMap": {
                            "next": [
                                "isSeizeEntrustTaskInWolrld",
                                "[JumpBack]SceneEnterWorldWulingWulingCity5"
                            ]
                        }
                    }
                },
                {
                    "name": "仓储节点左侧锚点",
                    "pipeline_override": {
                        "isSeizeEntrustTaskInMap": {
                            "next": [
                                "isSeizeEntrustTaskInWolrld",
                                "[JumpBack]SceneEnterWorldWulingWulingCity6"
                            ]
                        }
                    }
                }
            ]
        }
    }
}
