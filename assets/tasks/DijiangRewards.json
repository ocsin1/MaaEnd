        "AutoExtractSeed": {
            "type": "switch",
            "label": "$option.AutoExtrachSeed.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "GrowthChamberSeedExtract": {
                            "enabled": true
                        },
                        "GrowthChamberGrowExit": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "GrowthChamberCheckTargetNotEmpty": {
                            "recognition": {
                                "type": "And",
                                "param": {
                                    "all_of": [
                                        "GrowthChamberCheckSeedNotEmpty"
                                    ]
                                }
                            }
                        },
                        "GrowthChamberSeedExtract": {
                            "enabled": false
                        },
                        "GrowthChamberGrowExit": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
