{
    "task": [
        {
            "name": "DijiangRewards",
            "label": "$task.DijiangRewards.label",
            "entry": "DijiangRewards",
            "description": "$task.DijiangRewards.description",
            "option": [
                "AutoStartExchange",
                "StageTaskSetting",
                "ClueSetting",
                "SelectToGrow"
            ],
            "group": [
                "daily"
            ]
        }
    ],
    "option": {
        "AutoStartExchange": {
            "type": "switch",
            "label": "$option.AutoStartExchange.label",
            "description": "$option.AutoStartExchange.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ReceptionRoomStartExchange": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ReceptionRoomStartExchange": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "StageTaskSetting": {
            "type": "switch",
            "label": "$option.StageTaskSetting.label",
            "description": "$option.StageTaskSetting.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "FastCollect",
                        "RecoveryEmotionStage",
                        "ReceptionRoomStage",
                        "ManufacturingStage",
                        "GrowthChamberStage"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "FastCollect": {
            "type": "switch",
            "label": "$option.FastCollect.label",
            "description": "$option.FastCollect.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DijiangRewardsFastCollectProduction": {
                            "enabled": true
                        },
                        "DijiangRewardsFastCollectClues": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DijiangRewardsFastCollectProduction": {
                            "enabled": false
                        },
                        "DijiangRewardsFastCollectClues": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "RecoveryEmotionStage": {
            "type": "switch",
            "label": "$option.RecoveryEmotionStage.label",
            "description": "$option.RecoveryEmotionStage.description",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RecoveryEmotionMain": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RecoveryEmotionMain": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "ReceptionRoomStage": {
            "type": "switch",
            "label": "$option.ReceptionRoomStage.label",
            "description": "$option.ReceptionRoomStage.description",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "ReceptionRoomMain": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ReceptionRoomMain": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "ManufacturingStage": {
            "type": "switch",
            "label": "$option.ManufacturingStage.label",
            "description": "$option.ManufacturingStage.description",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "MFGCabinMain": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "MFGCabinMain": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "GrowthChamberStage": {
            "type": "switch",
            "label": "$option.GrowthChamberStage.label",
            "description": "$option.GrowthChamberStage.description",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "GrowthChamberMain": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "GrowthChamberMain": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "ClueSetting": {
            "type": "switch",
            "label": "$option.ClueSetting.label",
            "description": "$option.ClueSetting.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "ClueSend",
                        "ClueStockLimit"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "ReceptionRoomSendCluesSelectClues": {
                            "max_hit": 3
                        },
                        "ClueItemCount": {
                            "expected": "^(?:[3-9]|[1-9]\\d+)$"
                        }
                    }
                }
            ]
        },
        "ClueSend": {
            "type": "input",
            "label": "$option.ClueSend.label",
            "inputs": [
                {
                    "name": "MaxClueSend",
                    "label": "$option.ClueSend.MaxClueSend.label",
                    "pipeline_type": "int",
                    "default": "3"
                }
            ],
            "pipeline_override": {
                "ReceptionRoomSendCluesSelectClues": {
                    "max_hit": "{MaxClueSend}"
                }
            }
        },
        "ClueStockLimit": {
            "type": "select",
            "label": "$option.ClueStockLimit.label",
            "description": "$option.ClueStockLimit.description",
            "default_case": "2",
            "cases": [
                {
                    "name": "1",
                    "label": "$option.ClueStockLimit.cases.1.label",
                    "pipeline_override": {
                        "ClueItemCount": {
                            "expected": "^(?:[2-9]|[1-9]\\d+)$"
                        }
                    }
                },
                {
                    "name": "2",
                    "label": "$option.ClueStockLimit.cases.2.label",
                    "pipeline_override": {
                        "ClueItemCount": {
                            "expected": "^(?:[3-9]|[1-9]\\d+)$"
                        }
                    }
                }
            ]
        },
