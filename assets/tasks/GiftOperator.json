        "OnlyReceiveGift": {
            "type": "switch",
            "label": "$option.OnlyReceiveGift.label",
            "description": "$option.OnlyReceiveGift.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "AcceptAllGifts"
                    ],
                    "pipeline_override": {
                        "GiftOperatorContacSortOrder": {
                            "enabled": false
                        },
                        "GiftOperatorContacSortBy": {
                            "enabled": false
                        },
                        "GiftOperatorSelectOp1": {
                            "enabled": false
                        },
                        "GiftOperatorSelectGiftOp": {
                            "enabled": true
                        },
                        "GiftOperatorSelectSpecifiedOp": {
                            "enabled": false
                        },
                        "GiftOperatorName": {
                            "expected": [
                                ".*"
                            ]
                        },
                        "GiftOperatorReceiveDialog": {
                            "next": []
                        },
                        "GiftOperatorSkipDialog": {
                            "next": [
                                "GiftOperatorBranchReceive",
                                "GiftOperatorLeave"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "option": [
                        "SelectOperator",
                        "SendWrongGift"
                    ],
                    "pipeline_override": {}
                }
            ]
        },
        "AcceptAllGifts": {
            "type": "switch",
            "label": "$option.AcceptAllGifts.label",
            "description": "$option.AcceptAllGifts.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "GiftOperatorReceiveDialog": {
                            "next": [
                                "GiftOperatorMain"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {}
                }
            ]
        },
        "GiftCount": {
            "type": "input",
            "label": "$option.GiftCount.label",
            "description": "$option.GiftCount.description",
            "inputs": [
                {
                    "name": "Count",
                    "label": "$option.GiftCount.inputs.Count.label",
                    "description": "$option.GiftCount.inputs.Count.description",
                    "pipeline_type": "int",
                    "verify": "^[1-9]\\d*$",
                    "default": "1"
                }
            ],
            "pipeline_override": {
                "GiftOperatorClickGift": {
                    "repeat": "{Count}",
                    "repeat_delay": 100
                }
            }
        },
        "SendWrongGift": {
            "type": "switch",
            "label": "$option.SendWrongGift.label",
            "description": "$option.SendWrongGift.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "GiftOperatorClickGift": {
                            "repeat": 1
                        },
                        "GiftOperatorClickGiftColorNumber": {
                            "recognition": {
                                "param": {
                                    "index": -1
                                }
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "option": [
                        "GiftCount"
                    ],
                    "pipeline_override": {}
                }
            ]
        }
    }
}
