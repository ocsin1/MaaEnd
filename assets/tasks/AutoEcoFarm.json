{
    "task": [
        {
            "name": "AutoEcoFarm",
            "label": "$task.AutoEcoFarm.label",
            "entry": "AutoEcoFarmMain",
            "description": "$task.AutoEcoFarm.description",
            "controller": [
                "Win32-Front",
                "Wlroots"
            ],
            "option": [
                "SelectFarm",
                "FarmlandFindingScheme",
                "AutoEcoFarmClearBagBeforeTasks",
                "AutoEcoFarmClearBagAfterTasks"
            ],
            "group": [
                "foreground"
            ]
        }
    ],
    "option": {
        "SelectFarm": {
            "type": "switch",
            "label": "$task.AutoEcoFarm.option.SelectFarm.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "GotoValleyIV",
                        "GotoWulin"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "GotoValleyIV": {
            "type": "switch",
            "label": "$task.AutoEcoFarm.option.GotoValleyIV.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "_AutoEcoFarmInitStartValleyIV": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "_AutoEcoFarmInitStartValleyIV": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "GotoWulin": {
            "type": "switch",
            "label": "$task.AutoEcoFarm.option.GotoWulin.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "_AutoEcoFarmInitStartWulin": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "_AutoEcoFarmInitStartWulin": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "FarmlandFindingScheme": {
            "type": "select",
            "label": "$task.AutoEcoFarm.option.FarmlandFindingScheme.label",
            "description": "$task.AutoEcoFarm.option.FarmlandFindingScheme.description",
            "default_case": "Center",
            "cases": [
                {
                    "name": "BRtoTL",
                    "label": "$task.AutoEcoFarm.option.FarmlandFindingScheme.cases[1].label",
                    "pipeline_override": {
                        "_AutoEcoFarmFindFarmlandCustom": {
                            "recognition": {
                                "param": {
                                    "custom_recognition_param": {
                                        "recognitionNodeName": "_AutoEcoFarmFindFarmland",
                                        "xRatio": 0,
                                        "yRatio": 0
                                    }
                                }
                            }
                        },
                        "_AutoEcoFarmWaitForTeammate": {
                            "post_delay": 60000,
                            "focus": {
                                "Node.Action.Succeeded": "等待60秒，让队友多干点活，不是脚本卡咯，别担心"
                            }
                        }
                    }
                },
                {
                    "name": "Center",
                    "label": "$task.AutoEcoFarm.option.FarmlandFindingScheme.cases[2].label",
                    "pipeline_override": {
                        "_AutoEcoFarmFindFarmlandCustom": {
                            "recognition": {
                                "param": {
                                    "custom_recognition_param": {
                                        "recognitionNodeName": "_AutoEcoFarmFindFarmland",
                                        "xRatio": 0.5,
                                        "yRatio": 0.5
                                    }
                                }
                            }
                        },
                        "_AutoEcoFarmGotoTarget": {
                            "enabled": true
                        },
                        "_AutoEcoFarmWaitForTeammate": {
                            "post_delay": 60000,
                            "focus": {
                                "Node.Action.Succeeded": "等待60秒，让队友多干点活，不是脚本卡咯，别担心"
                            }
                        },
                        "_AutoEcoFarmInAnyFarm": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoEcoFarmClearBagBeforeTasks": {
            "type": "switch",
            "label": "$task.AutoEcoFarm.option.AutoEcoFarmClearBagBeforeTasks.label",
            "description": "",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "_AutoEcoFarmPrepareClearBagStart": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "_AutoEcoFarmPrepareClearBagStart": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoEcoFarmClearBagAfterTasks": {
            "type": "switch",
            "label": "$task.AutoEcoFarm.option.AutoEcoFarmClearBagAfterTasks.label",
            "description": "",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "_AutoEcoFarmEndClearBagStart": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "_AutoEcoFarmEndClearBagStart": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
