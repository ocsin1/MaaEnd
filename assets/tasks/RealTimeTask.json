{
    "task": [
        {
            "name": "RealTimeTask",
            "label": "$task.RealTimeTask.label",
            "entry": "RealTimeTaskMain",
            "description": "$task.RealTimeTask.description",
            "option": [
                "AutoSkip",
                "AutoCloseInteraction",
                "AutoFight",
                "AutoPick",
                "QuickTeleport",
                "AutoPuzzleSolving",
                "AutoZipline",
                "AutoPat",
                "AutoTaskInterval"
            ],
            "controller": [
                "Win32-Window",
                "Win32-Front"
            ]
        }
    ],
    "option": {
        "AutoSkip": {
            "type": "switch",
            "label": "$option.AutoSkip.label",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeAutoSkip": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "AutoSkipAll",
                        "AutoSkipChoose",
                        "AutoSkipNext"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeAutoSkip": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoSkipAll": {
            "label": "$option.AutoSkipAll.label",
            "description": "$option.AutoSkipAll.description",
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeAutoSkipAll": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeAutoSkipAll": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoSkipChoose": {
            "label": "$option.AutoSkipChoose.label",
            "description": "$option.AutoSkipChoose.description",
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeAutoSkipChoose": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeAutoSkipChoose": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoSkipNext": {
            "label": "$option.AutoSkipNext.label",
            "description": "$option.AutoSkipNext.description",
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeAutoSkipNext": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeAutoSkipNext": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoCloseInteraction": {
            "type": "switch",
            "label": "$option.AutoCloseInteraction.label",
            "default_case": "No",
            "description": "$option.AutoCloseInteraction.description",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "HandleTutorialGuide_RightUp": {
                            "enabled": true
                        },
                        "HandleTutorialGuide_LeftUp": {
                            "enabled": true
                        },
                        "HandleTutorialPaging": {
                            "enabled": true
                        },
                        "HandleTutorialConfirm": {
                            "enabled": true
                        },
                        "CheckAnywhere": {
                            "enabled": true
                        },
                        "CheckSpecialInfoPanel": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "EnableTutorialGuide",
                        "EnableTutorialBook",
                        "EnableClickAnywhere",
                        "EnableCloseSpecialPanel"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "HandleTutorialGuide_RightUp": {
                            "enabled": false
                        },
                        "HandleTutorialGuide_LeftUp": {
                            "enabled": false
                        },
                        "HandleTutorialPaging": {
                            "enabled": false
                        },
                        "HandleTutorialConfirm": {
                            "enabled": false
                        },
                        "CheckAnywhere": {
                            "enabled": false
                        },
                        "CheckSpecialInfoPanel": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "EnableTutorialGuide": {
            "label": "$option.EnableTutorialGuide.label",
            "description": "$option.EnableTutorialGuide.description",
            "type": "switch",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "HandleTutorialGuide_RightUp": {
                            "enabled": true
                        },
                        "HandleTutorialGuide_LeftUp": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "HandleTutorialGuide_RightUp": {
                            "enabled": false
                        },
                        "HandleTutorialGuide_LeftUp": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "EnableTutorialBook": {
            "label": "$option.EnableTutorialBook.label",
            "description": "$option.EnableTutorialBook.description",
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "HandleTutorialPaging": {
                            "enabled": true
                        },
                        "HandleTutorialConfirm": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "HandleTutorialPaging": {
                            "enabled": false
                        },
                        "HandleTutorialConfirm": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "EnableClickAnywhere": {
            "label": "$option.EnableClickAnywhere.label",
            "description": "$option.EnableClickAnywhere.description",
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "CheckAnywhere": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "CheckAnywhere": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "EnableCloseSpecialPanel": {
            "label": "$option.EnableCloseSpecialPanel.label",
            "description": "$option.EnableCloseSpecialPanel.description",
            "type": "switch",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "CheckSpecialInfoPanel": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "CheckSpecialInfoPanel": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoFight": {
            "type": "switch",
            "label": "$option.AutoFight.label",
            "description": "$option.AutoFight.description",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AutoFightRealtimeTask": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "AutoFightAttack"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "AutoFightRealtimeTask": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoFightAttack": {
            "label": "$option.AutoFightAttack.label",
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AutoFightRealtimeTask": {
                            "anchor": {
                                "__AutoFightActionAttackAnchor": "__AutoFightActionAttackClick"
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "AutoFightRealtimeTask": {
                            "anchor": {
                                "__AutoFightActionAttackAnchor": ""
                            }
                        }
                    }
                }
            ]
        },
        "AutoPick": {
            "label": "$option.AutoPick.label",
            "type": "switch",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "AutoPickFalls": {
                            "enabled": false
                        },
                        "AutoPickInteractive": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AutoPickFalls": {
                            "enabled": true
                        },
                        "AutoPickInteractive": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "QuickTeleport": {
            "type": "switch",
            "label": "$option.QuickTeleport.label",
            "description": "$option.QuickTeleport.description",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeQuickTeleportList": {
                            "enabled": false
                        },
                        "RealTimeQuickTeleportDirect": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeQuickTeleportList": {
                            "enabled": true
                        },
                        "RealTimeQuickTeleportDirect": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "AutoPuzzleSolving": {
            "type": "switch",
            "label": "$option.AutoPuzzleSolving.label",
            "description": "$option.AutoPuzzleSolving.description",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "PuzzleSolverOnSuccess": {
                            "next": [
                                "RealTimeTaskMain"
                            ]
                        },
                        "PuzzleSolverOnMiss": {
                            "next": [
                                "RealTimeTaskMain"
                            ]
                        },
                        "PuzzleSolverOnPass": {
                            "next": [
                                "RealTimeTaskMain"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "PuzzleSolverMain": {
                            "enabled": false
                        },
                        "PuzzleSolverOnScenePrepare": {
                            "enabled": false
                        },
                        "PuzzleSolverOnSceneMain": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoTaskInterval": {
            "type": "select",
            "label": "$option.AutoTaskInterval.label",
            "description": "$option.AutoTaskInterval.description",
            "default_case": "AutoTaskIntervalNormal",
            "cases": [
                {
                    "name": "AutoTaskIntervalFast",
                    "label": "$option.AutoTaskInterval.cases.AutoTaskIntervalFast.label",
                    "pipeline_override": {
                        "RealTimeSleep": {
                            "post_delay": 50
                        }
                    }
                },
                {
                    "name": "AutoTaskIntervalNormal",
                    "label": "$option.AutoTaskInterval.cases.AutoTaskIntervalNormal.label",
                    "pipeline_override": {
                        "RealTimeSleep": {
                            "post_delay": 200
                        }
                    }
                },
                {
                    "name": "AutoTaskIntervalSlow",
                    "label": "$option.AutoTaskInterval.cases.AutoTaskIntervalSlow.label",
                    "pipeline_override": {
                        "RealTimeSleep": {
                            "post_delay": 400
                        }
                    }
                }
            ]
        },
        "AutoZipline": {
            "type": "switch",
            "label": "$option.AutoZipline.label",
            "description": "$option.AutoZipline.description",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeAutoZipline": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeAutoZipline": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoPat": {
            "type": "switch",
            "label": "$option.AutoPat.label",
            "description": "$option.AutoPat.description",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTimeAutoPat": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTimeAutoPat": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
