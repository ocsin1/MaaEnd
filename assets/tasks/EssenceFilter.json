{
    "task": [
        {
            "name": "EssenceFilter",
            "label": "$task.EssenceFilter.label",
            "entry": "EssenceFilterMain",
            "description": "$task.EssenceFilter.description",
            "option": [
                "SelectInputLanguage",
                "SelectWeaponRarity",
                "SelectEssence",
                "SelectExtraRules",
                "SkipThumbLock",
                "SkipThumbDiscard"
            ],
            "controller": [
                "Win32-Front",
                "Wlroots",
                "ADB",
                "PlayCover"
            ],
            "group": [
                "valuables_vault"
            ]
        }
    ],
    "option": {
        "SelectInputLanguage": {
            "type": "select",
            "label": "$option.SelectInputLanguage.label",
            "description": "$option.SelectInputLanguage.description",
            "default_case": "CN",
            "cases": [
                {
                    "name": "CN",
                    "label": "$option.SelectInputLanguage.cases.CN.label",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "input_language": "CN"
                            }
                        }
                    }
                },
                {
                    "name": "TC",
                    "label": "$option.SelectInputLanguage.cases.TC.label",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "input_language": "TC"
                            }
                        }
                    }
                },
                {
                    "name": "EN",
                    "label": "$option.SelectInputLanguage.cases.EN.label",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "input_language": "EN"
                            }
                        }
                    }
                },
                {
                    "name": "JP",
                    "label": "$option.SelectInputLanguage.cases.JP.label",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "input_language": "JP"
                            }
                        }
                    }
                },
                {
                    "name": "KR",
                    "label": "$option.SelectInputLanguage.cases.KR.label",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "input_language": "KR"
                            }
                        }
                    }
                }
            ]
        },
        "SelectWeaponRarity": {
            "type": "switch",
            "label": "$option.SelectWeaponRarity.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "Rarity6Weapon",
                        "Rarity5Weapon",
                        "Rarity4Weapon"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "Rarity6Weapon": {
            "type": "switch",
            "label": "$option.Rarity6Weapon.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "rarity6_weapon": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "rarity6_weapon": false
                            }
                        }
                    }
                }
            ]
        },
        "Rarity5Weapon": {
            "type": "switch",
            "label": "$option.Rarity5Weapon.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "rarity5_weapon": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "rarity5_weapon": false
                            }
                        }
                    }
                }
            ]
        },
        "Rarity4Weapon": {
            "type": "switch",
            "label": "$option.Rarity4Weapon.label",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "rarity4_weapon": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "rarity4_weapon": false
                            }
                        }
                    }
                }
            ]
        },
        "SelectEssence": {
            "type": "switch",
            "label": "$option.SelectEssence.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "FlawlessEssence",
                        "PureEssence"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "FlawlessEssence": {
            "type": "switch",
            "label": "$option.FlawlessEssence.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "flawless_essence": true
                            }
                        },
                        "EssenceGridAdvance": {
                            "attach": {
                                "flawless_essence": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "flawless_essence": false
                            }
                        },
                        "EssenceGridAdvance": {
                            "attach": {
                                "flawless_essence": false
                            }
                        }
                    }
                }
            ]
        },
        "PureEssence": {
            "type": "switch",
            "label": "$option.PureEssence.label",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "pure_essence": true
                            }
                        },
                        "EssenceGridAdvance": {
                            "attach": {
                                "pure_essence": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "pure_essence": false
                            }
                        },
                        "EssenceGridAdvance": {
                            "attach": {
                                "pure_essence": false
                            }
                        }
                    }
                }
            ]
        },
        "SkipThumbLock": {
            "type": "switch",
            "label": "$option.SkipThumbLock.label",
            "description": "$option.SkipThumbLock.description",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "skip_thumb_lock": true
                            }
                        },
                        "EssenceGridAdvance": {
                            "attach": {
                                "skip_thumb_lock": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "skip_thumb_lock": false
                            }
                        },
                        "EssenceGridAdvance": {
                            "attach": {
                                "skip_thumb_lock": false
                            }
                        }
                    }
                }
            ]
        },
        "SkipThumbDiscard": {
            "type": "switch",
            "label": "$option.SkipThumbDiscard.label",
            "description": "$option.SkipThumbDiscard.description",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "skip_thumb_discard": true
                            }
                        },
                        "EssenceGridAdvance": {
                            "attach": {
                                "skip_thumb_discard": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "skip_thumb_discard": false
                            }
                        },
                        "EssenceGridAdvance": {
                            "attach": {
                                "skip_thumb_discard": false
                            }
                        }
                    }
                }
            ]
        },
        "SelectExtraRules": {
            "type": "switch",
            "label": "$option.SelectExtraRules.label",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "KeepFuturePromising",
                        "KeepSlot3Level3Practical",
                        "DiscardUnmatched",
                        "ExportCalculatorScript"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "KeepFuturePromising": {
            "type": "switch",
            "label": "$option.KeepFuturePromising.label",
            "description": "$option.KeepFuturePromising.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "FuturePromisingMinTotal",
                        "LockFuturePromising"
                    ],
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "keep_future_promising": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "keep_future_promising": false
                            }
                        }
                    }
                }
            ]
        },
        "LockFuturePromising": {
            "type": "switch",
            "label": "$option.LockFuturePromising.label",
            "description": "$option.LockFuturePromising.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "lock_future_promising": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "lock_future_promising": false
                            }
                        }
                    }
                }
            ]
        },
        "FuturePromisingMinTotal": {
            "type": "input",
            "label": "$option.KeepFuturePromising.inputs.FuturePromisingMinTotal.label",
            "description": "$option.KeepFuturePromising.inputs.FuturePromisingMinTotal.description",
            "inputs": [
                {
                    "name": "FuturePromisingMinTotal",
                    "label": "$option.KeepFuturePromising.inputs.FuturePromisingMinTotal.label",
                    "description": "$option.KeepFuturePromising.inputs.FuturePromisingMinTotal.description",
                    "pipeline_type": "int",
                    "verify": "^[3-9]$|^1[0-5]$",
                    "default": "6"
                }
            ],
            "pipeline_override": {
                "EssenceFilterInit": {
                    "attach": {
                        "future_promising_min_total": "{FuturePromisingMinTotal}"
                    }
                }
            }
        },
        "KeepSlot3Level3Practical": {
            "type": "switch",
            "label": "$option.KeepSlot3Level3Practical.label",
            "description": "$option.KeepSlot3Level3Practical.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "option": [
                        "Slot3MinLevel",
                        "LockSlot3Practical"
                    ],
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "keep_slot3_level3_practical": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "keep_slot3_level3_practical": false
                            }
                        }
                    }
                }
            ]
        },
        "LockSlot3Practical": {
            "type": "switch",
            "label": "$option.LockSlot3Practical.label",
            "description": "$option.LockSlot3Practical.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "lock_slot3_practical": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "lock_slot3_practical": false
                            }
                        }
                    }
                }
            ]
        },
        "Slot3MinLevel": {
            "type": "input",
            "label": "$option.KeepSlot3Level3Practical.inputs.Slot3MinLevel.label",
            "description": "$option.KeepSlot3Level3Practical.inputs.Slot3MinLevel.description",
            "inputs": [
                {
                    "name": "Slot3MinLevel",
                    "label": "$option.KeepSlot3Level3Practical.inputs.Slot3MinLevel.label",
                    "description": "$option.KeepSlot3Level3Practical.inputs.Slot3MinLevel.description",
                    "pipeline_type": "int",
                    "verify": "^[1-3]$",
                    "default": "3"
                }
            ],
            "pipeline_override": {
                "EssenceFilterInit": {
                    "attach": {
                        "slot3_min_level": "{Slot3MinLevel}"
                    }
                }
            }
        },
        "DiscardUnmatched": {
            "type": "switch",
            "label": "$option.DiscardUnmatched.label",
            "description": "$option.DiscardUnmatched.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "discard_unmatched": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "discard_unmatched": false
                            }
                        }
                    }
                }
            ]
        },
        "ExportCalculatorScript": {
            "type": "switch",
            "label": "$option.ExportCalculatorScript.label",
            "description": "$option.ExportCalculatorScript.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "export_calculator_script": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EssenceFilterInit": {
                            "attach": {
                                "export_calculator_script": false
                            }
                        }
                    }
                }
            ]
        }
    }
}
