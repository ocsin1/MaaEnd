{
    "task": [
        {
            "name": "DeliveryJobs",
            "label": "$task.DeliveryJobs.label",
            "entry": "DeliveryJobsMain",
            "description": "$task.DeliveryJobs.description",
            "option": [
                "ValleyIV",
                "Wuling",
                "PackCargoSelectItem",
                "DeliveryJobsAcceptJobOnly",
                "DeliveryJobsPackCargoOnly"
            ],
            "group": [
                "daily"
            ]
        }
    ],
    "option": {
        "ValleyIV": {
            "type": "switch",
            "label": "$global.region.ValleyIV",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsValleyIV": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "OriginiumSciencePark",
                        "OriginLodespring",
                        "PowerPlateau"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsValleyIV": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "OriginiumSciencePark": {
            "type": "switch",
            "label": "$global.region.OriginiumSciencePark",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsEnterOriginiumScienceParkCargo": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsEnterOriginiumScienceParkCargo": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "OriginLodespring": {
            "type": "switch",
            "label": "$global.region.OriginLodespring",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsEnterOriginLodespringCargo": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsEnterOriginLodespringCargo": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "PowerPlateau": {
            "type": "switch",
            "label": "$global.region.PowerPlateau",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsEnterPowerPlateauCargo": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsEnterPowerPlateauCargo": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "Wuling": {
            "type": "switch",
            "label": "$global.region.Wuling",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsWuling": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "WulingCity"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsWuling": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "WulingCity": {
            "type": "switch",
            "label": "$global.region.WulingCity",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsEnterWulingCityCargo": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "DeliveryJobsEnterWulingCityCargo": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "PackCargoSelectItem": {
            "type": "switch",
            "label": "$task.DeliveryJobs.PackCargoSelectItem.label",
            "description": "$task.DeliveryJobs.PackCargoSelectItem.description",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsSelectTypeOfGoodsToPackNextStep": {
                            "next": [
                                "DeliveryJobsSelectItemLoop"
                            ]
                        }
                    },
                    "option": [
                        "WhatToFillValleyIV",
                        "WhatToFillWuling"
                    ]
                },
                {
                    "name": "No"
                }
            ],
            "default_case": "No"
        },
        "WhatToFillValleyIV": {
            "type": "select",
            "label": "$task.DeliveryJobs.WhatToFillValleyIV",
            "cases": [
                {
                    "name": "砂叶粉末",
                    "label": "$item.SandleafPowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillValleyIV": {
                            "template": "DeliveryJobs/SandleafPowder.png"
                        }
                    }
                },
                {
                    "name": "荞花粉末",
                    "label": "$item.BuckflowerPowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillValleyIV": {
                            "template": "DeliveryJobs/BuckflowerPowder.png"
                        }
                    }
                },
                {
                    "name": "柑实粉末",
                    "label": "$item.CitromePowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillValleyIV": {
                            "template": "DeliveryJobs/CitromePowder.png"
                        }
                    }
                },
                {
                    "name": "酮化灌木粉末",
                    "label": "$item.AketinePowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillValleyIV": {
                            "template": "DeliveryJobs/AketinePowder.png"
                        }
                    }
                }
            ],
            "default_case": "砂叶粉末"
        },
        "WhatToFillWuling": {
            "type": "select",
            "label": "$task.DeliveryJobs.WhatToFillWuling",
            "cases": [
                {
                    "name": "砂叶粉末",
                    "label": "$item.SandleafPowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillWuling": {
                            "template": "DeliveryJobs/SandleafPowder.png"
                        }
                    }
                },
                {
                    "name": "荞花粉末",
                    "label": "$item.BuckflowerPowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillWuling": {
                            "template": "DeliveryJobs/BuckflowerPowder.png"
                        }
                    }
                },
                {
                    "name": "柑实粉末",
                    "label": "$item.CitromePowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillWuling": {
                            "template": "DeliveryJobs/CitromePowder.png"
                        }
                    }
                },
                {
                    "name": "酮化灌木粉末",
                    "label": "$item.AketinePowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillWuling": {
                            "template": "DeliveryJobs/AketinePowder.png"
                        }
                    }
                },
                {
                    "name": "芽针粉末",
                    "label": "$item.YazhenPowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillWuling": {
                            "template": "DeliveryJobs/YazhenPowder.png"
                        }
                    }
                },
                {
                    "name": "锦草粉末",
                    "label": "$item.JincaoPowder",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillWuling": {
                            "template": "DeliveryJobs/JincaoPowder.png"
                        }
                    }
                },
                {
                    "name": "芽针",
                    "label": "$item.Yazhen",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillWuling": {
                            "template": "DeliveryJobs/Yazhen.png"
                        }
                    }
                },
                {
                    "name": "锦草",
                    "label": "$item.Jincao",
                    "pipeline_override": {
                        "DeliveryJobsSelectItemToFillWuling": {
                            "template": "DeliveryJobs/Jincao.png"
                        }
                    }
                }
            ],
            "default_case": "砂叶粉末"
        },
        "DeliveryJobsAcceptJobOnly": {
            "type": "switch",
            "label": "$task.DeliveryJobs.AcceptJobOnly.label",
            "description": "$task.DeliveryJobs.AcceptJobOnly.description",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        // 确保不会转交任务
                        "DeliveryJobsEnterDeliveryJob": {
                            "enabled": false
                        },
                        // 回到大世界后直接停止任务，不继续后续流程
                        "DeliveryJobsBackToDepot": {
                            "next": [
                                "DeliveryJobsAcceptJobOnly"
                            ]
                        }
                    }
                },
                {
                    "name": "No"
                }
            ],
            "default_case": "No"
        },
        "DeliveryJobsPackCargoOnly": {
            "type": "switch",
            "label": "$task.DeliveryJobs.PackCargoOnly.label",
            "description": "$task.DeliveryJobs.PackCargoOnly.description",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "DeliveryJobsEnterDeliveryJob": {
                            "enabled": false
                        },
                        "DeliveryJobsInCargoRedistributionBid": {
                            "next": [
                                "DeliveryJobsBackToDepotFromBid"
                            ]
                        },
                        "DeliveryJobsCheckOriginiumScienceParkCargo": {
                            "expected": [
                                "货物装箱",
                                "貨物裝箱",
                                "(?i)Pack\\s*Goods",
                                "パッキング",
                                "화물 포장"
                            ]
                        },
                        "DeliveryJobsCheckOriginLodespringCargo": {
                            "expected": [
                                "货物装箱",
                                "貨物裝箱",
                                "(?i)Pack\\s*Goods",
                                "パッキング",
                                "화물 포장"
                            ]
                        },
                        "DeliveryJobsCheckPowerPlateauCargo": {
                            "expected": [
                                "货物装箱",
                                "貨物裝箱",
                                "(?i)Pack\\s*Goods",
                                "パッキング",
                                "화물 포장"
                            ]
                        },
                        "DeliveryJobsCheckWulingCityCargo": {
                            "expected": [
                                "货物装箱",
                                "貨物裝箱",
                                "(?i)Pack\\s*Goods",
                                "パッキング",
                                "화물 포장"
                            ]
                        }
                    }
                },
                {
                    "name": "No"
                }
            ],
            "default_case": "No"
        }
    }
}
