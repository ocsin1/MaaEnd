        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "RecoveryEmotionBar",
                "roi_offset": [
                    0,
                    0,
                    10,
                    0
                ],
                "lower": [
                    26,
                    26,
                    24
                ],
                "upper": [
                    27,
                    27,
                    25
                ],
                "connected": true,
                "count": 30,
                "order_by": "Vertical"
            }
        }
    },
    "RecoveryEmotionCouldNotAssist": {
        "desc": "[恢复心情·收尾] 没有更多心情激励点数时的提示，点击确认",
