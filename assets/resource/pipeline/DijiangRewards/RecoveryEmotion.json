    },
    "RecoveryEmotionSelectLowEmotion": {
        "desc": "[恢复心情·操作] 在列表中识别心情条有空缺的干员并点击",
        "max_hit": 6,
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "RecoveryEmotionIcon",
                    "RecoveryEmotionBar",
                    "RecoveryEmotionEmpty"
                ],
                "box_index": 2
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    -5,
                    -70,
                    -5,
                    0
                ]
            }
        },
        "post_delay": 400, // 上方tips出现需要时间，可能显示也可能不显示，避免连续点击不同干员导致覆盖提示判断错误
        "rate_limit": 0,
        "next": [
            "RecoveryEmotionFull",
            "RecoveryEmotionCouldNotAssist",
            "RecoveryEmotionSelectLowEmotion",
            "RecoveryEmotionExitView2ToView1"
        ]
    },
    "RecoveryEmotionIcon": {
        "desc": "[恢复心情·状态] 心情图标位置",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    467,
                    236,
                    620,
                    282
                ],
                "template": [
                    "ClaimDijiangRewards/LowEmotion.png",
                    "ClaimDijiangRewards/NormalEmotion.png"
                ],
                "threshold": [
                    0.8,
                    0.8
                ],
                "order_by": "Vertical"
            }
        }
    },
    "RecoveryEmotionBar": {
        "desc": "[恢复心情·状态] 心情条位置",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "RecoveryEmotionIcon",
                "roi_offset": [
                    19,
                    7,
                    45,
                    -14
