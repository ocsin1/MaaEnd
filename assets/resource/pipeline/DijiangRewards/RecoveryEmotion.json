    "RecoveryEmotionFull": {
        "desc": "[恢复心情·意外] 点击了满心情/无法助力干员时的提示",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    416,
                    65,
                    428,
                    119
