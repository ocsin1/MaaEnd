{
    "RecoveryEmotionMain": {
        "desc": "[控制中枢·恢复心情] 在总控中枢点击恢复心情红点，进入选择干员或关闭",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InDijiangControlNexus",
                    "NeedAssistColor"
                ],
                "box_index": 1
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    -60,
                    10,
                    0,
                    0
                ]
            }
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "RecoveryEmotionAssistWindowOpen"
        ]
    },
    "RecoveryEmotionAssistWindowTitle": {
        "desc": "[恢复心情·助力] 助力界面标题",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    400,
                    200
                ],
                "expected": [
                    "生产助力",
                    "生產助力",
                    "Production Assist",
                    "生産サポート",
                    "생산 지원"
                ]
            }
        }
    },
    "RecoveryEmotionAssistView1Label": {
        "desc": "[恢复心情·助力] 第一层界面标签",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    464,
                    138,
                    370,
                    154
                ],
                "expected": [
                    "今日助力好友",
                    "Assists Today",
                    "本日のサポート記録",
                    "オペレーターは体力が十分なため、サポートできません",
                    "오늘 지원한 친구"
                ]
            }
        }
    },
    "RecoveryEmotionAssistView2Label": {
        "desc": "[恢复心情·助力] 第二层界面标签",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    464,
                    138,
                    370,
                    154
                ],
                "expected": [
                    "选择待恢复心情的干员",
                    "選擇待恢復心情的幹員",
                    "(?i)Select\\s*operator\\s*awaiting\\s*mood\\s*recovery",
                    "対象オペレーターを選んでください"
                ]
            }
        }
    },
    "RecoveryEmotionAssistWindowOpen": {
        "desc": "[恢复心情·助力] 打开助力界面",
        "recognition": "And",
        "all_of": [
            "RecoveryEmotionAssistWindowTitle"
        ],
        "pre_delay": 0,
        "pre_wait_freezes": {
            "time": 100,
            "target": "RecoveryEmotionAssistWindowTitle",
            "target_offset": [
                0,
                0,
                200,
                250
            ]
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "RecoveryEmotionAssistUseAssist"
        ]
    },
    "RecoveryEmotionAssistUseAssist": {
        "desc": "[恢复心情·需要助力] 点击使用助力",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "YellowConfirmButtonType1",
                    "UseAssistText"
                ],
                "box_index": 1
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "RecoveryEmotionView2In"
        ]
