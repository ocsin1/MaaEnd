{
    // 只能使用本文件中定义的接口，禁止引用 SceneManager 文件夹内的 __ScenePrivate 节点
    "SceneAnyEnterWorld": {
        "desc": "从任意界面进入谷地/武陵/帝江任意一个大世界",
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "__ScenePrivateCloseADBExit",
            "__ScenePrivateMenuListEnterWorld",
            "__ScenePrivateAnyEnterWorldSuccess",
            "[JumpBack]__ScenePrivateLogin",
            "[JumpBack]SceneDialogConfirm",
            "[JumpBack]__ScenePrivateNoticeRewardsUpgrade",
            "[JumpBack]__ScenePrivateEndVisit",
            "[JumpBack]__ScenePrivateEndVisitConfirm",
            "[JumpBack]SceneWaitLoadingExit",
            "[JumpBack]__ScenePrivateAnyExit"
        ]
    },
    "SceneEnterMapAny": {
        "desc": "从任意界面进入任意一个地图界面",
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "__ScenePrivateWorldEnterMapAny",
            "[JumpBack]SceneAnyEnterWorld"
        ]
    },
    "SceneEnterWorldFactory": {
        "desc": "从任意界面进入大世界工厂模式",
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "__ScenePrivateAnyEnterWorldFactorySuccess",
            "__ScenePrivateWorldFactoryDisableEnterFactoryActive",
            "__ScenePrivateWorldFactoryNotActiveEnterFactoryActive",
            "__ScenePrivateWorldDijiangEnterFactoryActive",
            "[JumpBack]SceneAnyEnterWorld"
        ]
    },
    "SceneDialogConfirm": {
        "desc": "点击对话框的确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "GrayCancelButton",
                    "YellowConfirmButtonType1"
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "SceneDialogCancel": {
        "desc": "点击对话框的取消按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "GrayCancelButton",
                    "YellowConfirmButtonType1"
                ]
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "SceneNoticeRewardsConfirm": {
        "desc": "点击奖励界面的确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InNoticeRewards",
                    "CloseRewardsButton"
                ],
                "box_index": 1
            }
        },
        "pre_wait_freezes": {
            "time": 400,
            "timeout": 5000,
            "target": [
                230,
                250,
                800,
                200
            ]
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": {
            "time": 400,
            "timeout": 2000,
            "target": [
                500,
                0,
                280,
                200
            ]
        },
        "next": [
            "[JumpBack]__ScenePrivateNoticeRewardsUpgrade",
            "__ScenePrivateNextTrue"
        ]
    },
    "SceneNoticeRewardsConfirmWithAnchor": {
        "desc": "点击奖励界面的确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InNoticeRewards",
                    "CloseRewardsButton"
                ],
                "box_index": 1
            }
        },
        "pre_wait_freezes": {
            "time": 400,
            "timeout": 5000,
            "target": [
                230,
                250,
                800,
                200
            ]
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": {
            "time": 400,
            "timeout": 2000,
            "target": [
                500,
                0,
                280,
                200
            ]
        },
        "next": [
            "[JumpBack]__ScenePrivateNoticeRewardsUpgrade",
            "[Anchor]SceneNoticeRewardsConfirmNextAnchor"
        ]
    },
    "SceneWaitLoadingExit": {
        "desc": "判断当前场景在加载界面，什么都不做，用于等待加载界面消失",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    200,
                    200
                ],
                "template": [
                    "SceneManager/LoadingIcon.png"
                ]
            }
        },
        "next": [
            "[JumpBack]__SceneCheckOSD",
            "[JumpBack]__SceneCheckYellowColor",
            "[JumpBack]__SceneCheckTealColor",
            "[JumpBack]__SceneCheckPurpleColor",
            "SceneWaitLoadingExit",
            "__ScenePrivateNextTrue"
        ]
    }
}
