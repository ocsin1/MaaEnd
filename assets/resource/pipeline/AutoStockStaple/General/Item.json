{
    "AutoStockInStapleItem": {
        "desc": "识别商品基准点(剩余刷新时间框)，用于后续识别",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "method": 40,
                "lower": [
                    [
                        76,
                        200,
                        200
                    ],
                    [
                        24,
                        250,
                        250
                    ],
                    [
                        160,
                        255,
                        217
                    ]
                ],
                "upper": [
                    [
                        76,
                        255,
                        215
                    ],
                    [
                        24,
                        255,
                        255
                    ],
                    [
                        160,
                        255,
                        217
                    ]
                ],
                "connected": true,
                "count": 300,
                "order_by": "Vertical"
            }
        }
    },
    "AutoStockInStapleItemDiscounts": {
        "desc": "识别商品折扣信息框，用于后续识别",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "AutoStockInStapleItem",
                "roi_offset": [
                    79,
                    -17,
                    10,
                    29
                ],
                "method": 40,
                "lower": [
                    26,
                    255,
                    255
                ],
                "upper": [
                    26,
                    255,
                    255
                ],
                "connected": true,
                "count": 300,
                "order_by": "Vertical"
            }
        }
    },
    "AutoStockInStapleItemName": {
        "desc": "识别商品名称",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "AutoStockInStapleItemDiscounts",
                "roi_offset": [
                    -91,
                    165,
                    95,
                    22
                ],
                "expected": [],
                "order_by": "Vertical"
            }
        }
    },
    "AutoStockTargetStockBillColor": {
        "desc": "识别目标调度券颜色(这是子节点,后续会被OCR节点引用)",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "AutoStockInStapleItemName",
                "roi_offset": [
                    -27,
                    -48,
                    55,
                    20
                ],
                "method": 6,
                "lower": [
                    80
                ],
                "upper": [
                    122
                ]
            }
        }
    },
    "AutoStockTargetStockBillText": {
        "desc": "识别目标调度券数量",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "AutoStockTargetStockBillColor",
                "roi_offset": [
                    -2,
                    -2,
                    4,
                    4
                ],
                "expected": [
                    "\\d+"
                ],
                "only_rec": true,
                "color_filter": "AutoStockTargetStockBillColor"
            }
        }
    },
    "AutoStockTargetStockBill": {
        "desc": "识别目标调度券数量",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "AutoStockTargetStockBillColor",
                    "AutoStockTargetStockBillText"
                ],
                "box_index": 1
            }
        }
    },
    "AutoStockTargetCanBuy": {
        "desc": "识别目标调度券是否可购买",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ExpressionRecognition",
                "custom_recognition_param": {
                    "expression": "{AutoStockTargetStockBill} < {AutoStockCurrentStockBill}"
                    //"expression": "240000< {AutoStockCurrentStockBill}"
                }
            }
        }
    },
    "AutoStockSwipeToMax": {
        "desc": "识别滑动按钮，用于滑动到最大库存",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    55,
                    53,
                    333,
                    167
                ],
                "expected": [
                    "购买商品",
                    "購買商品",
                    "(?i)Purchase",
                    "購入"
                ]
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "BetterSliding",
                "custom_action_param": {
                    "Direction": "right"
                }
            }
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockSwipeBuy"
        ]
    },
    "AutoStockSwipeBuy": {
        "desc": "识别确认购买按钮，用于确认购买",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "YellowConfirmButtonType1",
                    "ConfirmBuyText"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "AutoStockpileCheckBuyResult"
        ]
    },
    "AutoStockCurrentStockBill": {
        "desc": "识别当前库存票据，用于获取当前库存",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "CurrentStockBillColor",
                    "CurrentStockBillText"
                ],
                "box_index": 1
            }
        }
    },
    "AutoStockStapleBetterSliding": {
        "desc": "自动购买稳定物资 - BetterSliding 精确滑动到指定数量",
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "BetterSliding",
                "custom_action_param": {
                    "DecreaseButton": "AutoStockpile/DecreaseButton.png",
                    "Direction": "right",
                    "IncreaseButton": "AutoStockpile/IncreaseButton.png",
                    "GreenMask": true,
                    "Quantity": {
                        "Box": [
                            367,
                            473,
                            102,
                            94
                        ],
                        "OnlyRec": false
                    },
                    "QuantityFilter": {
                        "lower": [
                            28,
                            100,
                            100
                        ],
                        "upper": [
                            28,
                            255,
                            255
                        ],
                        "method": 40
                    }
                }
            }
        },
        "post_delay": 0,
        "rate_limit": 0,
        "attach": {
            "Target": 10 //这里会被custom程序覆盖后运行
        }
    }
}
