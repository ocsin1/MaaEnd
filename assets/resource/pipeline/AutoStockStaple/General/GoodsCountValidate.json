    "AutoStockStapleGoodsCountValidate": {
        "desc": "物品数量验证",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1068,
                    185,
                    20,
                    14
                ],
                "expected": [
                    "\\d+"
                ],
                "only_rec": true
            }
        }
    },
