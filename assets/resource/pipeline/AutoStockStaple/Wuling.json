{
    "AutoStockInStapleWuling": {
        "desc": "识别当前处于武陵界面，并进入囤货界面",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InWulingText",
                    "InStapleColor",
                    "InStockStaple"
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockTargetCanNotBuyWuling",
            "[JumpBack]AutoStockBuyItemWulingTask",
            "SoldOut",
            "[JumpBack]AutoStockSwipeWuling"
        ]
    },
    "AutoStockTargetCompareWuling": {
        "desc": "识别目标调度券是否不可购买",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ExpressionRecognition",
                "custom_recognition_param": {
                    "expression": "240000> {AutoStockCurrentStockBill}"
                }
            }
        }
    },
    "AutoStockTargetCanNotBuyWuling": {
        "desc": "识别目标调度券是否不可购买",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InStapleColor",
                    "AutoStockTargetCompareWuling"
                ]
            }
        }
    },
    "AutoStockBuyItemWulingTask": {
        "desc": "识别商品，并进入购买流程",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "AutoStockInStapleItem",
                    "AutoStockInStapleItemName_Expected",
                    "AutoStockInStapleItemDiscountsWuling"
                ],
                "box_index": 2
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    -50,
                    95,
                    0,
                    0
                ]
            }
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockStapleQuantityControl"
        ]
    },
    "AutoStockSwipeWuling": {
        "desc": "向下滑动寻找商品，直到找到商品或到达底部",
        "max_hit": 25,
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InWulingText",
                    "InStapleColor"
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    240,
                    500
                ],
                "end": [
                    [
                        240,
                        400
                    ],
                    [
                        360,
                        400
                    ]
                ],
                "end_hold": 200
            }
        },
        "post_wait_freezes": {
            "time": 300,
            "target": [
                89,
                200,
                99,
                176
            ]
        }
    }
}
