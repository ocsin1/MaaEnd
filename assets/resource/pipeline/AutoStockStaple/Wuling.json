{
    "AutoStockInStapleWuling": {
        "desc": "识别当前处于武陵界面，并进入囤货界面",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InWulingText",
                    "InStapleColor"
                ]
            }
        },
        "next": [
            "AutoStockTargetCanNotBuyWuling",
            "[JumpBack]AutoStockBuyItemWulingTask",
            "SoldOut",
            "[JumpBack]AutoStockSwipeWuling"
        ]
    },
    "AutoStockTargetCompareWuling": {
        "desc": "识别目标调度券是否不可购买",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ExpressionRecognition",
                "custom_recognition_param": {
                    "expression": "240000> {AutoStockCurrentStockBill}"
                }
            }
        }
    },
    "AutoStockTargetCanNotBuyWuling": {
        "desc": "识别目标调度券是否不可购买",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InStapleColor",
                    "AutoStockTargetCompareWuling"
                ]
            }
        }
    },
    "AutoStockBuyItemWulingTask": {
        "desc": "识别商品，并进入购买流程",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "AutoStockInStapleItem",
                    "AutoStockInStapleItemName",
                    "AutoStockInStapleItemDiscountsWuling",
                    "AutoStockTargetCanBuy"
                ],
                "box_index": 2
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target_offset": [
                    -50,
                    95,
                    0,
                    0
                ]
            }
        },
        "next": [
            "AutoStockStapleQuantityControl"
        ]
    },
    "AutoStockSwipeWuling": {
        "desc": "向下滑动寻找商品，直到找到商品或到达底部",
        "max_hit": 20,
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InWulingText",
                    "InStapleColor"
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Scroll",
            "param": {
                "target_offset": [
                    0,
                    140,
                    0,
                    0
                ],
                "dx": 120
            }
        },
        "post_wait_freezes": {
            "time": 150,
            "target": [
                101,
                131,
                106,
                548
            ]
        }
    }
}
