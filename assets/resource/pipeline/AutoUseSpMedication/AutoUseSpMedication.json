{
    "AutoUseSpMedicationEntry": {
        "desc": "自动使用应急理智加强剂任务入口",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "AutoUseSpMedicationInStashValuablesTab",
            "[JumpBack]SceneEnterMenuValuablesValuableTab"
        ],
        "focus": {
            "Node.Action.Starting": "即将进入珍贵物品标签页"
        }
    },
    "AutoUseSpMedicationInStashValuablesTab": {
        "desc": "识别是否在珍贵物品页界面",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InStashValuablesTab"
                ]
            }
        },
        "next": [
            "AutoUseSpMedicationLoop"
        ]
    },
    "AutoUseSpMedicationLoop": {
        "desc": "主任务循环",
        "max_hit": 1, //由选项覆盖
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "AutoUseSpMedicationSelectRedDeadlineEmergencySanityBooster",
            "AutoUseSpMedicationSelectGreenDeadlineEmergencySanityBooster",
            "AutoUseSpMedicationUseNoEmergencySanityBooster"
        ]
    },
    "AutoUseSpMedicationSelectGreenDeadlineEmergencySanityBooster": {
        "desc": "选择任意时限应急理智加强剂",
        "enabled": true,
        "recognition": "Or",
        "any_of": [
            "AutoUseSpMedicationFindRedDeadlineEmergencySanityBooster",
            "AutoUseSpMedicationFindGreenDeadlineEmergencySanityBooster"
        ],
        "action": "Click",
        "post_wait_freezes": 300,
        "next": [
            "AutoUseSpMedicationUseEmergencySpBooster"
        ],
        "focus": {
            "Node.Action.Starting": "开始选择应急理智加强剂"
        }
    },
    "AutoUseSpMedicationFindGreenDeadlineEmergencySanityBooster": {
        "desc": "识别绿色时限(大于7天)应急理智加强剂",
        "recognition": "And",
        "all_of": [
            "FindGreenDeadlineEmergencySanityBooster",
            "ColorRecognitionGreenEmergencySanityBooster"
        ]
    },
    "FindGreenDeadlineEmergencySanityBooster": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    30,
                    80,
                    940,
                    560
                ],
                "template": "Valuables/EmergencySpBooster.png",
                "green_mask": true,
                "threshold": 0.84,
                "order_by": "Vertical"
            }
        }
    },
    "ColorRecognitionGreenEmergencySanityBooster": {
        "desc": "颜色识别,确认是绿色时限的应急理智加强剂",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "FindGreenDeadlineEmergencySanityBooster",
                "roi_offset": [
                    0,
                    0,
                    -79,
                    -81
                ],
                "method": 40,
                "lower": [
                    50,
                    0,
                    0
                ],
                "upper": [
                    90,
                    255,
                    255
                ],
                "connected": true,
                "count": 100
            }
        }
    },
    "AutoUseSpMedicationSelectRedDeadlineEmergencySanityBooster": {
        "desc": "选择红色时限应急理智加强剂",
        "enabled": true,
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "AutoUseSpMedicationFindRedDeadlineEmergencySanityBooster"
                ]
            }
        },
        "action": "Click",
        "post_wait_freezes": 300,
        "next": [
            "AutoUseSpMedicationUseEmergencySpBooster"
        ],
        "focus": {
            "Node.Action.Starting": "开始选择即将过期的应急理智加强剂"
        }
    },
    "AutoUseSpMedicationFindRedDeadlineEmergencySanityBooster": {
        "desc": "识别红色时限(小于7天)应急理智加强剂",
        "recognition": "And",
        "all_of": [
            "FindRedDeadlineEmergencySanityBooster",
            "ColorRecognitionRedEmergencySanityBooster"
        ]
    },
    "FindRedDeadlineEmergencySanityBooster": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    30,
                    80,
                    940,
                    560
                ],
                "template": "Valuables/EmergencySpBooster.png",
                "green_mask": true,
                "threshold": 0.84,
                "order_by": "Score"
            }
        }
    },
    "ColorRecognitionRedEmergencySanityBooster": {
        "desc": "颜色识别,确认是红色时限的应急理智加强剂",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "FindRedDeadlineEmergencySanityBooster",
                "roi_offset": [
                    0,
                    0,
                    -79,
                    -81
                ],
                "method": 40,
                "lower": [
                    161,
                    0,
                    0
                ],
                "upper": [
                    191,
                    255,
                    255
                ],
                "connected": true,
                "count": 100
            }
        }
    },
    "AutoUseSpMedicationUseEmergencySpBooster": {
        "desc": "点击详情页的使用按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "WhiteConfirmButtonType1"
                ],
                "box_index": 0
            }
        },
        "action": "Click",
        "post_wait_freezes": 300,
        "next": [
            "AutoUseSpMedicationQuickUse",
            "AutoUseSpMedicationQuickUseCancel"
        ]
    },
    "AutoUseSpMedicationQuickUse": {
        "desc": "确认使用应急理智加强剂",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "YellowConfirmButtonType2",
                    {
                        "param": {
                            "expected": [
                                "快捷使用",
                                "Quick Use"
                            ],
                            "roi": [
                                190,
                                205,
                                155,
                                35
                            ]
                        },
                        "type": "OCR"
                    },
                    {
                        //冗余检测，避免用错
                        "type": "OCR",
                        "param": {
                            "expected": [
                                "应急理智加强剂",
                                "緊急理智加強劑",
                                "Emergency Sanity Booster"
                            ],
                            "roi": [
                                350,
                                335,
                                160,
                                40
                            ]
                        }
                    }
                ],
                "box_index": 0
            }
        },
        "action": "Click",
        "timeout": 5000,
        "next": [
            "AutoUseSpMedicationRewardsConfirm"
        ]
    },
    "AutoUseSpMedicationRewardsConfirm": {
        "desc": "点击奖励界面的确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "SceneNoticeRewardsConfirm"
                ]
            }
        },
        "pre_wait_freezes": {
            "time": 400,
            "timeout": 5000,
            "target": [
                230,
                250,
                800,
                200
            ]
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": {
            "time": 400,
            "timeout": 2000,
            "target": [
                500,
                0,
                280,
                200
            ]
        },
        "next": [
            "AutoUseSpMedicationLoop",
            "AutoUseSpMedicationFinish"
        ]
    },
    "AutoUseSpMedicationFinish": {
        "desc": "完成使用应急理智加强剂，结束任务",
        "pre_delay": 0,
        "post_delay": 0,
        "focus": {
            "Node.Action.Succeeded": "完成使用应急理智加强剂，结束任务"
        }
    },
    "AutoUseSpMedicationQuickUseError": {
        "desc": "提示错误并结束任务",
        "recognition": "DirectHit",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "FalseAction",
        "post_delay": 0,
        "focus": {
            "Node.Recognition.Succeeded": "快捷使用出错，结束任务"
        }
    },
    "AutoUseSpMedicationQuickUseCancel": {
        "desc": "退出快捷使用",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1084,
                    203,
                    33,
                    31
                ],
                "template": "Valuables/Close.png",
                "threshold": 0.8
            }
        },
        "action": "Click",
        "next": [
            "AutoUseSpMedicationQuickUseError"
        ],
        "focus": {
            "Node.Action.Succeeded": "无法使用应急理智加强剂！"
        }
    },
    "AutoUseSpMedicationUseNoEmergencySanityBooster": {
        "desc": "提示没有应急理智加强剂并结束任务,只有用户选择了使用应急理智加强剂的任意选项才会跳转到这个节点",
        "enabled": true,
        "focus": {
            "Node.Recognition.Succeeded": "没有应急理智加强剂，结束任务"
        }
    }
}
