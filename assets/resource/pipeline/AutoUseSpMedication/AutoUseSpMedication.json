{
    "AutoUseSpMedicationEntry": {
        "desc": "自动使用理智药剂任务入口",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "AutoUseSpMedicationInStashValuablesTab",
            "[JumpBack]SceneStashValuablesTab"
        ],
        "focus": {
            "Node.Action.Starting": "即将进入珍贵物品标签页"
        }
    },
    "AutoUseSpMedicationInStashValuablesTab": {
        "desc": "识别是否在珍贵物品页界面",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InStashValuablesTab"
                ]
            }
        },
        "next": [
            "AutoUseSpMedicationMain"
        ]
    },
    "AutoUseSpMedicationMain": {
        "desc": "主任务流程",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "AutoUseSpMedicationChooseEmergencySanityBoosterExpSoon",
            "AutoUseSpMedicationChooseEmergencySanityBooster",
            "AutoUseSpMedicationUseNoEmergencySanityBooster",
            "AutoUseSpMedicationSkipRegular"
        ]
    },
    "AutoUseSpMedicationChooseEmergencySanityBooster": {
        "desc": "选择应急理智加强剂",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    30,
                    80,
                    940,
                    560
                ],
                "template": "Valuables/EmergencySpBooster.png",
                "green_mask": true,
                "threshold": 0.84,
                "order_by": "Vertical"
            }
        },
        "action": "Click",
        "post_wait_freezes": 300,
        "next": [
            "AutoUseSpMedicationUseEmergencySpBooster"
        ],
        "focus": {
            "Node.Action.Starting": "开始选择药剂"
        }
    },
    "AutoUseSpMedicationChooseEmergencySanityBoosterExpSoon": {
        "desc": "优先选择红时限应急理智加强剂",
        "enabled": false,
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "FindEmergencySanityBoosterExpSoon",
                    "ColorRecognitionEmergencySanityBooster"
                ]
            }
        },
        "action": "Click",
        "post_wait_freezes": 300,
        "next": [
            "AutoUseSpMedicationIfExpireSoon",
            "AutoUseSpMedicationUseEmergencySpBooster"
        ],
        "focus": {
            "Node.Action.Starting": "开始选择即将过期的药剂"
        }
    },
    "FindEmergencySanityBoosterExpSoon": {
        "desc": "识别红时限应急理智加强剂",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    30,
                    80,
                    940,
                    560
                ],
                "template": "Valuables/EmergencySpBoosterExpireSoon.png",
                "green_mask": true,
                "threshold": 0.84,
                "order_by": "Vertical"
            }
        }
    },
    "ColorRecognitionEmergencySanityBooster": {
        "desc": "颜色识别,确认是过期理智药",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": "FindEmergencySanityBoosterExpSoon",
                "roi_offset": [
                    0,
                    0,
                    -79,
                    -81
                ],
                "method": 40,
                "lower": [
                    161,
                    0,
                    0
                ],
                "upper": [
                    191,
                    255,
                    255
                ]
            }
        }
    },
    "AutoUseSpMedicationIfExpireSoon": {
        "desc": "详情页检测到红色限时,只有在UseAllExpireSoonSpMedication为yes时才会启用",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    989,
                    203,
                    28,
                    26
                ],
                "template": "Valuables/ExpireSoon.png",
                "threshold": 0.8
            }
        },
        "anchor": {
            "UseAllExpireSoonSpMedication": "AutoUseSpMedicationAdd"
        },
        "next": [
            "AutoUseSpMedicationUseEmergencySpBooster"
        ]
    },
    "AutoUseSpMedicationQuickUse": {
        "desc": "确认使用理智药",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "YellowConfirmButtonType2",
                    {
                        "param": {
                            "expected": [
                                "快捷使用",
                                "Quick Use"
                            ],
                            "roi": [
                                190,
                                205,
                                155,
                                35
                            ]
                        },
                        "type": "OCR"
                    },
                    {
                        //冗余检测，避免用错
                        "type": "OCR",
                        "param": {
                            "expected": [
                                "应急理智加强剂",
                                "緊急理智加強劑",
                                "Emergency Sanity Booster"
                            ],
                            "roi": [
                                350,
                                335,
                                160,
                                40
                            ]
                        }
                    }
                ],
                "box_index": 0
            }
        },
        "action": "Click",
        "next": [
            "SceneNoticeRewardsConfirm"
        ]
    },
    "AutoUseSpMedicationQuickUseError": {
        "desc": "提示错误并结束任务",
        "recognition": "DirectHit",
        "action": "DoNothing",
        "focus": {
            "Node.Action.Failed": "快捷使用出错，结束任务"
        }
    },
    "AutoUseSpMedicationUseEmergencySpBooster": {
        "desc": "点击详情页的使用按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "WhiteConfirmButtonType1"
                ],
                "box_index": 0
            }
        },
        "action": "Click",
        "post_wait_freezes": 300,
        "next": [
            "[Anchor]UseAllExpireSoonSpMedication",
            "AutoUseSpMedicationQuickUse",
            "AutoUseSpMedicationQuickUseCancel"
        ]
    },
    "AutoUseSpMedicationQuickUseCancel": {
        "desc": "退出快捷使用",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1084,
                    203,
                    33,
                    31
                ],
                "template": "Valuables/Close.png",
                "threshold": 0.8
            }
        },
        "action": "Click",
        "next": [
            "AutoUseSpMedicationQuickUseError"
        ],
        "focus": {
            "Node.Action.Succeeded": "无法使用理智药剂！"
        }
    },
    "AutoUseSpMedicationUseNoEmergencySanityBooster": {
        "desc": "提示没有应急理智加强剂并结束任务,只有用户选择了使用应急理智的任意选项才会跳转到这个节点",
        "enabled": false,
        "focus": {
            "Node.Action.Succeeded": "没有应急理智加强剂，结束任务"
        }
    },
    "AutoUseSpMedicationSkipRegular": {
        "desc": "用户未选择使用应急药剂,放弃任务并回调",
        "focus": {
            "Node.Action.Succeeded": "用户选择不使用应急药剂，结束任务"
        }
    },
    "AutoUseSpMedicationAdd": {
        "desc": "点击添加按钮",
        "max_hit": 14, // 理智上限为1000，最高使用14+1次总共加600理智
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1072,
                    415,
                    37,
                    37
                ],
                "template": [
                    "Valuables/AddButton.png",
                    "Valuables/AddButtonHover.png"
                ],
                "threshold": [
                    0.8,
                    0.9
                ]
            }
        },
        "action": "Click",
        "next": [
            "AutoUseSpMedicationAdd", //loop until add button unavailable
            "AutoUseSpMedicationCantAdd"
        ]
    },
    "AutoUseSpMedicationCantAdd": {
        "desc": "无法添加",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1072,
                    415,
                    37,
                    37
                ],
                "template": "Valuables/DisabledAddButton.png",
                "threshold": 0.8
            }
        },
        "next": [
            "AutoUseSpMedicationQuickUse"
        ]
    }
}
