//这里写一些通用节点，用来处理各种事件，一般都要带jumpback来引用
{
    "_AutoEcoFarmMoveMouse": {
        "desc": "移动鼠标到左上角，配合jumpback使用，避免干扰识别",
        "max_hit": 20, //默认为20，超过就不要再试了免得死循环
        "action": {
            "type": "TouchMove",
            "param": {
                "target": [
                    0,
                    0,
                    1,
                    1
                ]
            }
        }
    },
    //强制结束任务前解除占用
    "_AutoEcoFarmMoveToTargetErr": {
        "desc": "这是个异常处理节点，触发时解除占用并结束任务",
        "next": [
            "_AutoEcoFarmMoveToTargetErr1"
        ],
        "focus": {
            "Node.Action.Starting": "出现异常情况，脚本提前中止"
        }
    },
    "_AutoEcoFarmMoveToTargetErrFindTarget": {
        "desc": "这是个异常处理节点，触发时解除占用并结束任务",
        "next": [
            "_AutoEcoFarmMoveToTargetErr1"
        ],
        "focus": {
            "Node.Action.Starting": "在识别标记时出现异常情况，脚本提前中止"
        }
    },
    "_AutoEcoFarmMoveToTargetErr1": {
        "desc": "先解除w键占用",
        "action": {
            "type": "KeyUp",
            "param": {
                "key": 87 //w键
            }
        },
        "next": [
            "_AutoEcoFarmMoveToTargetErr2"
        ]
    },
    "_AutoEcoFarmMoveToTargetErr2": {
        "desc": "恢复跑步模式，方式是按一下shift",
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 16 //shift键
            }
        },
        "next": [
            "AutoEcoFarmExit"
        ]
    },
    "_AutoEcoFarmSwipeToGround": {
        "desc": "移动视角到地面，配合jumpback使用",
        "max_hit": 3, //默认为3，超过就不要再试了免得死循环
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    640,
                    360,
                    1,
                    1
                ],
                "end": [
                    640,
                    480,
                    1,
                    1
                ]
            }
        },
        "next": [
            "_AutoEcoFarmSwipeToGround2"
        ],
        "focus": {
            "Node.Recognition.Failed": "识别不到标记，拉低视角视角尝试解决问题"
        }
    },
    "_AutoEcoFarmSwipeToGround2": {
        "desc": "按下alt",
        "action": {
            "type": "KeyDown",
            "param": {
                "key": 18 //alt键
            }
        },
        "next": [
            "_AutoEcoFarmSwipeToGround3"
        ]
    },
    "_AutoEcoFarmSwipeToGround3": {
        "desc": "按下鼠标左键",
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    640,
                    700,
                    1,
                    1
                ]
            }
        },
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmSwipeToGround4"
        ]
    },
    "_AutoEcoFarmSwipeToGround4": {
        "desc": "松开alt",
        "pre_delay": 0,
        "action": {
            "type": "KeyUp",
            "param": {
                "key": 18 //alt键
            }
        },
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmJumpBack"
        ]
    },
    //这是一个清空背包的任务，需要jumpback
    "_AutoEcoFarmClearBagStart": {
        "desc": "准备清理背包任务,需要Jumpback",
        "next": [
            "_AutoEcoFarmClearBag",
            "[JumpBack]SceneEnterMenuBackpackWithDepot"
        ]
    },
    "_AutoEcoFarmClearBag": {
        "desc": "前往帝江号，并打开背包，以是否识别到一键存放为标准，识别到了就点击一下",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    896,
                    497,
                    57,
                    41
                ],
                "template": [
                    "AutoEcoFarm/autoecofarmQuickStash.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "_AutoEcoFarmCloseBag"
        ]
    },
    "_AutoEcoFarmCloseBag": {
        "desc": "关掉背包",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1097,
                    124,
                    37,
                    34
                ],
                "template": [
                    "AutoEcoFarm/AutoecofarmBlackcloseWhitegrouund.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "_AutoEcoFarmJumpBack"
        ]
    },
    "_AutoEcoFarmJumpBack": {
        "desc": "空节点，用来触发jumpback"
    }
}
