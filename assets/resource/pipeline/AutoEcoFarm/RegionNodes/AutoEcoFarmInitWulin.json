//这里是初始化所有地区独立的节点，如果以后有新增农场，那么只需要按以下步骤进行
// 1、复制这个文件
// 2、直接CTRL+H将这个json中的所有"Wulin"（包括说明里的）替换为新的地区名，并确认节点名都改成了“共用节点名+新地区名”
// 3、刚替换完会有一堆报错，不要紧张，先将Anchor节点的参数设置成新地区的，全部替换完成后一般就没有报错了
// 4、将节点入口（如"_AutoEcoFarmInitStartWulin"）放到"AutoEcoFarmMain"的next里 "_AutoEcoFarmPrepareStart"和"_AutoEcoFarmEndStart"之间就行了
// 5、在task里面新增地区入口的开关，在SelectFarm这一组设置里面，将子节点GotoXXX复制一个然后将参数、描述里的地区名改成新的地区节点就行了
{
    "_AutoEcoFarmInitStartWulin": {
        "desc": "[Wulin版]子任务入口",
        "max_hit": 1,
        "next": [
            "_AutoEcoFarmInitAnchorsWulin"
        ]
    },
    "_AutoEcoFarmInitAnchorsWulin": {
        "desc": "[Wulin版]设置地区独有的Anchor节点",
        "anchor": {
            //AutoEcoFarmGotoFarm.json 前往农场部分
            "_AutoEcoFarmTeleportToFarmAnchor": "_AutoEcoFarmTeleportToFarmWulin",
            //智能导航
            "_AutoEcoFarmGotoEcoFarmBaseNavAnchor": "_AutoEcoFarmGotoEcoFarmBaseNavWulin",
            "_AutoEcoFarmGotoEcoFarmMapTrackerGoalAnchor": "_AutoEcoFarmGotoEcoFarmMapTrackerGoalWulin",
            //预设路径
            "_AutoEcoFarmGotoEcoFarmCppAnchor": "_AutoEcoFarmGotoEcoFarmCppWulin",
            "_AutoEcoFarmGotoEcoFarmGoAnchor": "_AutoEcoFarmGotoEcoFarmGoWulin",
            //AutoEcoFarmFindFarmland.json 寻找标记部分
            "_AutoEcoFarmFindEcoFarmAnchor": "_AutoEcoFarmFindEcoFarmWulin",
            "_AutoEcoFarmBlindWalkStartAnchor": "_AutoEcoFarmBlindWalkStartWulin",
            //AutoEcoFarmMoveAndWork.json 工作循环部分
            "_AutoEcoFarmInFarmAnchor": "_AutoEcoFarmInFarmWulin"
        },
        "next": [
            "[JumpBack][Anchor]_AutoEcoFarmTeleportToFarmAnchor",
            "[Anchor]_AutoEcoFarmBlindWalkStartAnchor",
            "_AutoEcoFarmGotoEcoFarmStart"
        ]
    },
    //下面是所有Anchor节点
    //传送到农场附近的节点，使用万能跳转的节点，将next里的替换成寻路节点起点附近的传送点，具体方法参考对应的文档
    "_AutoEcoFarmTeleportToFarmWulin": {
        "desc": "[Wulin版]万能跳转到农场附近",
        "max_hit": 1,
        "next": [
            "SceneEnterWorldWulingWulingCityCore"
        ]
    },
