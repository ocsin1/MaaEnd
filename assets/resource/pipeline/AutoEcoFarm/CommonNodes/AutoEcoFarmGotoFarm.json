//引用节点：MapTracker、万能跳转
//
//节点从Start进入，开始前必须要在地图界面
//节点从Exit离开，这里关联下一个阶段的节点
{
    //通用出入口
    "_AutoEcoFarmGotoEcoFarmStart": {
        "desc": "这块代码是用来前往农场的",
        "next": [
            "[JumpBack][Anchor]_AutoEcoFarmGotoEcoFarmCppAnchor",
            "_AutoEcoFarmGotoEcoFarmExit"
        ]
    },
    "_AutoEcoFarmGotoEcoFarmExit": {
        "desc": "结束去农场任务，接下一个任务",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "SubTask",
        "custom_action_param": {
            "sub": [
                "_AutoEcoFarmFindFarmlandStart",
                "_AutoEcoFarmSwipeToTargetInitFarmLand"
            ]
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "_AutoEcoFarmMoveAndWorkStart"
        ]
    },
    //盲走避障模块，一般用来出基地

    "_AutoEcoFarmBlindWalkPhotoMode": {
        "desc": "进入拍照模式，准备盲走",
        "next": [
            "[JumpBack]_AutoEcoFarmEnterCameraModeKeyDownR",
            "_AutoEcoFarmPressW"
        ]
    },
    "_AutoEcoFarmPressW": {
        "desc": "长按W盲走一段距离,然后进入下一步",
        "pre_delay": 0,
        "action": {
            "type": "LongPressKey",
            "param": {
                "duration": 20000,
                "key": 87 //w键
            }
        },
        "post_delay": 0,
        "next": [
            "[JumpBack]_AutoEcoFarmExitCameraMode",
            "_AutoEcoFarmGotoEcoFarmStart"
        ],
        "focus": {
            "Node.Action.Starting": "盲走20秒出基地，可能会撞墙或落水，这些不影响脚本运行，不用在意"
        }
    }
}
