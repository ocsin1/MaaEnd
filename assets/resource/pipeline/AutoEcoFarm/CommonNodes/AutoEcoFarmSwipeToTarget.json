//这是一个微调视角直到目标到屏幕中间的节点，可以通用，其他人只需要按以下步骤操作，
//自己建一个入口节点，参考“_AutoEcoFarmSwipeToTargetInitDefault”这个模板（可以直接复制后改），将"template"设定成目标的图片（这个要自己做）
//然后给这个入口节点加个JumpBack，比如"[JumpBack]_AutoEcoFarmSwipeToTargetInitDefault"，放在需要转向目标的地方即可
{
    //入口节点模板
    "_AutoEcoFarmSwipeToTargetInitDefault": {
        "desc": "设定并将视角拉向{默认}标记",

        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "autoEcoFarmOverrideTargetTemplate",
                "custom_action_param": {
                    "template": "AutoEcoFarm/AutoEcoFarmTarget.png",
                    "nodeNames": [
                        "_AutoEcoFarmSwipeToTargetInitDefault",
                        "_AutoEcoFarmTargeRecognitionFullScreen"
                    ]
                }
            }
        },
        "next": [
            "_AutoEcoFarmSwipeToTargetStart"
        ]
    },
    //节点内部出入口（不开放了）
    "_AutoEcoFarmSwipeToTargetStart": {
        "desc": "微调视角直到目标到屏幕中间",
        "next": [
            "[JumpBack]_AutoEcoFarmInWorldFactory",
            "_AutoEcoFarmInWorldExplore",
            "[JumpBack]SceneAnyEnterWorld"
        ]
    },
    "_AutoEcoFarmSwipeToTargetExit": {
        "next": [
            "_AutoEcoFarmJumpBack"
        ]
    },

    "_AutoEcoFarmTargeRecognitionFullScreen": {
        "desc": "在大范围识别标记的节点",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    171,
                    64,
                    951,
                    563
                ],
                "template": "AutoEcoFarm/AutoEcoFarmTarget.png",
                "green_mask": true,
                "method": 5,
                "threshold": 0.5,
                "order_by": "Score"
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmCalculateSwipeTarget"
        ]
    },
    "_AutoEcoFarmTargeRecognitionSmallMap": {
        "desc": "在小地图上识别标记的节点，纯识别用",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    43,
                    42,
                    138,
                    134
                ],
                "template": "AutoEcoFarm/AutoEcoFarmTarget.png",
                "green_mask": true,
                "method": 5,
                "threshold": 0.5,
                "order_by": "Score"
            }
        },
        "pre_delay": 0,
        "post_delay": 0
    },
    //识别模板设置节点，照着这个样子写一个并加JumpBack放在调用位置
    "_AutoEcoFarmTargeInCenter": {
        "desc": "判断目标在视野中央的节点,识别方法同上，但是范围更小",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    620,
                    100,
                    40,
                    300
                ],
                "template": "AutoEcoFarm/AutoEcoFarmTarget.png",
                "green_mask": true,
                "threshold": 0.5,
                "order_by": "Score"
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmSwipeToTargetExit"
        ]
    },
    "_AutoEcoFarmTargeInBack": {
        "desc": "判断目标在视野下方，即背后",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    336,
                    406,
                    675,
                    243
                ],
                "template": "AutoEcoFarm/AutoEcoFarmTarget.png",
                "green_mask": true,
                "threshold": 0.5,
                "order_by": "Score"
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmTurnAround1"
        ]
    },
    //这里会调用一个Custom节点，计算要将视角拉近目标多少比例所需要的swipe的end坐标
    "_AutoEcoFarmCalculateSwipeTarget": {
        "desc": "生成拉近目标所需要的坐标",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "autoEcoFarmCalculateSwipeTarget",
                "custom_recognition_param": {
                    //将视角拉向目标多少比例
                    "xStepRatio": 0.5,
                    "yStepRatio": 0.5
                },
                "roi": "_AutoEcoFarmTargeRecognitionFullScreen"
            }
        },
        "next": [
            "_AutoEcoFarmSwipeToTarget"
        ]
    },
    //下面是内部节点，不用改
    "_AutoEcoFarmInWorld": {
        "desc": "判断是否在大世界",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "_AutoEcoFarmInWorldFactory",
                    "_AutoEcoFarmInWorldExplore"
                ]
            }
        },
        "next": [
            "_AutoEcoFarmJumpBack"
        ]
    },
    "_AutoEcoFarmInWorldFactory": {
        "desc": "判断是否在大世界工业模式，如果是点一下切探索模式",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    32,
                    14,
                    128,
                    41
                ],
                "expected": [
                    "工业",
                    "工業",
                    "(?i)Factory",
                    "공업"
                ],
                "threshold": 0.7
            }
        },
        "next": [
            "_AutoEcoFarmChangeToExplore1"
        ]
    },
    "_AutoEcoFarmChangeToExplore1": {
        "desc": "按下alt",
        "action": {
            "type": "KeyDown",
            "param": {
                "key": 18 //alt键
            }
        },
        "next": [
            "_AutoEcoFarmChangeToExplore2"
        ]
    },
    "_AutoEcoFarmChangeToExplore2": {
        "desc": "按下鼠标左键,点击切换模式",
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {
                "target": "_AutoEcoFarmInWorldFactory"
            }
        },
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmChangeToExplore3"
        ]
    },
    "_AutoEcoFarmChangeToExplore3": {
        "desc": "松开alt",
        "pre_delay": 0,
        "action": {
            "type": "KeyUp",
            "param": {
                "key": 18 //alt键
            }
        },
        "post_wait_freezes": {
            "time": 500,
            "target": [
                32,
                14,
                128,
                41
            ]
        },
        "next": [
            "_AutoEcoFarmJumpBack"
        ]
    },
    "_AutoEcoFarmInWorldExplore": {
        "desc": "判断是否在大世界探索模式，是的话进入下一步",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    32,
                    14,
                    128,
                    41
                ],
                "expected": [
                    "探索",
                    "探索",
                    "(?i)Explore",
                    "탐색"
                ],
                "threshold": 0.7
            }
        },
        "next": [
            "_AutoEcoFarmResetSwipeState"
        ]
    },
    "_AutoEcoFarmResetSwipeState": {
        "desc": "重置滑动目标状态",
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "autoEcoFarmResetSwipeState"
            }
        },
        "next": [
            "_AutoEcoFarmSwipeLoopCommon"
        ]
    },
    "_AutoEcoFarmSwipeLoopCommon": {
        "desc": "[通用版]控制循环次数节点，防死循环",
        "max_hit": 100,
        "next": [
            "_AutoEcoFarmCheckTarget"
        ]
    },
    "_AutoEcoFarmCheckTarget": {
        "desc": "识别标记状态并判断下一步做什么",
        "max_hit": 20,
        "next": [
            "_AutoEcoFarmTargeInBack",
            "_AutoEcoFarmTargeRecognitionFullScreen",
            "[JumpBack]_AutoEcoFarmSwipeRandomWithErr",
            "_AutoEcoFarmMoveToTargetErrFindTarget"
        ]
    },
    "_AutoEcoFarmSwipeToTarget": {
        "desc": "转向到识别结果",
        "pre_delay": 0,
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    640,
                    360,
                    1,
                    1
                ],
                "end": "_AutoEcoFarmCalculateSwipeTarget",
                "only_hover": true,
                "duration": 200
            }
        },
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmAltDown"
        ]
    },
    "_AutoEcoFarmTurnAround1": {
        "desc": "长按 S 0.1 秒，转身",
        "action": {
            "type": "LongPressKey",
            "param": {
                "duration": 100,
                "key": 83
            }
        },
        "next": [
            "_AutoEcoFarmTurnAround2"
        ]
    },
    "_AutoEcoFarmTurnAround2": {
        "desc": "按一下鼠标中键",
        "action": {
            "type": "Click",
            "param": {
                "contact": 2
            }
        },
        "next": [
            "_AutoEcoFarmAltUp"
        ]
    },
    "_AutoEcoFarmSwipeRandomWithErr": {
        "desc": "识别不到标记时将标记随便拉一下，尝试解决问题",
        "max_hit": 3,
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    640,
                    360
                ],
                "end": [
                    320,
                    180,
                    640,
                    360
                ],
                "only_hover": true,
                "duration": 1000
            }
        },
        "next": [
            "_AutoEcoFarmAltDown"
        ],
        "focus": {
            "Node.Action.Starting": "识别不到标记，随便转转视角尝试解决问题"
        }
    },
    "_AutoEcoFarmAltDown": {
        "desc": "按下alt",
        "action": {
            "type": "KeyDown",
            "param": {
                "key": 18 //alt键
            }
        },
        "next": [
            "_AutoEcoFarmClick"
        ]
    },
    "_AutoEcoFarmClick": {
        "desc": "按下鼠标左键",
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    640,
                    700,
                    1,
                    1
                ]
            }
        },
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmAltUp"
        ]
    },
    "_AutoEcoFarmAltUp": {
        "desc": "松开alt",
        "pre_delay": 0,
        "action": {
            "type": "KeyUp",
            "param": {
                "key": 18 //alt键
            }
        },
        "post_delay": 0,
        "next": [
            //目标在中央则直接结束该子任务，否则继续循环
            "_AutoEcoFarmTargeInCenter",
            "_AutoEcoFarmSwipeLoopCommon",
            //循环控制节点超上限后会失效，直接结束任务
            "_AutoEcoFarmMoveToTargetErr"
        ]
    }
}
