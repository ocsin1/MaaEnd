//这块代码的目的是通过追踪标记来识别农田，并点击追踪标记
//节点从Start进入，开始前必须要在农田附近
//节点从Exit离开，这里关联下一个阶段的节点
{
    //节点出入口
    "_AutoEcoFarmFindFarmlandValleyStart": {
        "desc": "通过追踪标记来识别四号谷地的农田，并点击追踪标记",
        "anchor": {
            "_AutoEcoFarmFindEcoFarmAnchor": "_AutoEcoFarmFindValleyIVEcoFarm",
            "_AutoEcoFarmFindFarmandExitAnchor": "_AutoEcoFarmFindFarmlandValleyIVExit"
        },
        "next": [
            "_AutoEcoFarmFindFarmlandOpenMap"
        ]
    },
    "_AutoEcoFarmFindFarmlandWulinStart": {
        "desc": "通过追踪标记来识别武陵的农田，并点击追踪标记",
        "anchor": {
            "_AutoEcoFarmFindEcoFarmAnchor": "_AutoEcoFarmFindWulinEcoFarm",
            "_AutoEcoFarmFindFarmandExitAnchor": "_AutoEcoFarmFindFarmlandWulinExit"
        },
        "next": [
            "_AutoEcoFarmFindFarmlandOpenMap"
        ]
    },
    "_AutoEcoFarmFindFarmlandValleyIVExit": {
        "next": [
            "_AutoEcoFarmSwipeToTargetValleyIVStart"
        ]
    },
    "_AutoEcoFarmFindFarmlandWulinExit": {
        "next": [
            "_AutoEcoFarmSwipeToTargetWulinStart"
        ]
    },
    //内部节点
    "_AutoEcoFarmFindFarmlandOpenMap": {
        "desc": "先打开大地图",
        "next": [
            "_AutoEcoFarmInMap",
            "[JumpBack]SceneEnterMapAny"
        ]
    },
    "_AutoEcoFarmInMap": {
        "desc": "查找标记管理按钮来确认是否在地图界面，找到后点一下",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    25,
                    635,
                    156,
                    48
                ],
                "expected": [
                    "标记显示管理",
                    "標記顯示管理",
                    "Marker Tags",
                    "ソート",
                    "표식 관리"
                ]
            }
        },
        "next": [
            "_AutoEcoFarmClickTargetManager"
        ]
    },
    //下面这段代码是在地图上清除标记，只留工业设备，方便找农田
    "_AutoEcoFarmClickTargetManager": {
        "desc": "点开标记显示管理",
        "max_hit": 3,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    25,
                    635,
                    156,
                    48
                ],
                "expected": [
                    "标记显示管理",
                    "標記顯示管理",
                    "Marker Tags",
                    "ソート",
                    "표식 관리"
                ]
            }
        },
        "action": "Click",
        "next": [
            "_AutoEcoFarmClickClear"
        ]
    },
    "_AutoEcoFarmClickClear": {
        "desc": "点击清空选中",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    49,
                    637,
                    142,
                    50
                ],
                "expected": [
                    "清空选中",
                    "清除選取",
                    "Clear All",
                    "一括解除",
                    "선택 초기화"
                ]
            }
        },
        "action": "Click",
        "next": [
            "_AutoEcoFarmScrollToIndustrialFacilities"
        ]
    },
    "_AutoEcoFarmScrollToIndustrialFacilities": {
        "desc": "滚动一下",
        "action": {
            "type": "Scroll",
            "param": {
                "target": [
                    159,
                    347,
                    19,
                    15
                ],
                "dy": -480
            }
        },
        "post_wait_freezes": 500,
        "next": [
            "_AutoEcoFarmClickIndustrialFacilities"
        ]
    },
    "_AutoEcoFarmClickIndustrialFacilities": {
        "desc": "点击工业设备",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    18,
                    44,
                    337,
                    593
                ],
                "expected": [
                    "工业设备",
                    "工業設備",
                    "Factory",
                    "工業設備",
                    "공업 설비"
                ],
                "threshold": 0.9
            }
        },
        "action": "Click",
        "next": [
            "_AutoEcoFarmExitTargetManager"
        ]
    },
    "_AutoEcoFarmExitTargetManager": {
        "desc": "按一下esc",
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 27 //esc键
            }
        },
        "next": [
            "[Anchor]_AutoEcoFarmFindEcoFarmAnchor"
        ]
    },
    "_AutoEcoFarmFindValleyIVEcoFarm": {
        "desc": "寻找源石研究园的生态种植这几个字,找到后将鼠标移到目标位置并滚动视角直到最大",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    337,
                    166,
                    943,
                    458
                ],
                "expected": [
                    "生|态|种|植|",
                    "生|態|種|植|",
                    "Eco|Farm",
                    "栽|培",
                    "생태|재배"
                ],
                "threshold": 0.7
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Scroll",
            "param": {
                "target": true,
                "dy": 240
            }
        },
        "post_wait_freezes": 10,
        "post_delay": 0,
        "next": [
            //找到农田就下一步，没找到再拉缩放
            "_AutoEcoFarmFindFarmlandCustom",
            //通过一个自循环来做到多次识别→拉近
            "_AutoEcoFarmPullValleyIVEcoFarmToCenter",
            //要是一直失败就先移动鼠标避免干扰再找
            "[JumpBack]_AutoEcoFarmMoveMouse"
        ]
    },
    "_AutoEcoFarmFindWulinEcoFarm": {
        "desc": "寻找武陵城的“实验作物试点”这几个字,找到后将鼠标移到目标位置并滚动视角直到最大",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    222,
                    17,
                    812,
                    620
                ],
                "expected": [
                    "作|物|试|点",
                    "作|物|測|試",
                    "Agricultural|Test",
                    "実|験|栽|培|試|行",
                    "실험|작물|시범"
                ],
                "threshold": 0.7
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Scroll",
            "param": {
                "target": true,
                "dy": 240
            }
        },
        "post_wait_freezes": 10,
        "post_delay": 0,
        "next": [
            //找到农田就下一步，没找到再拉缩放
            "_AutoEcoFarmFindFarmlandCustom",
            //通过一个自循环来做到多次识别→拉近
            "_AutoEcoFarmPullWulinEcoFarmToCenter",
            //要是一直失败就先移动鼠标避免干扰再找
            "[JumpBack]_AutoEcoFarmMoveMouse"
        ]
    },
    "_AutoEcoFarmPullValleyIVEcoFarmToCenter": {
        "desc": "将生态园拉到屏幕中间",
        "max_hit": 10,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    337,
                    166,
                    943,
                    458
                ],
                "expected": [
                    "生|态|种|植|",
                    "生|態|種|植|",
                    "Eco|Farm",
                    "栽|培",
                    "생태|재배"
                ],
                "threshold": 0.7
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Swipe",
            "param": {
                "begin": true,
                "end": [
                    640,
                    360,
                    1,
                    1
                ]
            }
        },
        "post_wait_freezes": 10,
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmFindValleyIVEcoFarm",
            //要是一直失败就先移动鼠标避免干扰再找
            "[JumpBack]_AutoEcoFarmMoveMouse"
        ]
    },
    "_AutoEcoFarmFindFarmland": {
        "desc": "给custom调用的识别节点，全屏识别农田",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    1280,
                    720
                ],
                "template": "AutoEcoFarm/AutoEcoFarmFarmland.png",
                "order_by": "Horizontal"
            }
        }
    },
    "_AutoEcoFarmPullWulinEcoFarmToCenter": {
        "desc": "将“实验作物试点”拉到屏幕中间",
        "max_hit": 10,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    222,
                    17,
                    812,
                    620
                ],
                "expected": [
                    "作|物|试|点",
                    "作|物|測|試",
                    "Agricultural|Test",
                    "実|験|栽|培|試|行",
                    "실험|작물|시범"
                ],
                "threshold": 0.7
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Swipe",
            "param": {
                "begin": true,
                "end": [
                    640,
                    360,
                    1,
                    1
                ]
            }
        },
        "post_wait_freezes": 10,
        "post_delay": 0,
        "next": [
            "_AutoEcoFarmFindWulinEcoFarm",
            //要是一直失败就先移动鼠标避免干扰再找
            "[JumpBack]_AutoEcoFarmMoveMouse"
        ]
    },
    "_AutoEcoFarmFindFarmlandCustom": {
        "desc": "全屏寻找农田,并点击离特定点最近的农田",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "autoEcoFarmFindNearestRecognitionResult",
                "custom_recognition_param": {
                    "recognitionNodeName": "_AutoEcoFarmFindFarmland",
                    "xRatio": 0.5,
                    "yRatio": 0.5
                }
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "_AutoEcoFarmIsMrarking",
            "[JumpBack]_AutoEcoFarmMutiSelection",
            "_AutoEcoFarmAlreadySetTarget",
            "_AutoEcoFarmSetTarget",
            "[JumpBack]_AutoEcoFarmMoveMouse",
            //识别不到农田的话不结束脚本，而是只结束该子任务，因为农田可能就在边上
            "[Anchor]_AutoEcoFarmFindFarmandExitAnchor"
        ]
    },
    "_AutoEcoFarmIsMrarking": {
        "desc": "找到标记两个字说明点歪了，按一下esc",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    937,
                    33,
                    281,
                    45
                ],
                "expected": [
                    "标记",
                    "標記",
                    "Tag",
                    "マーカー",
                    "표식"
                ],
                "threshold": 0.7
            }
        },
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 27 //esc键
            }
        },
        "next": [
            "_AutoEcoFarmFindFarmlandCustom"
        ]
    },
    "_AutoEcoFarmAlreadySetTarget": {
        "desc": "找到取消两个字则直接下一步，不点击",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1123,
                    644,
                    113,
                    35
                ],
                "expected": [
                    "取消",
                    "取消",
                    "Cancel",
                    "キャンセル",
                    "취소"
                ],
                "threshold": 0.9
            }
        },
        "next": [
            "[Anchor]_AutoEcoFarmFindFarmandExitAnchor"
        ]
    },
    "_AutoEcoFarmSetTarget": {
        "desc": "点击追踪按钮，设定追踪",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1123,
                    644,
                    113,
                    35
                ],
                "expected": [
                    "追踪",
                    "追蹤",
                    "Track",
                    "追跡",
                    "추적하기"
                ],
                "threshold": 0.9
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "[Anchor]_AutoEcoFarmFindFarmandExitAnchor"
        ]
    },
    "_AutoEcoFarmMutiSelection": {
        "desc": "识别是否有多选情况，识别初次点击点附近有无田块字样，有的话点一下含田块两字的选项",
        "max_hit": 3, //超过3次没点掉就是出bug了直接跳过
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    873,
                    361,
                    273,
                    262
                ],
                "expected": [
                    "田块",
                    "田塊",
                    "Plot",
                    "畑",
                    "논배미"
                ]
            }
        },
        "action": {
            "type": "Click"
        }
    }
}
