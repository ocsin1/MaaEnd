{
    "BatchUseDetectorMain": {
        "desc": "批量使用探物器/罗盘入口",
        "next": [
            "BatchUseDetectorInStashValuablesTab",
            "[JumpBack]SceneStashValuablesTab"
        ],
        "focus": {
            "Node.Action.Starting": "主任务启动"
        }
    },
    "BatchUseDetectorInStashValuablesTab": {
        "desc": "在珍贵物品页",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InStashValuablesTab"
                ]
            }
        },
        "post_wait_freezes": 10,
        "next": [
            "BatchUseDetectorMainProcessLoop"
        ]
    },
    "BatchUseDetectorMainProcessLoop": {
        "desc": "批量使用探物器/罗盘主流程",
        "max_hit": 1, //使用次数,由用户修改
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "BatchUseDetectorFindValleyIVItem",
            "BatchUseDetectorFindWulingItem"
        ]
    },
    "BatchUseDetectorFindNoItem": {
        "desc": "没有找到或无法使用选择的探物器/罗盘",
        "action": "StopTask",
        "focus": {
            "Node.Recognition.Succeeded": "没有找到或无法使用选择的探物器/罗盘"
        }
    },
    "BatchUseDetectorClickWhiteConfirmButton": {
        "desc": "点击详情页白色确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "WhiteConfirmButtonType1"
                ],
                "box_index": 0
            }
        },
        "action": "Click",
        "next": [
            "BatchUseDetectorClickYellowConfirmButton"
        ]
    },
    "BatchUseDetectorClickYellowConfirmButton": {
        "desc": "点击详情页黄色确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "YellowConfirmButtonType1"
                ],
                "box_index": 0
            }
        },
        "action": "Click",
        "post_wait_freezes": 500,
        "next": [
            "BatchUseDetectorBacktoValuablesTab"
        ]
    },
    "BatchUseDetectorBacktoValuablesTab": {
        "desc": "返回珍贵物品页，返回上一级",
        "action": "Click",
        "target": [
            0,
            0
        ],
        "contact": 1,
        "next": [
            "BatchUseDetectorMainProcessLoop",
            "BatchUseDetectorFinished"
        ]
    },
    "BatchUseDetectorFinished": {
        "desc": "批量使用探物器/罗盘流程结束",
        "focus": {
            "Node.Action.Starting": "主任务结束"
        }
    }
}
