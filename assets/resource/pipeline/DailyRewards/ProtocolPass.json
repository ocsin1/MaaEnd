{
    "DailyProtocolPassStart": {
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "DailyProtocolPassInMenu",
            "[JumpBack]DailyProtocolPassNew",
            "[JumpBack]SceneEnterMenuProtocolPass"
        ]
    },
    "DailyProtocolPassInMenu": {
        "desc": "在通行证界面",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    100,
                    100
                ],
                "template": [
                    "SceneManager/MenuPassRewardsChoose.png",
                    "SceneManager/MenuPassRewardsNotChoose.png"
                ],
                "threshold": 0.9
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "[JumpBack]DailyProtocolMissionsEnter",
            "[JumpBack]DailyProtocolRewardsEnter",
            "DailyProtocolFinish"
        ]
    },
    "DailyProtocolPassNew": {
        "desc": "确认新一期的通行证界面",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    600,
                    650,
                    40,
                    40
                ],
                "template": [
                    "Common/Button/PassConfirmButton.png"
                ],
                "threshold": 0.9
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "DailyProtocolFinish": {
        "desc": "结束任务",
        "pre_delay": 0,
        "post_delay": 0
    },
    "DailyProtocolMissionsEnter": {
        "desc": "在通行证界面点击进入任务界面",
        "max_hit": 1,
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    500,
                    100
                ],
                "expected": [
                    "通行证任务",
                    "通行證任務",
                    "(?i)Pass\\s*Missions",
                    "通行証クエスト",
                    "통행증 임무"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500,
        "next": [
            "[JumpBack]DailyProtocolMissionsPick",
            "[JumpBack]DailyProtocolSwitchWeeklyMission",
            "[JumpBack]DailyProtocolSwitchCurrentMission",
            "[JumpBack]DailyProtocolSwitchEventMission",
            "[JumpBack]DailyProtocolSwitchHorizonsMission",
            "[JumpBack]DailyProtocolSwitchCurrentSpeedUpMission",
            "DailyProtocolFinish"
        ]
    },
    "DailyProtocolSwitchWeeklyMission": {
        "desc": "在任务界面点击切换列表，找周常",
        "max_hit": 1,
        "recognition": "And",
