{
    "DailyEventStart": {
        "desc": "每日奖励活动入口",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "DailyEventEnterMenu",
            "[JumpBack]SceneEnterMenuEvent"
        ]
    },
    "DailyEventEnterMenu": {
        "desc": "进入活动界面",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    200,
                    60
                ],
                "expected": [
                    "活动中心",
                    "活動中心",
                    "Event Center",
                    "イベント",
                    "EVENT CENTER",
                    "이벤트 센터"
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "DailyEventUnreadItemInit",
            "DailyEventFinish"
        ]
    },
    "DailyEventUnreadItemInit": {
        "desc": "初始化未读活动",
        "recognition": "Custom",
        "custom_recognition": "DailyEventUnreadItemInitRecognition",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "DailyEventUnreadItemInitAction",
        "post_delay": 0
    },
    "DailyEventUnreadItemSwitch": {
        "desc": "切换未处理的活动列表",
        "recognition": "OCR",
        "roi": [
            0,
            0,
            300,
            720
        ],
        "expected": [
            ".{3,}" // 匹配三个及以上字符
        ],
        "only_rec": true,
        "pre_delay": 0,
        "action": "Click",
        "post_wait_freezes": {
            "target": [
                -200,
                0,
                200,
                200
            ],
            "time": 200
        },
        "post_delay": 0,
        "next": [
            "DailyEventUnreadLimitedTimeSignin",
            "DailyEventUnreadWeeklyRoutine",
            "DailyEventUnreadGuideEvent",
            "DailyEventUnreadUnknown"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "切换活动"
        }
    },
    "DailyEventUnreadUnknown": {
        "desc": "跳过未支持的活动",
        "pre_delay": 0,
        "post_delay": 0,
        "focus": {
            "Node.Recognition.Succeeded": "跳过未支持的活动"
        }
    },
    "DailyEventFinish": {
        "desc": "结束任务",
        "focus": {
            "Node.Recognition.Succeeded": "领取活动奖励结束"
        }
    },
    "DailyEventRecognitionRedDot": {
        "desc": "识别活动界面的红点",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "DailyRewards/EventRedDot.png",
                    "DailyRewards/EventRedDot2.png",
                    "DailyRewards/EventRedDot3.png",
                    "DailyRewards/EventRedDot4.png"
                ],
                "green_mask": true,
                "threshold": 0.9
            }
        }
    },
    "DailyEventRecognitionGotoButton": {
        "desc": "识别活动界面是前往按钮",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "前往",
                    "Go",
                    "移動",
                    "바로가기"
                ]
            }
        }
    },
    "DailyEventRecognitionItemText": {
        "desc": "识别活动界面的红点",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    ".{3,}" // 匹配三个及以上字符
                ],
                "threshold": 0.7
            }
        }
    }
}
