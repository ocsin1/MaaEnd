        "all_of": [
            "InFloraObservationPointMission"
        ],
        "next": [
            "TrackFloraObservationPoint",
            "GoToFloraObservationPoint"
        ]
    },
    "TrackFloraObservationPoint": {
        "desc": "追踪植物观察点任务",
