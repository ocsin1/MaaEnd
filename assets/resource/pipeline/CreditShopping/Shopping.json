{
    "CreditShoppingShopping": {
        "desc": "信用购物",
        "recognition": "TemplateMatch",
        "roi": [
            813,
            44,
            293,
            82
        ],
        "template": "CreditShopping/CreditShoppingTabSelected.png",
        "threshold": 0.7,
        "post_wait_freezes": {
            "time": 200,
            "target": [
                52,
                98,
                1186,
                548
            ]
        },
        "next": [
            "CreditShoppingInit",
            "CreditShoppingScanItem"
        ]
    },
    "CreditShoppingInit": {
        "desc": "初始化信用购物参数：优先购买（仅执行一次）",
        "max_hit": 1,
        "recognition": "DirectHit",
        "action": "Custom",
        "custom_action": "AttachToExpectedRegexAction",
        "custom_action_param": {
            "target": "BuyFirstOCR"
        },
        "next": [
            "CreditShoppingInitCanNotAffordPriority1"
        ]
    },
    "CreditShoppingInitCanNotAffordPriority1": {
        "desc": "初始化信用购物参数：优先购买买不起分支（仅执行一次）",
        "max_hit": 1,
        "recognition": "DirectHit",
        "action": "Custom",
        "custom_action": "AttachToExpectedRegexAction",
        "custom_action_param": {
            "target": "BuyFirstOCR_CanNotAfford"
        },
        "next": [
            "CreditShoppingInitPriority2"
        ]
    },
    "CreditShoppingInitPriority2": {
        "desc": "初始化信用购物参数：普通购买1（仅执行一次）",
        "max_hit": 1,
        "recognition": "DirectHit",
        "action": "Custom",
        "custom_action": "AttachToExpectedRegexAction",
        "custom_action_param": {
            "target": "Priority2OCR"
        },
        "next": [
            "CreditShoppingInitCanNotAffordPriority2"
        ]
    },
    "CreditShoppingInitCanNotAffordPriority2": {
        "desc": "初始化信用购物参数：普通购买1买不起分支（仅执行一次）",
        "max_hit": 1,
        "recognition": "DirectHit",
        "action": "Custom",
        "custom_action": "AttachToExpectedRegexAction",
        "custom_action_param": {
            "target": "Priority2OCR_CanNotAfford"
        },
        "next": [
            "CreditShoppingInitPriority3"
        ]
    },
    "CreditShoppingInitPriority3": {
        "desc": "初始化信用购物参数：普通购买2（仅执行一次）",
        "max_hit": 1,
        "recognition": "DirectHit",
        "action": "Custom",
        "custom_action": "AttachToExpectedRegexAction",
        "custom_action_param": {
            "target": "Priority3OCR"
        },
        "next": [
            "CreditShoppingInitCanNotAffordPriority3"
        ]
    },
    "CreditShoppingInitCanNotAffordPriority3": {
        "desc": "初始化信用购物参数：普通购买2买不起分支（仅执行一次）",
        "max_hit": 1,
        "recognition": "DirectHit",
        "action": "Custom",
        "custom_action": "AttachToExpectedRegexAction",
        "custom_action_param": {
            "target": "Priority3OCR_CanNotAfford"
        },
        "next": [
            "CreditShoppingScanItem"
        ]
    },
    "CreditShoppingScanItem": {
        "recognition": "TemplateMatch",
        "roi": [
            813,
            44,
            293,
            82
        ],
        "template": "CreditShopping/CreditShoppingTabSelected.png",
        "threshold": 0.7,
        "next": [
            "AutoGetCredits",
            "CreditShoppingBuyPriority1",
            "CreditShoppingBuyPriority2",
            "CreditShoppingBuyPriority3",
            "CreditShoppingReserveCredit",
            "CreditShoppingRefreshCountReached",
            "CreditShoppingPrudentRefresh",
            "CreditShoppingBuyBlacklist",
            "CreditShippingCanNotToBuy",
            "ADBSpecial",
            "RefreshItem",
            "CreditShoppingNothingToBuy"
        ]
    },
    "ADBSpecial": {
        "desc": "ADB特殊流程,向上滑动一段",
        "enabled": false,
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    640,
                    500
                ],
                "end": [
                    640,
                    300
                ],
                "duration": 500
            }
        },
        "next": [
            "AutoGetCredits",
            "CreditShoppingBuyPriority1",
            "CreditShoppingBuyPriority2",
            "CreditShoppingBuyPriority3",
            "CreditShoppingReserveCredit",
            "CreditShoppingRefreshCountReached",
            "CreditShoppingPrudentRefresh",
            "CreditShoppingBuyBlacklist",
            "CreditShippingCanNotToBuy",
            "RefreshItem",
            "CreditShoppingNothingToBuy"
        ]
    },
    "CreditShippingCanNotToBuy": {
        "desc": "刷新流程中无法购买（选项：没有可购买物品时=执行刷新）",
        "enabled": false,
        "recognition": "Or",
        "any_of": [
            "AutoGetCredits",
            "CanNotFlash"
        ],
        "focus": {
            "Node.Action.Succeeded": "$task.CreditShopping.refresh_no_credit"
        }
    },
    "RefreshItem": {
        "desc": "刷新商品（选项：没有可购买物品时=执行刷新）",
        "enabled": false,
        "recognition": "And",
        "all_of": [
            "RefreshText"
        ],
        "action": "Click",
        "post_wait_freezes": {
            "time": 500,
            "timeout": 2000,
            "target": [
                66,
                97,
                1153,
                544
            ]
        },
        "next": [
            "CreditShoppingShopping",
            "[JumpBack]YellowConfirmButtonType1"
        ],
        "focus": {
            "Node.Action.Succeeded": "刷新商品"
        }
    },
    "CreditShoppingReserveCredit": {
        "desc": "信用点低于保留阈值（选项：保留信用点阈值）",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ExpressionRecognition",
                "custom_recognition_param": {
                    "expression": "{CreditShoppingReserveCreditOCRInternal}<300"
                }
            }
        },
        "focus": {
            "Node.Recognition.Succeeded": "$task.CreditShopping.reserve_credit_reached"
        }
    },
    "CreditShoppingReserveCreditSatisfied": {
        "desc": "信用点高于等于保留阈值（选项：保留信用点阈值）",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ExpressionRecognition",
                "custom_recognition_param": {
                    "expression": "{CreditShoppingReserveCreditOCRInternal}>=300"
                }
            }
        }
    },
    "CreditShoppingPriority1ReserveCreditGate": {
        "desc": "优先购买的保留信用点准入判断",
        "recognition": "DirectHit"
    },
    "CreditShoppingPriority2ReserveCreditGate": {
        "desc": "普通购买1的保留信用点准入判断",
        "recognition": "And",
        "all_of": [
            "CreditShoppingReserveCreditSatisfied"
        ]
    },
    "CreditShoppingPriority3ReserveCreditGate": {
        "desc": "普通购买2的保留信用点准入判断",
        "recognition": "And",
        "all_of": [
            "CreditShoppingReserveCreditSatisfied"
        ]
    },
    "CreditShoppingReserveCreditOCRInternal": {
        "desc": "识别当前信用点",
        "recognition": "OCR",
        "roi": [
            1123,
            21,
            38,
            17
        ],
        "expected": "^\\d+$",
        "only_rec": true,
        "color_filter": "CreditShoppingReserveCreditOCRInternalColor"
    },
    "CreditShoppingReserveCreditOCRInternalColor": {
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    1083,
                    17,
                    114,
                    27
                ],
                "method": 6,
                "lower": [
                    198
                ],
                "upper": [
                    255
                ]
            }
        }
    },
    "AutoGetCredits": {
        "desc": "已启用购买物品买不起时自动去基建获取（由 CreditShoppingPriority1AutoGetCredits / CreditShoppingPriority2AutoGetCredits / CreditShoppingPriority3AutoGetCredits 控制）",
        "max_hit": 1,
        "recognition": "Or",
        "any_of": [
            "AutoGetCreditsBuyPriority1",
            "AutoGetCreditsBuyPriority2",
            "AutoGetCreditsBuyPriority3"
        ],
        "next": [
            "GoToNeedCredit"
        ]
    },
    "GoToNeedCredit": {
        "max_hit": 1,
        "next": [
            "[JumpBack]NeedCredit",
            "CreditShoppingShopping",
            "CreditShoppingCheckShopPage",
            "[JumpBack]SceneEnterMenuShop"
        ],
        "focus": {
            "Node.Action.Succeeded": "$task.CreditShopping.auto_get_credits"
        }
    },
    "AutoGetCreditsBuy": {
        "recognition": "Or",
        "any_of": [
            "AutoGetCreditsBuyPriority1",
            "AutoGetCreditsBuyPriority2",
            "AutoGetCreditsBuyPriority3"
        ]
    },
    "AutoGetCreditsBuyPriority1": {
        "recognition": "And",
        "all_of": [
            "CreditIcon",
            "NotSoldOut",
            "CanNotAfford",
            "BuyFirstOCR_CanNotAfford",
            "IsDiscountPriority1_CanNotAfford"
        ],
        "box_index": 4
    },
    "AutoGetCreditsBuyPriority2": {
        "recognition": "And",
        "all_of": [
            "CreditIcon",
            "NotSoldOut",
            "CanNotAfford",
            "Priority2OCR_CanNotAfford",
            "IsDiscountPriority2_CanNotAfford"
        ],
        "box_index": 4
    },
    "AutoGetCreditsBuyPriority3": {
        "recognition": "And",
        "all_of": [
            "CreditIcon",
            "NotSoldOut",
            "CanNotAfford",
            "Priority3OCR_CanNotAfford",
            "IsDiscountPriority3_CanNotAfford"
        ],
        "box_index": 4
    },
