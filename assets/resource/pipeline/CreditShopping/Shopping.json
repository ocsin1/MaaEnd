        "desc": "优先购买（选项：优先购买物品、折扣设置、是否检测信用点阈值）",
        "recognition": "And",
        "all_of": [
            "CreditIcon",
            "NotSoldOut",
            "CanAfford",
            "BuyFirstOCR",
            "IsDiscountPriority1",
