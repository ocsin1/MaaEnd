        "target_offset": [
            -30,
            70,
            0,
            0
        ],
        "next": [
            "CreditShoppingBuyItem"
        ]
    },
    "CreditShoppingBuyPriority2": {
        //"enabled": false,
        "desc": "普通购买1（选项：普通购买1物品、折扣设置、是否检测信用点阈值）",
        "recognition": "And",
        "all_of": [
            "CreditIcon",
            "NotSoldOut",
            "CanAfford",
            "Priority2OCR",
            "IsDiscountPriority2",
            "CreditShoppingPriority2ReserveCreditGate"
        ],
        "box_index": 4,
        "pre_wait_freezes": 100,
        "action": "Click",
        "target_offset": [
            -30,
            70,
            0,
            0
        ],
        "next": [
            "CreditShoppingBuyItem"
        ]
    },
    "CreditShoppingBuyPriority3": {
        "desc": "普通购买2（选项：普通购买2物品、折扣设置、是否检测信用点阈值）",
        "recognition": "And",
        "all_of": [
            "CreditIcon",
            "NotSoldOut",
            "CanAfford",
            "Priority3OCR",
            "IsDiscountPriority3",
            "CreditShoppingPriority3ReserveCreditGate"
        ],
        "box_index": 4,
        "pre_wait_freezes": 100,
        "action": "Click",
        "target_offset": [
            -30,
            70,
            0,
            0
        ],
        "next": [
            "CreditShoppingBuyItem"
        ]
    },
    "CreditShoppingBuyBlacklist": {
        "desc": "强制购买剩余可购物品（选项：购买选项均未命中时操作=购买任意物品）",
        "recognition": "And",
        "all_of": [
            "CreditIcon",
            "NotSoldOut",
            "CanAfford"
        ],
        "box_index": 2,
        "pre_wait_freezes": 100,
        "action": "Click",
        "next": [
            "CreditShoppingBuyItem"
        ]
    },
    "CreditShoppingPrudentRefresh": {
        "desc": "稳健模式下改为直接购买（选项：稳健模式刷新、稳健刷新阈值）",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    {
                        "recognition": {
                            "type": "Custom",
                            "param": {
                                "custom_recognition": "ExpressionRecognition",
                                "custom_recognition_param": {
                                    "expression": "{CreditShoppingReserveCreditOCRInternal}-{RefreshCost}<400"
                                }
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "And",
                            "param": {
                                "all_of": [
                                    "CreditIcon",
                                    "NotSoldOut",
                                    "CanAfford"
                                ],
                                "box_index": 2
                            }
                        }
                    }
                ],
                "box_index": 1
            }
        },
        "pre_wait_freezes": 100,
        "action": {
            "type": "Click"
        },
        "next": [
            "CreditShoppingBuyItem"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.CreditShopping.prudent_refresh_triggered"
        }
    },
    "CreditShoppingRefreshCountReached": {
        "desc": "刷新次数已用尽时直接购买（选项：没有可购买物品时=执行刷新）",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    {
                        "recognition": {
                            "type": "OCR",
                            "param": {
                                "roi": [
                                    885,
                                    535,
                                    395,
                                    185
                                ],
                                "expected": [
                                    "今日刷新次数已用尽"
                                ]
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "And",
                            "param": {
                                "all_of": [
                                    "CreditIcon",
                                    "NotSoldOut",
                                    "CanAfford"
                                ],
                                "box_index": 2
                            }
                        }
                    }
                ],
                "box_index": 1
            }
        },
        "pre_wait_freezes": 100,
        "action": {
            "type": "Click"
        },
        "next": [
            "CreditShoppingBuyItem"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.CreditShopping.refresh_count_reached_triggered"
        }
    },
    "CreditShoppingNothingToBuy": {
        "desc": "没有合适的东西可以买了",
        "recognition": "DirectHit",
        "focus": {
            "Node.Recognition.Succeeded": "$task.CreditShopping.nothing_to_buy"
        }
    }
}
