{
    "AutoStockpileDecisionWuling": {
        "desc": "统一识别与决策：CustomRecognition识别商品，CustomAction选择购买",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "AutoStockpile.Recognition",
                "custom_recognition_param": {}
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "AutoStockpile.SelectItem",
                "custom_action_param": {
                    "Region": "Wuling"
                }
            }
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileClearDecisionHitCount"
        ]
    },
    "AutoStockpileDecisionValleyIV": {
        "desc": "统一识别与决策：CustomRecognition识别商品，CustomAction选择购买",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "AutoStockpile.Recognition",
                "custom_recognition_param": {}
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "AutoStockpile.SelectItem",
                "custom_action_param": {
                    "Region": "ValleyIV"
                }
            }
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileClearDecisionHitCount"
        ]
    },
    "AutoStockpileClearDecisionHitCount": {
        "desc": "清除中继节点MaxHit",
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "ClearHitCount",
                "custom_action_param": {
                    "nodes": [
                        "AutoStockpileRelayNodeDecision"
                    ]
                }
            }
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileRelayNodeDecision"
        ]
    },
    "AutoStockpileRelayNodeDecision": {
        "desc": "限制复核重试次数",
        "max_hit": 4,
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileSelectedGoodsClick",
            "AutoStockpileSkip"
        ]
    },
    "AutoStockpileSelectedGoodsClick": {
        "desc": "[Go覆盖] 点击决策选中的商品 (template)",
        "enabled": false,
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    50,
                    180,
                    1200,
                    500
                ],
                "template": [
                    "AutoStockpile/StockRedistributionButton.png"
                ],
                "threshold": [
                    0.8
                ]
            }
        },
        "pre_wait_freezes": 80,
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileEnsureDetailFrameStable"
        ]
    },
    "AutoStockpileEnsureDetailFrameStable": {
        "desc": "确保详情页已经加载完成",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    170,
                    120,
                    50,
                    50
                ],
                "template": [
                    "AutoStockpile/Cart.png"
                ]
            }
        },
        "pre_wait_freezes": {
            "time": 80,
            "target": [
                1000,
                240,
                80,
                30
            ],
            "threshold": 0.98
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileEnsureCashAnchor"
        ]
    },
    "AutoStockpileEnsureCashAnchor": {
        "desc": "确保现金标识可见，作为价格OCR锚点",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    975,
                    230,
                    130,
                    50
                ],
                "template": [
                    "AutoStockpile/ValleyCash.png",
                    "AutoStockpile/WulingCash.png"
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileReconcileDecision"
        ]
    },
    "AutoStockpileBackToSelection": {
        "desc": "返回选择界面，准备下一轮决策",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "CloseButtonType1"
                ]
            }
        },
        "pre_wait_freezes": 80,
        "pre_delay": 0,
        "action": {
            "type": "Click",
            "param": {}
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "AutoStockpileRelayNodeDecision",
            "AutoStockpileDecisionFailed"
        ]
    },
    "AutoStockpileSkip": {
        "desc": "决策未找到合格商品或提前结束",
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "focus": {
            "Node.Recognition.Succeeded": "跳过本次购买"
        }
    },
    "AutoStockpileDecisionFailed": {
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "focus": {
            "Node.Recognition.Starting": "<span style=\"color: orange\">⚠️超过最大复核重试次数，已跳过地区</span>"
        }
    },
    "AutoStockpileReconcileDecision": {
        "desc": "根据详情页价格校正并重算决策",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "AutoStockpileEnsureCashAnchor",
                "roi_offset": [
                    23,
                    -7,
                    33,
                    7
                ],
                "expected": [
                    "\\d{3,4}"
                ],
                "replace": [
                    [
                        "[^\\d]",
                        ""
                    ]
                ],
                "order_by": "Vertical",
                "only_rec": true
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "AutoStockpile.ReconcileDecision"
            }
        },
        "post_delay": 0,
        "timeout": 5000,
        "rate_limit": 0,
        "next": [
            "AutoStockpileRelayNodeDecisionReady",
            "AutoStockpileBackToSelection"
        ]
    }
}
