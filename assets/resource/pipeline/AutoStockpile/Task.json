    "AutoStockpileReconcileDecision": {
        "desc": "根据详情页价格校正并重算决策",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    990,
                    485,
                    70,
                    35
                ],
                "expected": [
                    "^\\d{3,4}$"
                ],
                "only_rec": true
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "AutoStockpile.ReconcileDecision"
            }
        },
        "post_delay": 0,
        "timeout": 5000,
        "rate_limit": 0,
        "next": [
            "AutoStockpileRelayNodeDecisionReady",
            "AutoStockpileBackToSelection"
