{
    "EssenceFilterUnavailable": {
        "desc": "新版本 UI 变动，暂时无法使用",
        "recognition": {
            "type": "DirectHit",
            "param": {}
        },
        "rate_limit": 0,
        "pre_delay": 0,
        "action": {
            "type": "DoNothing"
        },
        "post_delay": 0,
        "focus": {
            "Node.Recognition.Succeeded": "$task.EssenceFilter.description"
        }
    },
    "EssenceFilterMain": {
        "desc": "入口点",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "EssenceFilterSwitchTab",
            "EssenceFilterInitNormalize",
            "[JumpBack]SceneEnterMenuValuables"
        ],
        "on_error": "EssenceFilterMainFailed"
    },
    "EssenceFilterInitNormalize": {
        "desc": "初始化：若在基质栏位则先切武器库再切回基质页，否则直接切基质页（已选中武器基质页签）",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    435,
                    3,
                    150,
                    49
                ],
                "template": "EssenceFilter/EssenceTabChoose.png",
                "threshold": 0.9
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "DoNothing"
        },
        "post_delay": 0,
        "timeout": 2000,
        "next": [
            "EssenceFilterSwitchToWeapon"
        ]
    },
    "EssenceFilterSwitchToWeapon": {
        "desc": "切换到武器库标签页",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    200,
                    0,
                    350,
                    80
                ],
                "template": "EssenceFilter/EssenceWeapon.png",
                "threshold": 0.9
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 400,
        "post_delay": 0,
        "next": [
            "EssenceFilterSwitchTab"
        ]
    },
    "EssenceFilterSwitchTab": {
        "desc": "切换到武器基质标签页",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    350,
                    0,
                    500,
                    80
                ],
                "template": "EssenceFilter/EssenceTabNotChoose.png",
                "threshold": 0.9
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 400,
        "post_delay": 0,
        "next": [
            "EssenceFilterCheckInInventory"
        ]
    }
}
