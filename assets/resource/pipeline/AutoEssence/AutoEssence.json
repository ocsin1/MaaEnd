{
    "AutoEssenceMain": {
        "desc": "自动基质刷取的主入口",
        "anchor": {
            "AutoEssenceAfterMoveToTriggerPoint": "AutoEssenceClickTriggerButtonPre"
        },
        "next": [
            "AutoEssenceClickEssenceStartButton",
            "[JumpBack]AutoEssenceLocationSetup",
            "[Anchor]AutoEssenceMoveToTriggerPoint"
        ],
        "focus": {
            "Node.Action.Starting": "▶️**准备开始本次基质刷取**"
        }
    },
    "AutoEssenceLocationSetup": {
        "desc": "识别和确定附近的淤积点所属的地区",
        "max_hit": 1,
        "rate_limit": 2000,
        "next": [
            "VFTheHubLocationAssertion",
            "VFOriginiumScienceParkLocationAssertion",
            "VFOriginLodespringLocationAssertion",
            "VFPowerPlateauLocationAssertion",
            "WLWulingCityLocationAssertion",
            "WLQingboStockadeLocationAssertion",
            "[JumpBack]AutoEssenceLocationSetupFailed"
        ],
        "focus": {
            "Node.Action.Starting": "🔍正在寻找附近的淤积点"
        }
    },
    "AutoEssenceLocationSetupFailed": {
        "desc": "未能识别附近的淤积点所属的地区",
        "focus": {
            "Node.Action.Starting": "❓未能识别附近的淤积点所属的地区\n请确保当前**处于淤积点附近**，并且未遮挡小地图！"
        }
    },
    "__AutoEssenceAltKeyUp": {
        "desc": "释放键盘 Alt 键（通过覆写 AutoEssenceAfterAltKeyUp 锚点即可设置该节点执行完毕后的下一个节点）",
        "action": {
            "type": "KeyUp",
            "param": {
                "key": 18
            }
        },
        "next": [
            "[Anchor]AutoEssenceAfterAltKeyUp"
        ]
    },
    "AutoEssenceClickTriggerButtonPre": {
        "desc": "准备点击激发的大世界按钮，先按下 Alt 键",
        "action": {
            "type": "KeyDown",
            "param": {
                "key": 18
            }
        },
        "timeout": 1000,
        "next": [
            "AutoEssenceClickTriggerButton"
        ],
        "on_error": [
            "AutoEssenceClickTriggerButtonFailedPre"
        ]
    },
    "AutoEssenceClickTriggerButton": {
        "desc": "正式识别并点击激发的大世界按钮",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    800,
                    450,
                    100,
                    180
                ],
                "template": "AutoEssence/EssenceTrigger.png",
                "green_mask": true,
                "order_by": "Score"
            }
        },
        "action": {
            "type": "Click"
        },
        "anchor": {
            "AutoEssenceAfterAltKeyUp": "AutoEssenceReadyToStart"
        },
        "next": [
            "__AutoEssenceAltKeyUp"
        ],
        "focus": {
            "Node.Action.Starting": "👆点击激发按钮"
        }
    },
    "AutoEssenceClickTriggerButtonFailedPre": {
        "desc": "未能识别到激发的大世界按钮，先释放 Alt 键",
        "action": {
            "type": "KeyUp",
            "param": {
                "key": 18
            }
        },
        "next": [
            "AutoEssenceClickTriggerButtonFailed"
        ]
    },
    "AutoEssenceClickTriggerButtonFailed": {
        "desc": "未能识别到激发的大世界按钮、且释放了 Alt 键之后的守卫节点",
        "max_hit": 8,
        "next": [
            "[Anchor]AutoEssenceMoveToTriggerPoint"
        ]
    },
    "AutoEssenceReadyToStart": {
        "desc": "点击了激发的大世界按钮之后的守卫节点",
        "pre_delay": 0,
        "post_wait_freezes": 500,
        "post_delay": 0,
        "next": [
            "AutoEssenceMistakeFactoryDevice",
            "AutoEssenceClickEssenceStartButton"
        ]
    },
    "AutoEssenceMistakeFactoryDevice": {
        "desc": "识别是否误入工业设备界面，并将其关闭",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    950,
                    30,
                    270,
                    230
                ],
                "template": "AutoEssence/FactoryDeviceDialog.png"
            }
        },
        "action": {
            "type": "Click", // 此处点击的是工业设备界面的关闭按钮
            "param": {
                "target_offset": [
                    50,
                    5,
                    -50,
                    -10
                ]
            }
        },
        "next": [
            "AutoEssenceClickTriggerButtonFailed"
        ],
        "focus": {
            "Node.Action.Starting": "😕误入工业设备界面，点击关闭按钮"
        }
    },
