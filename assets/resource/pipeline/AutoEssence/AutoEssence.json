    "AutoEssenceOnSuccess": {
        "desc": "成功完成一次基质刷取后的守卫节点",
        "next": [
            // 循环与整次结束由任务选项覆写 next；典型为 Main -> [JumpBack]汇总 -> OnComplete（汇总无自有 next，JumpBack 后继续 OnComplete）
            "[JumpBack]AutoEssenceAfterBattleRunEndLootReport",
            "AutoEssenceOnComplete"
        ],
        "focus": {
            "Node.Action.Starting": "✅已完成一次基质刷取"
        }
    },
    "AutoEssenceAfterBattleRunEndLootReport": {
        "desc": "战后筛选整次任务汇总：EssenceFilterFinishAction；max_hit=1 全任务仅输出一次；须由父节点以 [JumpBack] 引用以便继续 OnComplete 或体力不足 StopTask；默认关闭",
        "enabled": false,
        "max_hit": 1,
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "EssenceFilterFinishAction"
            }
        },
        "post_delay": 0
    },
    "AutoEssenceOnComplete": {
        "desc": "成功完成了所有基质刷取，安全结束任务",
        "action": "StopTask",
        "focus": {
            "Node.Action.Starting": "🎉**已完成所规定次数的基质刷取**"
        }
    }
}
