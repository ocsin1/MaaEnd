{
    "AutoEssenceMain": {
        "desc": "自动基质刷取的主入口",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "AutoEssenceDispatcher"
        ],
        "focus": {
            "Node.Action.Starting": "▶️**准备开始本次基质刷取**"
        }
    },
    "AutoEssenceDispatcher": {
        "desc": "自动基质刷取的主分发器，识别当前的所有可能状态并决定下一步操作",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            // 如果玩家已唤起了激发的界面
            "AutoEssenceClickEssenceStartButton",
            // 如果玩家当前已精准处于某个淤积点的交互位置
            "AutoEssenceClickTriggerButton",
            // 如果玩家当前已精准处于某个淤积点的交互位置，并且处于奖励待领取的状态
            "[JumpBack]AutoEssenceClickObtainButton",
            "[JumpBack]AutoEssenceClickDiscardButton",
            "[JumpBack]AutoEssenceInObtain",
            // 如果上述情况都不满足，则根据所选的地区，导航到对应的淤积点的交互位置
            "AutoEssenceSpecifiedLocation"
        ]
    },
    "AutoEssenceSpecifiedLocation": {
        "desc": "自动导航到指定的淤积点（可供覆写，默认是枢纽区；此节点默认开启）",
        "enabled": true,
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "VFTheHubMoveToTriggerPointAuto" // 覆写为其他地区的对应节点即可导航到其他地区
        ],
        "focus": {
            "Node.Action.Starting": "😎滴！MapTracker智能导航已就绪"
        }
    },
    "__AutoEssenceBackToWorldOnce": {
        "desc": "仅一次，万能跳转回到大世界（需 jumpback 调用）",
        "max_hit": 1,
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "[JumpBack]SceneAnyEnterWorld"
        ]
    },
    "__AutoEssenceRecoEssenceTriggerButton": {
        "desc": "寻找激发的大世界按钮（仅识别）",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    800,
                    450,
                    100,
                    180
                ],
                "template": "AutoEssence/EssenceTrigger.png",
                "green_mask": true,
                "order_by": "Score"
            }
        }
    },
    "__AutoEssenceRecoEssenceTriggerText": {
        "desc": "寻找激发的文字（仅识别）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "__AutoEssenceRecoEssenceTriggerButton",
                "roi_offset": [
                    0,
                    0,
                    150,
                    0
                ],
                "expected": [
                    "激发", // 激发
                    "觸發", // 觸發
                    "Trigger", // Trigger
                    "トリガー" // トリガー
                ]
            }
        }
    },
    "AutoEssenceClickTriggerButton": {
        "desc": "识别并点击激发的大世界按钮（Alt 点击）",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "__AutoEssenceRecoEssenceTriggerButton",
                    "__AutoEssenceRecoEssenceTriggerText"
                ]
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "AutoAltClickAction"
            }
        },
        "timeout": 2000,
        "next": [
            "AutoEssenceMistakeFactoryDevice",
            "AutoEssenceReadyToStart"
        ],
        "on_error": [
            "AutoEssenceClickTriggerButtonFailed"
        ],
        "focus": {
            "Node.Action.Starting": "👆点击激发按钮"
        }
    },
    "AutoEssenceClickTriggerButtonFailed": {
        "desc": "未能识别到激发的大世界按钮的守卫节点",
        "max_hit": 8,
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "[Anchor]AutoEssenceMoveToTriggerPoint"
        ]
    },
    "AutoEssenceReadyToStart": {
        "desc": "点击了激发的大世界按钮之后的守卫节点",
        "pre_delay": 0,
        "post_wait_freezes": 500,
        "post_delay": 0,
        "next": [
            "AutoEssenceMistakeFactoryDevice",
            "AutoEssenceClickEssenceStartButton"
        ]
    },
    "AutoEssenceMistakeFactoryDevice": {
        "desc": "识别是否误入工业设备界面，并将其关闭",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    950,
                    30,
                    270,
                    230
                ],
                "template": "AutoEssence/FactoryDeviceDialog.png"
            }
        },
        "action": {
            "type": "Click", // 此处点击的是工业设备界面的关闭按钮
            "param": {
                "target_offset": [
                    50,
                    5,
                    -50,
                    -10
                ]
            }
        },
        "next": [
            "AutoEssenceClickTriggerButtonFailed"
        ],
        "focus": {
            "Node.Action.Starting": "😕误入工业设备界面，点击关闭按钮"
        }
    },
    "AutoEssenceClickEssenceStartButton": {
        "desc": "识别并点击开始界面中的开始挑战按钮",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1155,
                    590,
                    125,
                    130
                ],
                "template": "Common/Button/WhiteConfirmButtonType1.png"
            }
        },
        "pre_wait_freezes": 1000,
        "action": {
            "type": "Click"
        },
        "post_delay": 1000,
        "next": [
            "AutoEssenceDismissWarning1",
            "AutoEssenceChallengeEnter"
        ],
        "focus": {
            "Node.Action.Starting": "👆点击开启挑战按钮"
        }
    },
    "AutoEssenceDismissWarning1": {
        "desc": "识别并关闭开始挑战时的第一个警告弹窗",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    730,
                    390,
                    200,
                    150
                ],
                "template": "Common/Button/YellowConfirmButtonType1.png"
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 1000,
        "next": [
            "AutoEssenceDismissWarning2",
            "AutoEssenceChallengeEnter"
        ],
        "focus": {
            "Node.Action.Starting": "👷无视风险，继续刷取"
        }
    },
    "AutoEssenceDismissWarning2": {
        "desc": "识别并关闭开始挑战时的第二个警告弹窗",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    730,
                    390,
                    200,
                    150
                ],
                "template": "Common/Button/YellowConfirmButtonType1.png"
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 1000,
        "next": [
            "AutoEssenceChallengeEnter"
        ],
        "focus": {
            "Node.Action.Starting": "👷无视风险，继续刷取"
        }
    },
    "__AutoEssenceRecoEssenceOngoing": {
        "desc": "寻找挑战进行中的状态（仅识别）",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    40,
                    260,
                    330
                ],
                "template": "AutoEssence/EssenceOngoing.png",
                "green_mask": true
            }
        }
    },
    "AutoEssenceChallengeEnter": {
        "desc": "检查是否进入挑战，随后使用自动战斗方式进行挑战",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "__AutoEssenceRecoEssenceOngoing"
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "[JumpBack]AutoFight",
            "AutoEssenceChallengeFinished"
        ],
        "focus": {
            "Node.Recognition.Starting": "⚔️正在通过自动战斗挑战"
        }
    },
    "AutoEssenceChallengeFinished": {
        "desc": "检查是否挑战结束",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "__AutoEssenceRecoEssenceOngoing"
                ]
            }
        },
        "inverse": true,
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "[Anchor]AutoEssenceMoveToTriggerPoint" // 此 Anchor 最终会走回 AutoEssenceDispatcher 进行后续的奖励领取等操作
        ],
        "focus": {
            "Node.Recognition.Starting": "🔍检查挑战是否结束",
            "Node.Action.Starting": "👌识别到挑战结束"
        }
    },
    "AutoEssenceInObtain": {
        "desc": "需要滑动以确保领取奖励的按钮组可见",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    738,
                    335,
                    445,
                    300
                ],
                "expected": [
                    "重度|能量|淤积点", // 重度能量淤积点
                    "重度|能量|淤積點", // 重度能量淤積點
                    "Severe|Energy|Alluvium", // Severe Energy Alluvium
                    "重度|超域|活性点" // 重度超域活性点
                ]
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "AutoAltSwipeAction",
                "custom_action_param": {
                    "begin_offset": [
                        0,
                        30,
                        0,
                        -10
                    ],
                    "end_offset": [
                        0,
                        -120,
                        0,
                        0
                    ]
                }
            }
        },
        "focus": {
            "Node.Action.Starting": "🖐️滑动交互列表"
        }
    },
    "__AutoEssenceRecoEssenceObtainButton": {
        "desc": "寻找领取奖励的状态（仅识别）",
