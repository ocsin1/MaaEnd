    "SeizeDeliveryJobsTaskEnd": {
        "desc": "任务结束节点：当重复次数用完时结束任务",
        "enabled": true,
        "recognition": "DirectHit",
        "action": "DoNothing",
        "focus": {
            "Node.Action.Starting": "$task.SeizeDeliveryJobs.focus.taskEnd"
        }
    }
}
