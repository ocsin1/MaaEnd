        "post_delay": 0,
        "next": [
            // 无后续节点，即停止任务
        ],
        "focus": {
            "Node.Recognition.Succeeded": "<p style=\"color: #f44\">已经携带了货物，但未开启自动送货</p>"
        }
    },
    // ===== 其他公共节点 =====
    "SeizeDeliveryJobsFatalCannotFetchGoods": {
        "desc": "致命错误，始终未识别到接取货物按钮",
