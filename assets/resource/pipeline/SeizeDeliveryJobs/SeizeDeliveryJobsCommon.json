{
    // ===== 从任意位置进入武陵仓储管理页面的公用节点 =====
    "SeizeDeliveryJobsEnterWulingJobList": {
        "desc": "从任意位置进入武陵仓储管理页面的运送委托列表（需覆写锚点 SeizeDeliveryAfterEnterWulingJobList 来控制下一步）",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "__SeizeDeliveryJobsInWulingDepotNode",
            "[JumpBack]SceneEnterMenuRegionalDevelopmentWulingDepotNode"
        ]
    },
    "__SeizeDeliveryJobsRecoWulingDepotNode": {
        "desc": "寻找武陵仓储管理页面的特征标志（仅识别）",
        "recognition": "TemplateMatch",
        "template": "SeizeDeliveryJobs/DepotNodePage/InWulingDepotNode.png",
        "roi": [
            970,
            10,
            270,
            180
        ],
        "order_by": "Score"
    },
    "__SeizeDeliveryJobsRecoJobListActive": {
        "desc": "寻找已激活的运送委托列表标签页（仅识别）",
        "recognition": "TemplateMatch",
        "template": "SeizeDeliveryJobs/DepotNodePage/JobListTabActive.png",
        "roi": [
            170,
            10,
            180,
            180
        ],
        "order_by": "Score"
    },
    "__SeizeDeliveryJobsRecoJobList": {
        "desc": "寻找未激活的运送委托列表标签页（仅识别）",
        "recognition": "TemplateMatch",
        "template": "SeizeDeliveryJobs/DepotNodePage/JobListTab.png",
        "roi": [
            170,
            10,
            180,
            180
        ],
        "order_by": "Score"
    },
    "__SeizeDeliveryJobsInWulingDepotNode": {
        "desc": "已经在武陵仓储管理页面",
        "recognition": "And",
        "all_of": [
            "__SeizeDeliveryJobsRecoWulingDepotNode"
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "__SeizeDeliveryJobsInJobList",
            "[JumpBack]__SeizeDeliveryJobsEnterJobList"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "已位于武陵仓储管理"
        }
    },
    "__SeizeDeliveryJobsEnterJobList": {
        "desc": "在任意地区仓储管理页面，进入运送委托列表（需 jumpback 调用）",
        "max_hit": 10,
        "recognition": "And",
        "all_of": [
            "__SeizeDeliveryJobsRecoJobList"
        ],
        "action": "Click",
        "focus": {
            "Node.Action.Starting": "点击运送委托列表"
        }
    },
    "__SeizeDeliveryJobsInJobList": {
        "desc": "已经在运送委托列表",
        "recognition": "And",
        "all_of": [
            "__SeizeDeliveryJobsRecoJobListActive"
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "post_wait_freezes": 1000, // 等待列表加载动画结束
        "next": [
            "[Anchor]SeizeDeliveryJobsAfterEnterWulingJobList" // 外部调用者需要覆写此锚点的所指
        ],
        "focus": {
            "Node.Recognition.Succeeded": "已位于运送委托列表"
        }
    },
    // ===== 从任意位置进入当前送货任务的地图界面的公共节点 =====
    "SeizeDeliveryJobsEnterDestinationMap": {
        "desc": "从任意位置进入当前送货任务的地图界面",
        "pre_delay": 0,
        "post_delay": 0,
        "anchor": {
            "SeizeDeliveryJobsAfterEnterWulingJobList": "__SeizeDeliveryJobsReadyToViewCurrentJob"
        },
        "next": [
            "SeizeDeliveryJobsEnterWulingJobList"
        ]
    },
    "__SeizeDeliveryJobsReadyToViewCurrentJob": {
        "desc": "在运送委托列表，准备查看当前任务详情",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "__SeizeDeliveryJobsViewCurrentJob"
        ],
        "timeout": 5000 // 断言在较短时间内可找到当前任务详情（没找到就是没接任务）
    },
    "__SeizeDeliveryJobsRecoViewCurrentJob": {
        "desc": "寻找查看当前任务详情按钮（仅识别）",
        "recognition": "TemplateMatch",
        "template": "SeizeDeliveryJobs/DepotNodePage/JobViewButton.png",
        "roi": [
            1170,
            160,
            100,
            210
        ],
        "order_by": "Score"
    },
    "__SeizeDeliveryJobsViewCurrentJob": {
        "desc": "在运送委托列表，点击查看当前任务详情",
        "recognition": "TemplateMatch",
        "template": "SeizeDeliveryJobs/DepotNodePage/JobViewButton.png",
        "roi": [
            1170,
            160,
            100,
            210
        ], // 由于 And 模式不能正确处理 target_offset，此处直接拷贝原始识别参数
        // "recognition": "And",
        // "all_of": [
        //     "__SeizeDeliveryJobsRecoViewCurrentJob"
        // ],
        "order_by": "Score",
        "action": "Click",
        "target_offset": [
            -50,
            0,
            0,
            -10
        ], // 点击识别位置稍左位置，并压缩点击高度，防止点到按钮外面
        "post_wait_freezes": 500, // 等待任务详情界面弹出
        "next": [
            "__SeizeDeliveryJobsViewDestinationMap",
            "__SeizeDeliveryJobsStartTrackingTask"
        ],
        "focus": {
            "Node.Action.Starting": "打开当前任务详情"
        }
    },
    "__SeizeDeliveryJobsViewDestinationMap": {
        "desc": "在任务详情页面，点击定位按钮，打开大地图查看目的地",
        "recognition": "TemplateMatch",
        "template": "SeizeDeliveryJobs/TrackTaskButton.png",
        "roi": [
            940,
            580,
            150,
            130
        ],
        "order_by": "Score",
        "action": "Click",
        "next": [
            "__SeizeDeliveryJobsInDestinationMap"
        ],
        "focus": {
            "Node.Action.Starting": "点击查看任务位置"
        }
    },
    "__SeizeDeliveryJobsStartTrackingTask": {
        "desc": "在任务详情页面，若没找到定位按钮，此时需要先点击开始追踪任务按钮",
        "max_hit": 5, // 此为回环节点，防死循环
        "recognition": "TemplateMatch",
        "template": "Common/Button/WhiteConfirmButtonType1.png",
        "roi": [
            1070,
            570,
            200,
            140
        ],
        "order_by": "Score",
        "action": "Click",
        "next": [
            // 追踪任务后，界面会切换到大世界，此时需要回环执行前述流程
            "SeizeDeliveryJobsEnterWulingJobList"
        ],
        "focus": {
            "Node.Action.Starting": "点击开始追踪任务"
        }
    },
    "__SeizeDeliveryJobsInDestinationMap": {
        "desc": "确认已打开目的地地图",
        "recognition": "TemplateMatch",
        "template": "SeizeDeliveryJobs/TrackTaskSuccess.png",
        "roi": [
            900,
            10,
            130,
            140
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "__SeizeDeliveryJobsPurifyDestinationMap"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "正在查看任务位置"
        }
    },
    "__SeizeDeliveryJobsPurifyDestinationMap": {
        "desc": "在目的地地图界面，清理地图图标遮挡",
        "action": "Custom",
        "custom_action": "SubTask",
        "custom_action_param": {
            "sub": [
                "MapTrackerBigMap_FilterNone"
            ]
        },
        "anchor": {
            "SeizeDeliveryAfterEnterWulingJobList": "" // 任务结束，置空锚点以防止误用
        },
        "next": [
            "[Anchor]SeizeDeliveryJobsAfterEnterDestinationMap" // 外部调用者需要覆写此锚点的所指
        ],
        "focus": {
            "Node.Action.Starting": "清理图标遮挡"
        }
    }
}
