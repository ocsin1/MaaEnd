{
    "WeaponUpgradeStart": {
        "desc": "升级武器任务入口",
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "ClearHitCount",
                "custom_action_param": {
                    "nodes": [
                        "WeaponUpgradeSwitchLowLevel",
                        "WeaponUpgradeSwitchAscending"
                    ]
                }
            }
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "WeaponUpgradeSetFilter",
            "[JumpBack]SceneEnterMenuValuables"
        ]
    },
    "WeaponUpgradeSetFilter": {
        "desc": "设置武器库筛选条件",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    155,
                    85
                ],
                "expected": [
                    "武器"
                ]
            }
        },
        "pre_wait_freezes": {
            "time": 100,
            "target": [
                0,
                -400,
                400,
                400
            ]
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "[JumpBack]WeaponUpgradeSwitchLowLevel",
            "[JumpBack]WeaponUpgradeSwitchAscending",
            "WeaponUpgradeSelectLowLevelWeapons"
        ]
    },
    "WeaponUpgradeSelectLowLevelWeapons": {
        "desc": "选择低等级武器详情",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    985,
                    591,
                    277,
                    112
                ],
                "template": "Weapon/WeaponDetails.png",
                "threshold": 0.8
            }
        },
        "pre_wait_freezes": 100,
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "anchor": {
            "MouseMoveResetAnchor": "MouseMoveReset"
