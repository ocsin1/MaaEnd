{
    "WeaponUpgradeStart": {
        "desc": "升级武器任务入口",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "WeaponUpgradeSetFilter",
            "[JumpBack]SceneEnterMenuValuables"
        ]
    },
    "WeaponUpgradeSetFilter": {
        "desc": "设置武器库筛选条件",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    155,
                    85
                ],
                "expected": [
                    "武器"
                ]
            }
        },
        "pre_delay": 0,
        "post_wait_freezes": 1,
        "post_delay": 0,
        "next": [
            "[JumpBack]WeaponUpgradeSwitchLowLevel",
            "[JumpBack]WeaponUpgradeSwitchAscending",
            "WeaponUpgradeSelectLowLevelWeapons"
        ]
    },
    "WeaponUpgradeSelectLowLevelWeapons": {
        "desc": "选择低等级武器详情",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    985,
                    591,
                    277,
                    112
                ],
                "template": "Weapon/WeaponDetails.png",
                "threshold": 0.8
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 1,
        "next": [
            "WeaponUpgradeClickLevelUpButton"
        ]
    },
    "WeaponUpgradeClickLevelUpButton": {
        "desc": "进入升级UI",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "LevelUpButton"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "WeaponUpgradeClickAddUpgradeMaterial"
        ]
    },
    "WeaponUpgradeClickAddUpgradeMaterial": {
        "desc": "点击添加升级材料按钮",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1201,
                    54,
                    53,
                    135
                ],
                "template": "Weapon/AddUpgradeMaterialButton.png",
                "threshold": 0.8
            }
        },
        "pre_wait_freezes": 200,
        "action": {
            "type": "Click"
        },
        "next": [
            "WeaponUpgradeConfirmUpgradeLevel"
        ]
    },
    "WeaponUpgradeConfirmUpgradeLevel": {
        "desc": "确认升级等级",
        "recognition": "And",
        "all_of": [
            "LevelUpButton",
            {
                "recognition": "TemplateMatch",
                "roi": [
                    0,
                    -200,
                    200,
                    200
                ],
                "template": "Weapon/UpgradeMaterialsDelete.png"
            }
        ],
        "box_index": 0,
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 10,
        "next": [
            "WeaponUpgradeWeaponFinished",
            "[JumpBack]SceneAnyEnterWorld"
        ]
    },
    "WeaponUpgradeWeaponFinished": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    -200,
                    0,
                    200,
                    200
                ],
                "template": [
                    "SceneManager/WorldMenu.png"
                ],
                "green_mask": true
            }
        },
        "pre_delay": 0,
        "post_delay": 0
    },
    "WeaponUpgradeSwitchLowLevel": {
        "desc": "识别品质，切换到等级分类",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    16,
                    561,
                    375,
                    133
                ],
                "expected": [
                    "品质",
                    "品質",
                    "(?i)^Quality$"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 1,
        "next": [
            "WeaponUpgradeClickLevelSort",
            "WeaponUpgradeSwitchLowLevel"
        ]
    },
    "WeaponUpgradeClickLevelSort": {
        "desc": "识别武器等级",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    16,
                    561,
                    375,
                    133
                ],
                "expected": [
                    "武器等级",
                    "武器等級",
                    "(?i)^Weapon\\s*Level$",
                    "レベル"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 1
    },
    "WeaponUpgradeSwitchAscending": {
        "desc": "识别到降序，变成升序",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    16,
                    561,
                    375,
                    133
                ],
                "expected": [
                    "降序",
                    "(?i)^DESC$",
                    "降順"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 1
    }
}
