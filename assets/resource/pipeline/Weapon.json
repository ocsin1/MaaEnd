        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "[JumpBack][Anchor]MouseMoveResetAnchor",
            "WeaponUpgradeClickLevelUpButton"
        ]
    },
    "WeaponUpgradeClickLevelUpButton": {
        "desc": "进入升级UI",
        "max_hit": 5,
        "recognition": "And",
        "all_of": [
            "LevelUpButton"
        ],
        "pre_wait_freezes": {
            "time": 200,
            "target": [
                0,
                0,
                200,
                200
            ]
        },
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_delay": 0,
        "timeout": 5000,
        "rate_limit": 0,
        "next": [
            "WeaponUpgradeClickAddUpgradeMaterial"
        ],
        "on_error": [
            "WeaponUpgradeClickLevelUpButton" // 此动画过渡过程中会卡住时间较久，没办法了增加重试
        ]
    },
    "WeaponUpgradeClickAddUpgradeMaterial": {
        "desc": "点击添加升级材料按钮",
        "recognition": {
            "type": "TemplateMatch",
