{
    "EssenceFilterMainFailed": {
        "desc": "入口点失败",
        "pre_delay": 0,
        "action": {
            "type": "DoNothing"
        },
        "post_delay": 0,
        "next": [
            "EssenceFilterFinish"
        ],
        "focus": {
            "Node.Action.Failed": "未能进入基质界面，结束任务"
        }
    },
    "EssenceFilterCheckInInventory": {
        "desc": "检查是否在背包Essence页（已选中武器基质页签）",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    435,
                    3,
                    150,
                    49
                ],
                "template": "EssenceFilter/EssenceTabChoose.png",
                "threshold": 0.9
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "timeout": 2000,
        "next": [
            "EssenceFilterInit"
        ],
        "on_error": [
            "EssenceFilterNavigateToInventory"
        ],
        "focus": {
            "Node.Action.Succeeded": "确认在基质界面"
        }
    },
    "EssenceFilterNavigateToInventory": {
        "desc": "导航",
        "pre_delay": 0,
        "action": "DoNothing",
        "post_delay": 0,
        "next": [
            "EssenceFilterFinish"
        ],
        "focus": {
            "Node.Action.Succeeded": "不在基质界面"
        }
    },
    "EssenceFilterInit": {
        "desc": "初始化：加载数据与预设",
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "EssenceFilterInitAction"
            }
        },
        "post_wait_freezes": {
            "time": 50,
            "target": [
                38,
                398,
                922,
                198
            ]
        },
        "post_delay": 0,
        "next": [
            "EssenceGridAdvance"
        ],
        "focus": {
            "Node.Action.Succeeded": "初始化完成"
        }
    },
    "EssenceFilterFinish": {
        "desc": "任务完成",
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "EssenceFilterFinishAction"
            }
        },
        "post_delay": 0,
        "focus": {
            "Node.Action.Succeeded": "任务完成"
        }
    },
    "EssenceFilterTierBoundaryFlawlessNotice": {
        "desc": "仅选无暇：检测到高纯基质，提示后结束",
        "recognition": {
            "type": "DirectHit",
            "param": {}
        },
        "pre_delay": 0,
        "action": {
            "type": "DoNothing"
        },
        "post_delay": 0,
        "next": [
            "EssenceFilterFinish"
        ],
        "focus": {
            "Node.Action.Succeeded": "$task.EssenceFilter.focus.tier_boundary_flawless"
        }
    }
}
