        }
    },
    "EssenceFilterAfterBattleCloseDetail": {
        "desc": "点击左上角，关闭基质详情，防遮挡",
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    0,
                    0
                ]
            }
        },
        "next": [
            "EssenceFilterAfterBattleRowNextItem",
            "EssenceFilterAfterBattleExit"
        ]
    },
    "EssenceFilterAfterBattleRowNextItem": {
        "desc": "处理下一个命中的格子，或滑动/结束",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "EssenceFilterAfterBattleNthRecognition",
                "custom_recognition_param": {
                    "recognitionNodeName": "EssenceFullScreenDetectAll"
                }
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 200,
        "post_delay": 0,
        "next": [
            "EssenceFindLockItem"
        ],
        "on_error": [
            "EssenceFilterFinish"
        ]
    }
}
