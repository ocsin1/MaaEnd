        "desc": "废弃 Essence",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": "EssenceFindLockItem",
                "roi_offset": [
                    -46,
                    -8,
                    23,
                    17
                ],
                "template": "EssenceFilter/DiscardButton.png",
                "threshold": 0.8
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_delay": 300,
        "next": [
            "EssenceFilterAfterBattleCheckDiscarded",
            "EssenceFilterAfterBattleDiscardItem"
        ],
        "focus": {
            "Node.Action.Succeeded": "已废弃基质"
        }
    },
    "EssenceFilterAfterBattleCheckDiscarded": {
        "desc": "确认已废弃",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": "EssenceFindLockItem",
                "roi_offset": [
                    -46,
                    -8,
                    23,
                    17
                ],
                "template": "EssenceFilter/DiscardButtonDiscarded.png",
                "threshold": 0.8
            }
