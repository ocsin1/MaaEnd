{
    "EssenceFilterAfterBattleLockItemLog": {
        "desc": "日志：即将锁定Essence",
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "EssenceFilterTraceAction",
                "custom_action_param": {
                    "step": "LockItem"
                }
            }
        },
        "post_delay": 0,
        "next": [
            "EssenceFilterAfterBattleCheckLocked",
            "EssenceFilterAfterBattleLockItem"
        ]
    },
    "EssenceFilterAfterBattleLockItem": {
        "desc": "锁定Essence",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": "EssenceFindLockItem",
                "roi_offset": [
                    -8,
                    -7,
                    16,
                    15
                ],
                "template": "EssenceFilter/LockButton.png",
                "threshold": 0.8
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_delay": 300,
        "next": [
            "EssenceFilterAfterBattleCheckLocked",
            "EssenceFilterAfterBattleLockItem"
        ],
        "focus": {
            "Node.Action.Succeeded": "已锁定基质"
        }
    },
    "EssenceFilterAfterBattleCheckLocked": {
        "desc": "确认已上锁",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": "EssenceFindLockItem",
                "roi_offset": [
                    -8,
                    -7,
                    16,
                    15
                ],
                "template": "EssenceFilter/LockButtonLocked.png",
                "threshold": 0.8
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "EssenceFilterAfterBattleCloseDetail"
        ],
        "on_error": [
            "EssenceFilterAfterBattleLockItem"
        ],
        "focus": {
            "Node.Action.Succeeded": "已确认上锁"
        }
    },
    "EssenceFilterAfterBattleRecognitionLocked": {
        "desc": "识别：是否已上锁（仅识别，试最后一个时用）",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": "EssenceFindLockItem",
                "roi_offset": [
                    -8,
                    -7,
                    16,
                    15
                ],
                "template": "EssenceFilter/LockButtonLocked.png",
                "threshold": 0.8
            }
        },
        "pre_delay": 0,
        "post_delay": 0
    },
    "EssenceFilterAfterBattleDiscardItemLog": {
        "desc": "日志：即将废弃 Essence",
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "EssenceFilterTraceAction",
                "custom_action_param": {
                    "step": "DiscardItem"
                }
            }
        },
        "post_delay": 0,
        "next": [
