{
    //要想调用识别战斗后基质的话，只需要把"[Jumpback]EssenceFilterAfterBattleStart"插入到战斗结束，出现战利品界面的那个时间点对应的节点的next里面
    // ，任务跑完后会自动点击退出战利品界面，然后Jumpback回来的时候识别失败跳过自身，继续下一个节点
    //如果需要修改配置，那就在你的任务里面加上option来override掉"EssenceFilterAfterBattleInit"的"attach"部分即可
    //各个配置对应的功能同EssenceFilter
    "EssenceFilterAfterBattleStart": {
        "desc": "识别画面中是否有基质，是的话开始任务,完成后会自动退出战利品界面，要加Jumpback",
        //有基质才开始任务，不然直接返回失败
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    1280,
                    720
                ],
                "template": "EssenceFilter/EssenceGeneral.png",
                "method": 5,
                "threshold": 0.35
            }
        },
        "next": [
            "EssenceFilterAfterBattleInit"
        ]
    },
    "EssenceFilterAfterBattleExit": {
        "desc": "任务完成,点击离开",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    803,
                    616,
                    124,
                    83
                ],
                "template": "Common/Button/CancelButtonType1.png",
                "method": 5,
                "threshold": 0.35
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_delay": 0
    },
    "EssenceFilterAfterBattleInit": {
        "desc": "初始化：加载数据与预设[刷完基质版]",
        "pre_delay": 0,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "EssenceFilterInitAction"
            }
        },
        "post_wait_freezes": {
            "time": 50,
            "target": [
                38,
                398,
                922,
                198
            ]
        },
        "post_delay": 0,
        "next": [
            "EssenceFilterAfterBattleCloseDetail",
            "EssenceFilterFinish"
        ],
        "focus": {
            "Node.Action.Succeeded": "初始化完成"
        },
        "attach": {
            "rarity6_weapon": true,
            "rarity5_weapon": true,
            "rarity4_weapon": false,
            "flawless_essence": true,
            "pure_essence": false,
            "keep_future_promising": false,
            "future_promising_min_total": 6,
            "lock_future_promising": false,
            "keep_slot3_level3_practical": false,
            "slot3_min_level": 3,
            "lock_slot3_practical": false,
            "discard_unmatched": true,
            "export_calculator_script": false,
            "skip_locked_row": false
        }
    },
    "EssenceFullScreenDetectAll": {
        "desc": "战利品全屏模板匹配：收集所有基质图标（不点击）,给custom调用",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    1280,
                    720
                ],
                "template": "EssenceFilter/EssenceGeneral.png",
                "method": 5,
                "threshold": 0.35
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "DoNothing"
        },
        "post_delay": 0
    },
    "EssenceFindLockItem": {
        "desc": "查找上锁的图标",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    1280,
                    720
                ],
                "template": "EssenceFilter/LockButton.png",
                "threshold": 0.9,
                "order_by": "Score"
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "DoNothing"
        },
        "post_delay": 300,
        "next": [
            "EssenceFilterAfterBattleCheckItemSlot1"
        ],
        "focus": {
            "Node.Action.Succeeded": "基质未锁定"
        }
    }
}
