            "EssenceFilterAfterBattleDiscardItem"
        ],
        "focus": {
            //"Node.Action.Succeeded": "已确认废弃"
        }
    },
    "EssenceFilterAfterBattleCloseDetail": {
        "desc": "关闭详情页后继续处理下一个基质（Skip路径专用）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "EssenceFindLockItem",
                "roi_offset": [
                    -253,
                    -127,
                    157,
                    20
                ],
                "expected": [
                    "基质",
                    "基質",
                    "Essence",
                    "基質",
                    "기질"
                ],
                "threshold": 0.8
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    0,
                    0
                ]
            }
        },
        "next": [
            "EssenceFilterAfterBattleRowNextItem"
        ]
    },
    "EssenceFilterAfterBattleCloseDetailJumpback": {
        "desc": "如果基质详情页还在，则点击左上角，关闭基质详情，防遮挡（JumpBack专用）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "EssenceFindLockItem",
                "roi_offset": [
                    -253,
                    -127,
                    157,
                    20
                ],
                "expected": [
                    "基质",
                    "基質",
                    "Essence",
                    "基質",
                    "기질"
                ],
                "threshold": 0.8
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": [
                    0,
                    0
                ]
            }
        },
        "next": [
            //无next，用来触发Jumpback
        ]
    },
    "EssenceFilterAfterBattleRowNextItem": {
        "desc": "处理下一个命中的格子，识别不到则退出任务",
        "next": [
            "[JumpBack]EssenceFilterAfterBattleCloseDetailJumpback",
            "EssenceFilterAfterBattleNthRecognition",
            "EssenceFilterAfterBattleExit"
        ]
    },
    "EssenceFilterAfterBattleNthRecognition": {
        "desc": "按顺序返回识别结果，每次调用时index++",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "EssenceFilterAfterBattleNthRecognition",
                "custom_recognition_param": {
                    "recognitionNodeName": "EssenceFullScreenDetectAll"
                }
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 200,
        "post_delay": 0,
        "next": [
            "EssenceFindLockItem"
        ],
        "on_error": [
            "EssenceFilterAfterBattleExit"
        ]
    }
}
