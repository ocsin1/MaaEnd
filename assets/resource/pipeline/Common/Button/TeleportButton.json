{
    // 传送按钮。
    // 主节点对常态和悬停态模板做短路优先识别，命中后直接点击。
    "TeleportButton": {
        "desc": "传送按钮：按常态优先短路匹配常态与悬停态模板",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "__TeleportButton",
                    "__TeleportButtonHover"
                ]
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": {
            "time": 80,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "post_delay": 0,
        "rate_limit": 0
    },
    "__TeleportButton": {
        "desc": "传送按钮常态模板，在右下固定区域优先匹配",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1181,
                    611,
                    94,
                    102
                ],
                "template": [
                    "Common/Button/TeleportButton.png"
                ],
                "threshold": 0.9
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0
    },
    "__TeleportButtonHover": {
        "desc": "传送按钮悬停态模板，在常态未命中时作为回退匹配",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    1181,
                    611,
                    94,
                    102
                ],
                "template": [
                    "Common/Button/TeleportButtonHover.png"
                ],
                "threshold": 0.9
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0
    }
}
