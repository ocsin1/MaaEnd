    // 兼容 ESC 菜单的关闭入口。
    // 先复用普通关闭按钮识别，未命中时再尝试 ESCMenu 节点。
    "CloseButtonType2": {
        "desc": "通用关闭按钮类型2：在右上角关闭按钮基础上兼容 ESC 菜单",
        "recognition": {
            "type": "Or",
            "param": {
