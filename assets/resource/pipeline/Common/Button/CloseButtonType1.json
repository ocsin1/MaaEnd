{
    // 通用关闭按钮。
    // CloseButtonType1 只负责右上角关闭按钮模板的短路识别；CloseButtonType2 在此基础上再兼容 ESC 菜单关闭入口。
    "CloseButtonType1": {
        "desc": "通用关闭按钮类型1：右上角 X，仅覆盖普通关闭按钮，不兼容 ESC 菜单",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "__CloseButtonType1",
                    "__CloseButtonType2",
                    "__CloseButtonType3",
                    "__CloseButtonType4",
                    "__CloseButtonType5"
                ]
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": {
            "time": 80,
            "target": [
                0,
                0,
                0,
                0
            ]
        },
        "post_delay": 0,
        "rate_limit": 0
    },
