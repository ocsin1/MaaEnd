            "GiftOperatorGiftSelected"
        ]
    },
    "GiftOperatorConfirmGift": {
        "desc": "点击赠送按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "YellowButtonBackground",
                    "GiftOperatorConfirmGiftText"
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": {
            "time": 200,
            "timeout": 3000
        },
        "next": [
            "[JumpBack]GiftOperatorGiftDialog",
            "GiftOperatorLeave"
        ]
    },
    "GiftOperatorConfirmGiftText": {
        "desc": "确认赠送按钮上有文字，避免误点",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "YellowButtonBackground",
                "expected": [
                    "确认赠送",
                    "確定贈送",
                    "Confirm",
                    "贈る"
                ]
            }
        }
    },
    "GiftOperatorGiftDialog": {
