    "GiftOperatorBranchReceive": {
        "desc": "分支2：干员给你送礼，点击领取",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    900,
                    334,
                    350,
                    318
                ],
                "expected": [
                    "收下礼物",
                    "收下禮物",
                    "(?i)Accept\\s*gift",
                    "プレゼントを受け取る"
                ]
            }
        },
        "pre_wait_freezes": {
            "time": 200,
            "timeout": 3000,
            "target": [
                1008,
                474,
                84,
                38
            ]
