{
    "GiftOperatorBranchGift": {
        "desc": "分支1：可以赠送礼物",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    900,
                    334,
                    350,
                    318
                ],
                "expected": [
                    "赠送礼物",
                    "贈送禮物",
                    "(?i)Offering\\s*Gifts",
                    "プレゼントを贈る"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "GiftOperatorGiftUI"
        ]
    },
    "GiftOperatorBranchMaxAffinity": {
