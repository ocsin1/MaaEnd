    "GiftOperatorMoveFail": {
        "desc": "移动未能接触到干员，炸掉程序",
        "action": "Custom",
        "custom_action": "ERROR", //引发一个错误来结束当前任务并留下截图
        "focus": {
            "Node.Recognition.Succeeded": "$task.GiftOperator.focus.move_fail"
        }
    },
    "GiftOperatorMoveLocation1": {
        "desc": "转向270度(正西)尝试接触到干员(预设位置1)",
        "max_hit": 2,
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "MapNavigateAction",
                "custom_action_param": {
                    "path": [
                        {
                            "action": "HEADING",
                            "angle": 270,
                            "zone_id": "OMVBase01"
                        }
                    ]
                }
            }
        },
        "post_delay": 1000 //需要等待角色彻底停下
    },
